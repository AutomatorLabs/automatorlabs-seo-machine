---
import Layout from '../layouts/Layout.astro';
import NewsletterCta from './NewsletterCta.astro';
import {
  calculatorConfigs,
  type CalculatorFaq,
  type CalculatorInput,
  type CalculatorOutput,
  type CalculatorResultExplanation,
} from '../data/calculators';
import {
  createCommonMistakes,
  createHowToSteps,
  createResultExplanations,
} from '../lib/calculator-education';
import { calculatorWorkedExamples } from '../data/calculator-examples';
import { calculatorTableHeadings } from '../lib/calculator-tables';

interface RelatedItem {
  title: string;
  url: string;
}

interface Props {
  title: string;
  eyebrow: string;
  description: string;
  inputs: CalculatorInput[];
  outputs: CalculatorOutput[];
  faq: CalculatorFaq[];
  relatedItems: RelatedItem[];
  guideItems?: RelatedItem[];
  exampleItems?: RelatedItem[];
  exampleHeading?: string;
  chart?: boolean;
  howToSteps?: string[];
  resultExplanation?: CalculatorResultExplanation[];
  commonMistakes?: string[];
}

const {
  title,
  eyebrow,
  description,
  inputs,
  outputs,
  faq,
  relatedItems,
  guideItems = [],
  exampleItems = [],
  exampleHeading = 'Compound Interest Examples',
  chart: configuredChart,
  howToSteps: configuredHowToSteps,
  resultExplanation: configuredResultExplanation,
  commonMistakes: configuredCommonMistakes,
} = Astro.props;

const calculatorConfig = Object.values(calculatorConfigs).find(
  (config) => config.url === Astro.url.pathname,
);
const tableHeading = calculatorConfig
  ? calculatorTableHeadings[calculatorConfig.id]
  : undefined;
const workedExample = calculatorConfig
  ? calculatorWorkedExamples[calculatorConfig.url]
  : undefined;
const chart = configuredChart ?? calculatorConfig?.chart ?? false;
const howToSteps =
  configuredHowToSteps ?? createHowToSteps(title, inputs);
const resultExplanation =
  configuredResultExplanation ??
  createResultExplanations(title, inputs, outputs);
const commonMistakes =
  configuredCommonMistakes ?? createCommonMistakes(title);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: title,
  description,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  url: new URL(Astro.url.pathname, Astro.site).toString(),
};
const structuredDataJson = JSON.stringify(structuredData).replace(
  /</g,
  '\\u003c',
);
const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
const faqStructuredDataJson = JSON.stringify(faqStructuredData).replace(
  /</g,
  '\\u003c',
);
---

<Layout title={title} description={description}>
  <script
    type="application/ld+json"
    set:html={structuredDataJson}
  />
  <script
    type="application/ld+json"
    set:html={faqStructuredDataJson}
  />

  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li aria-current="page">{title}</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="intro">{description}</p>
    </header>

    <section class="calculator" aria-labelledby="calculator-heading">
      <div class="panel">
        <h2 id="calculator-heading">Calculate your investment growth</h2>

        <form id="calculator-form">
          <div class="form-grid">
            {inputs.map((input) => (
              <div class:list={['field', { 'field-wide': input.wide }]}>
                <label for={input.id}>{input.label}</label>

                {input.type === 'select' ? (
                  <select id={input.id} name={input.name} required={input.required}>
                    {input.options?.map((option) => (
                      <option
                        value={option.value}
                        selected={option.value === input.value}
                      >
                        {option.label}
                      </option>
                    ))}
                  </select>
                ) : input.prefix ? (
                  <div class="input-with-prefix">
                    <span aria-hidden="true">{input.prefix}</span>
                    <input
                      id={input.id}
                      name={input.name}
                      type="text"
                      inputmode="decimal"
                      min={input.min}
                      step={input.step}
                      value={input.value.replace(/[$,\s]/g, '')}
                      data-currency-input
                      required={input.required}
                    />
                  </div>
                ) : (
                  <input
                    id={input.id}
                    name={input.name}
                    type="number"
                    min={input.min}
                    step={input.step}
                    value={input.value}
                    required={input.required}
                  />
                )}
              </div>
            ))}
          </div>

          <p id="form-error" class="error" role="alert" hidden>
            Enter valid, non-negative values in every field.
          </p>
          <p id="form-warning" class="warning" role="status" hidden></p>

          <button type="submit">Calculate</button>
        </form>

        <script is:inline>
          (() => {
            const form = document.querySelector('#calculator-form');
            if (!form || !window.location.search) return;

            const params = new URLSearchParams(window.location.search);

            for (const field of form.elements) {
              if (
                !(field instanceof HTMLInputElement) &&
                !(field instanceof HTMLSelectElement)
              ) {
                continue;
              }

              const queryValue = params.get(field.name);
              if (queryValue === null) continue;

              if (field instanceof HTMLSelectElement) {
                if (
                  Array.from(field.options).some(
                    (option) => option.value === queryValue,
                  )
                ) {
                  field.value = queryValue;
                }
                continue;
              }

              const normalizedValue = queryValue.replace(/[$,\s]/g, '');
              const numericValue = Number(normalizedValue);
              const minimum = field.min === '' ? null : Number(field.min);
              const maximum = field.max === '' ? null : Number(field.max);

              if (
                normalizedValue === '' ||
                !Number.isFinite(numericValue) ||
                (minimum !== null && numericValue < minimum) ||
                (maximum !== null && numericValue > maximum)
              ) {
                continue;
              }

              field.value = normalizedValue;
            }
          })();
        </script>
      </div>

      <section class="results panel" aria-labelledby="results-heading" aria-live="polite">
        <h2 id="results-heading">Your results</h2>
        <dl>
          {outputs.map((output) => (
            <div class:list={{ 'primary-result': output.primary }}>
              <dt>{output.label}</dt>
              <dd id={output.id}>{output.initialValue}</dd>
            </div>
          ))}
        </dl>

        <div id="share-calculation-controls" class="share-results" hidden>
          <button id="share-calculation" class="copy-link" type="button">
            Share calculation
          </button>
          <span
            id="share-calculation-status"
            class="copy-link-status"
            role="status"
            aria-live="polite"
          ></span>
        </div>

        {chart && (
          <div
            id="chart"
            role="img"
            aria-label={`${title} chart`}
          ></div>
        )}
      </section>
    </section>

    {tableHeading && calculatorConfig && (
      <section
        id="result-table-section"
        class="content-section result-table-section"
        data-calculator-id={calculatorConfig.id}
        aria-labelledby="result-table-heading"
        hidden
      >
        <h2 id="result-table-heading">{tableHeading}</h2>
        <p id="result-table-warning" class="table-warning" role="status" hidden></p>
        <div class="table-scroll">
          <table>
            <thead>
              <tr id="result-table-head"></tr>
            </thead>
            <tbody id="result-table-body"></tbody>
          </table>
        </div>
      </section>
    )}

    <section class="education-grid" aria-label="Calculator guidance">
      <section class="content-section education-section" aria-labelledby="how-to-heading">
        <h2 id="how-to-heading">How to Use This Calculator</h2>
        <ol class="guidance-list">
          {howToSteps.map((step) => <li>{step}</li>)}
        </ol>
      </section>

      <section
        class="content-section education-section"
        aria-labelledby="understanding-results-heading"
      >
        <h2 id="understanding-results-heading">Understanding the Results</h2>
        <dl class="result-explanations">
          {resultExplanation.map((result) => (
            <div>
              <dt>{result.label}</dt>
              <dd>{result.explanation}</dd>
            </div>
          ))}
        </dl>
      </section>
    </section>

    <section
      class="content-section mistakes-section"
      aria-labelledby="common-mistakes-heading"
    >
      <h2 id="common-mistakes-heading">Common Mistakes</h2>
      <ul class="guidance-list">
        {commonMistakes.map((mistake) => <li>{mistake}</li>)}
      </ul>
    </section>

    {workedExample && (
      <section
        class="content-section worked-example"
        aria-labelledby="worked-example-heading"
      >
        <h2 id="worked-example-heading">Worked Example</h2>
        <div class="worked-example-grid">
          <div>
            <h3>Example inputs</h3>
            <dl>
              {workedExample.inputs.map((input) => (
                <div>
                  <dt>{input.label}</dt>
                  <dd>{input.value}</dd>
                </div>
              ))}
            </dl>
          </div>
          <div>
            <h3>Example results</h3>
            <dl>
              {workedExample.outputs.map((output) => (
                <div>
                  <dt>{output.label}</dt>
                  <dd>{output.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
        <p class="worked-example-interpretation">
          {workedExample.interpretation}
        </p>
      </section>
    )}

    <NewsletterCta />

    <section class="content-section" aria-labelledby="faq-heading">
      <h2 id="faq-heading">Frequently asked questions</h2>

      <div class="faq-list">
        {faq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    {relatedItems.length > 0 && (
      <section class="content-section" aria-labelledby="related-heading">
        <h2 id="related-heading">Related Calculators</h2>
        <nav class="related-links" aria-label="Related calculators">
          {relatedItems.map((item) => (
            <a href={item.url}>{item.title}</a>
          ))}
        </nav>
      </section>
    )}

    {exampleItems.length > 0 && (
      <section class="content-section" aria-labelledby="examples-heading">
        <h2 id="examples-heading">{exampleHeading}</h2>
        <nav class="related-links" aria-label={exampleHeading}>
          {exampleItems.map((item) => (
            <a href={item.url}>{item.title}</a>
          ))}
        </nav>
      </section>
    )}

    {guideItems.length > 0 && (
      <section class="content-section" aria-labelledby="related-guides-heading">
        <h2 id="related-guides-heading">Related Guides</h2>
        <nav class="related-links" aria-label="Related guides">
          {guideItems.map((item) => (
            <a href={item.url}>{item.title}</a>
          ))}
        </nav>
      </section>
    )}
  </main>

  <slot />
</Layout>

<script>
  import { buildCalculatorTable } from '../lib/calculator-tables';

  const shareControls = document.querySelector<HTMLElement>(
    '#share-calculation-controls',
  );
  const copyLinkButton = document.querySelector<HTMLButtonElement>(
    '#share-calculation',
  );
  const copyLinkStatus =
    document.querySelector<HTMLElement>('#share-calculation-status');
  let copyStatusTimeout: number | undefined;

  window.addEventListener('calculator:success', () => {
    if (shareControls) {
      shareControls.hidden = false;
    }

    const tableSection = document.querySelector<HTMLElement>(
      '#result-table-section',
    );
    const form = document.querySelector<HTMLFormElement>('#calculator-form');
    const tableHeading =
      document.querySelector<HTMLElement>('#result-table-heading');
    const tableHead = document.querySelector<HTMLTableRowElement>(
      '#result-table-head',
    );
    const tableBody =
      document.querySelector<HTMLTableSectionElement>('#result-table-body');
    const tableWarning =
      document.querySelector<HTMLElement>('#result-table-warning');

    if (
      !tableSection ||
      !form ||
      !tableHeading ||
      !tableHead ||
      !tableBody ||
      !tableWarning
    ) {
      return;
    }

    const tableData = buildCalculatorTable(
      tableSection.dataset.calculatorId ?? '',
      form,
    );

    if (!tableData) {
      return;
    }

    tableHeading.textContent = tableData.heading;
    tableHead.replaceChildren(
      ...tableData.columns.map((column) => {
        const heading = document.createElement('th');
        heading.scope = 'col';
        heading.textContent = column;
        return heading;
      }),
    );
    tableBody.replaceChildren(
      ...tableData.rows.map((row) => {
        const tableRow = document.createElement('tr');
        tableRow.replaceChildren(
          ...row.map((cell, index) => {
            const element = document.createElement(index === 0 ? 'th' : 'td');
            if (element instanceof HTMLTableCellElement && index === 0) {
              element.scope = 'row';
            }
            element.textContent = cell;
            return element;
          }),
        );
        return tableRow;
      }),
    );
    tableWarning.textContent = tableData.warning ?? '';
    tableWarning.hidden = !tableData.warning;
    tableSection.hidden = false;
  });

  async function copyCurrentUrl(): Promise<void> {
    if (!copyLinkStatus) {
      return;
    }

    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(window.location.href);
      } else {
        const textArea = document.createElement('textarea');
        textArea.value = window.location.href;
        textArea.style.position = 'fixed';
        textArea.style.opacity = '0';
        document.body.append(textArea);
        textArea.select();

        const copied = document.execCommand('copy');
        textArea.remove();

        if (!copied) {
          throw new Error('Copy command failed');
        }
      }

      copyLinkStatus.textContent = '✓ Copied!';
    } catch {
      copyLinkStatus.textContent = 'Unable to copy';
    }

    window.clearTimeout(copyStatusTimeout);
    copyStatusTimeout = window.setTimeout(() => {
      if (copyLinkStatus) {
        copyLinkStatus.textContent = '';
      }
    }, 2000);
  }

  copyLinkButton?.addEventListener('click', copyCurrentUrl);

  document.querySelectorAll<HTMLInputElement>('[data-currency-input]').forEach(
    (input) => {
      input.addEventListener('input', () => {
        const normalized = input.value.replace(/[$,\s]/g, '');

        if (normalized !== input.value) {
          input.value = normalized;
        }
      });
    },
  );
</script>

<style>
  :global(body) {
    background: var(--page-background);
    line-height: 1.6;
  }

  main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .page-header {
    max-width: 760px;
    margin-bottom: 2.5rem;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .breadcrumbs li + li::before {
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a {
    color: var(--link-color);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--text-color);
    font-weight: 650;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    color: var(--link-color);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 0.8rem;
    font-size: clamp(2.15rem, 6vw, 3.75rem);
    line-height: 1.08;
    letter-spacing: -0.045em;
  }

  h2 {
    margin-bottom: 1.25rem;
    font-size: 1.35rem;
    line-height: 1.25;
  }

  .intro {
    max-width: 680px;
    margin-bottom: 0;
    color: var(--muted-text-color);
    font-size: 1.08rem;
  }

  .calculator {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: 1.25rem;
    align-items: start;
  }

  .panel,
  .content-section {
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--card-background);
    box-shadow: 0 12px 35px var(--shadow-color);
  }

  .panel {
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .calculator > .panel:first-child {
    background: var(--form-background);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field-wide {
    grid-column: 1 / -1;
  }

  label {
    font-size: 0.9rem;
    font-weight: 650;
  }

  input,
  select {
    width: 100%;
    min-height: 46px;
    border: 1px solid var(--input-border);
    border-radius: 9px;
    background: var(--input-background);
    color: var(--input-text);
    font: inherit;
    padding: 0.65rem 0.75rem;
  }

  input:focus,
  select:focus {
    border-color: var(--link-color);
    outline: 3px solid var(--focus-ring);
  }

  .input-with-prefix {
    position: relative;
  }

  .input-with-prefix span {
    position: absolute;
    top: 50%;
    left: 0.8rem;
    color: var(--muted-text-color);
    transform: translateY(-50%);
    pointer-events: none;
  }

  .input-with-prefix input {
    padding-left: 1.75rem;
  }

  button {
    width: 100%;
    margin-top: 1.25rem;
    border: 0;
    border-radius: 9px;
    background: var(--button-background);
    color: var(--button-text);
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    padding: 0.8rem 1rem;
    transition:
      background 150ms ease,
      transform 150ms ease;
  }

  button:hover {
    background: var(--button-hover-background);
  }

  button:active {
    transform: translateY(1px);
  }

  button:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: 3px;
  }

  .error {
    margin: 1rem 0 0;
    color: var(--error-text);
    font-size: 0.9rem;
  }

  .warning {
    margin: 1rem 0 0;
    color: var(--warning-text);
    font-size: 0.9rem;
  }

  .results dl {
    display: grid;
    gap: 0;
    margin: 0;
  }

  .results dl > div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--border-subtle);
    padding: 1rem 0;
  }

  .results dl > div:first-child {
    padding-top: 0;
  }

  .results dt {
    color: var(--muted-text-color);
  }

  .results dd {
    margin: 0;
    font-weight: 750;
    text-align: right;
  }

  .results .primary-result dd {
    color: var(--link-color);
    font-size: 1.25rem;
  }

  .share-results {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .share-results[hidden] {
    display: none;
  }

  .copy-link {
    width: auto;
    margin: 0;
    border: 1px solid var(--border-color);
    background: var(--subtle-background);
    color: var(--link-color);
    padding: 0.65rem 0.9rem;
  }

  .copy-link:hover {
    border-color: var(--link-color);
    background: var(--card-background);
  }

  .copy-link-status {
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  #chart {
    height: clamp(360px, 38vw, 400px);
    min-height: 360px;
    margin-top: 1.5rem;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--chart-background);
    color: var(--muted-text-color);
    padding: 1rem;
    overflow: hidden;
  }

  :global(#chart svg) {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
  }

  :global(#chart .chart-state) {
    display: grid;
    min-height: 100%;
    margin: 0;
    color: var(--muted-text-color);
    font-size: 1rem;
    line-height: 1.6;
    place-items: center;
    text-align: center;
  }

  :global(#chart .chart-tooltip) {
    font-size: 0.95rem;
  }

  .content-section {
    margin-top: 1.25rem;
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .result-table-section[hidden] {
    display: none;
  }

  .table-scroll {
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .result-table-section table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
    color: var(--text-color);
    font-variant-numeric: tabular-nums;
  }

  .result-table-section th,
  .result-table-section td {
    border-bottom: 1px solid var(--border-subtle);
    padding: 0.8rem 0.9rem;
    text-align: right;
    white-space: nowrap;
  }

  .result-table-section th:first-child,
  .result-table-section td:first-child {
    text-align: left;
  }

  .result-table-section thead th {
    background: var(--subtle-background);
    color: var(--heading-color);
    font-size: 0.85rem;
    font-weight: 750;
  }

  .result-table-section tbody th {
    color: var(--text-color);
    font-weight: 700;
  }

  .result-table-section tbody tr:last-child th,
  .result-table-section tbody tr:last-child td {
    border-bottom: 0;
  }

  .table-warning {
    margin: 0 0 1rem;
    color: var(--warning-text);
  }

  .education-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    margin-top: 1.25rem;
  }

  .education-grid .content-section {
    margin-top: 0;
  }

  .education-section,
  .mistakes-section,
  .worked-example {
    background: var(--card-background);
  }

  .guidance-list {
    display: grid;
    gap: 0.8rem;
    margin: 0;
    padding-left: 1.25rem;
    color: var(--text-color);
  }

  .guidance-list li {
    padding-left: 0.2rem;
  }

  .guidance-list li::marker {
    color: var(--link-color);
    font-weight: 750;
  }

  .result-explanations {
    display: grid;
    gap: 1rem;
    margin: 0;
  }

