---
import Layout from '../layouts/Layout.astro';
import type {
  CalculatorFaq,
  CalculatorInput,
  CalculatorOutput,
} from '../data/calculators';

interface RelatedItem {
  title: string;
  url: string;
}

interface Props {
  title: string;
  eyebrow: string;
  description: string;
  inputs: CalculatorInput[];
  outputs: CalculatorOutput[];
  faq: CalculatorFaq[];
  relatedItems: RelatedItem[];
}

const {
  title,
  eyebrow,
  description,
  inputs,
  outputs,
  faq,
  relatedItems,
} = Astro.props;
---

<Layout title={title} description={description}>
  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li aria-current="page">{title}</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="intro">{description}</p>
    </header>

    <section class="calculator" aria-labelledby="calculator-heading">
      <div class="panel">
        <h2 id="calculator-heading">Calculate your investment growth</h2>

        <form id="calculator-form">
          <div class="form-grid">
            {inputs.map((input) => (
              <div class:list={['field', { 'field-wide': input.wide }]}>
                <label for={input.id}>{input.label}</label>

                {input.type === 'select' ? (
                  <select id={input.id} name={input.name} required={input.required}>
                    {input.options?.map((option) => (
                      <option
                        value={option.value}
                        selected={option.value === input.value}
                      >
                        {option.label}
                      </option>
                    ))}
                  </select>
                ) : input.prefix ? (
                  <div class="input-with-prefix">
                    <span aria-hidden="true">{input.prefix}</span>
                    <input
                      id={input.id}
                      name={input.name}
                      type="text"
                      inputmode="decimal"
                      min={input.min}
                      step={input.step}
                      value={input.value.replace(/[$,\s]/g, '')}
                      data-currency-input
                      required={input.required}
                    />
                  </div>
                ) : (
                  <input
                    id={input.id}
                    name={input.name}
                    type="number"
                    min={input.min}
                    step={input.step}
                    value={input.value}
                    required={input.required}
                  />
                )}
              </div>
            ))}
          </div>

          <p id="form-error" class="error" role="alert" hidden>
            Enter valid, non-negative values in every field.
          </p>
          <p id="form-warning" class="warning" role="status" hidden></p>

          <button type="submit">Calculate</button>
        </form>

        <script is:inline>
          (() => {
            const form = document.querySelector('#calculator-form');
            if (!form || !window.location.search) return;

            const params = new URLSearchParams(window.location.search);

            for (const field of form.elements) {
              if (
                !(field instanceof HTMLInputElement) &&
                !(field instanceof HTMLSelectElement)
              ) {
                continue;
              }

              const queryValue = params.get(field.name);
              if (queryValue === null) continue;

              if (field instanceof HTMLSelectElement) {
                if (
                  Array.from(field.options).some(
                    (option) => option.value === queryValue,
                  )
                ) {
                  field.value = queryValue;
                }
                continue;
              }

              const normalizedValue = queryValue.replace(/[$,\s]/g, '');
              const numericValue = Number(normalizedValue);
              const minimum = field.min === '' ? null : Number(field.min);
              const maximum = field.max === '' ? null : Number(field.max);

              if (
                normalizedValue === '' ||
                !Number.isFinite(numericValue) ||
                (minimum !== null && numericValue < minimum) ||
                (maximum !== null && numericValue > maximum)
              ) {
                continue;
              }

              field.value = normalizedValue;
            }
          })();
        </script>
      </div>

      <section class="results panel" aria-labelledby="results-heading" aria-live="polite">
        <h2 id="results-heading">Your results</h2>
        <dl>
          {outputs.map((output) => (
            <div class:list={{ 'primary-result': output.primary }}>
              <dt>{output.label}</dt>
              <dd id={output.id}>{output.initialValue}</dd>
            </div>
          ))}
        </dl>

        <div class="share-results">
          <button id="copy-calculator-link" class="copy-link" type="button">
            Copy link
          </button>
          <span
            id="copy-link-status"
            class="copy-link-status"
            role="status"
            aria-live="polite"
          ></span>
        </div>

        <div id="chart" aria-label="Investment growth chart placeholder">
          <span>Growth chart coming soon</span>
        </div>
      </section>
    </section>

    <section class="content-section" aria-labelledby="faq-heading">
      <h2 id="faq-heading">Frequently asked questions</h2>

      <div class="faq-list">
        {faq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    {relatedItems.length > 0 && (
      <section class="content-section" aria-labelledby="related-heading">
        <h2 id="related-heading">Related Calculators</h2>
        <nav class="related-links" aria-label="Related calculators">
          {relatedItems.map((item) => (
            <a href={item.url}>{item.title}</a>
          ))}
        </nav>
      </section>
    )}
  </main>

  <slot />
</Layout>

<script>
  const copyLinkButton = document.querySelector<HTMLButtonElement>(
    '#copy-calculator-link',
  );
  const copyLinkStatus =
    document.querySelector<HTMLElement>('#copy-link-status');
  let copyStatusTimeout: number | undefined;

  async function copyCurrentUrl(): Promise<void> {
    if (!copyLinkStatus) {
      return;
    }

    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(window.location.href);
      } else {
        const textArea = document.createElement('textarea');
        textArea.value = window.location.href;
        textArea.style.position = 'fixed';
        textArea.style.opacity = '0';
        document.body.append(textArea);
        textArea.select();

        const copied = document.execCommand('copy');
        textArea.remove();

        if (!copied) {
          throw new Error('Copy command failed');
        }
      }

      copyLinkStatus.textContent = 'Link copied';
    } catch {
      copyLinkStatus.textContent = 'Unable to copy link';
    }

    window.clearTimeout(copyStatusTimeout);
    copyStatusTimeout = window.setTimeout(() => {
      if (copyLinkStatus) {
        copyLinkStatus.textContent = '';
      }
    }, 2500);
  }

  copyLinkButton?.addEventListener('click', copyCurrentUrl);

  document.querySelectorAll<HTMLInputElement>('[data-currency-input]').forEach(
    (input) => {
      input.addEventListener('input', () => {
        const normalized = input.value.replace(/[$,\s]/g, '');

        if (normalized !== input.value) {
          input.value = normalized;
        }
      });
    },
  );
</script>

<style>
  :global(body) {
    background: var(--page-background);
    line-height: 1.6;
  }

  main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .page-header {
    max-width: 760px;
    margin-bottom: 2.5rem;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .breadcrumbs li + li::before {
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a {
    color: var(--link-color);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--text-color);
    font-weight: 650;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    color: var(--link-color);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 0.8rem;
    font-size: clamp(2.15rem, 6vw, 3.75rem);
    line-height: 1.08;
    letter-spacing: -0.045em;
  }

  h2 {
    margin-bottom: 1.25rem;
    font-size: 1.35rem;
    line-height: 1.25;
  }

  .intro {
    max-width: 680px;
    margin-bottom: 0;
    color: var(--muted-text-color);
    font-size: 1.08rem;
  }

  .calculator {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: 1.25rem;
    align-items: start;
  }

  .panel,
  .content-section {
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--card-background);
    box-shadow: 0 12px 35px var(--shadow-color);
  }

  .panel {
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .calculator > .panel:first-child {
    background: var(--form-background);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field-wide {
    grid-column: 1 / -1;
  }

  label {
    font-size: 0.9rem;
    font-weight: 650;
  }

  input,
  select {
    width: 100%;
    min-height: 46px;
    border: 1px solid var(--input-border);
    border-radius: 9px;
    background: var(--input-background);
    color: var(--input-text);
    font: inherit;
    padding: 0.65rem 0.75rem;
  }

  input:focus,
  select:focus {
    border-color: var(--link-color);
    outline: 3px solid var(--focus-ring);
  }

  .input-with-prefix {
    position: relative;
  }

  .input-with-prefix span {
    position: absolute;
    top: 50%;
    left: 0.8rem;
    color: var(--muted-text-color);
    transform: translateY(-50%);
    pointer-events: none;
  }

  .input-with-prefix input {
    padding-left: 1.75rem;
  }

  button {
    width: 100%;
    margin-top: 1.25rem;
    border: 0;
    border-radius: 9px;
    background: var(--button-background);
    color: var(--button-text);
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    padding: 0.8rem 1rem;
    transition:
      background 150ms ease,
      transform 150ms ease;
  }

  button:hover {
    background: var(--button-hover-background);
  }

  button:active {
    transform: translateY(1px);
  }

  button:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: 3px;
  }

  .error {
    margin: 1rem 0 0;
    color: var(--error-text);
    font-size: 0.9rem;
  }

  .warning {
    margin: 1rem 0 0;
    color: var(--warning-text);
    font-size: 0.9rem;
  }

  .results dl {
    display: grid;
    gap: 0;
    margin: 0;
  }

  .results dl > div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--border-subtle);
    padding: 1rem 0;
  }

  .results dl > div:first-child {
    padding-top: 0;
  }

  .results dt {
    color: var(--muted-text-color);
  }

  .results dd {
    margin: 0;
    font-weight: 750;
    text-align: right;
  }

  .results .primary-result dd {
    color: var(--link-color);
    font-size: 1.25rem;
  }

  .share-results {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .copy-link {
    width: auto;
    margin: 0;
    border: 1px solid var(--border-color);
    background: var(--subtle-background);
    color: var(--link-color);
    padding: 0.65rem 0.9rem;
  }

  .copy-link:hover {
    border-color: var(--link-color);
    background: var(--card-background);
  }

  .copy-link-status {
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  #chart {
    display: grid;
    min-height: 190px;
    margin-top: 1.5rem;
    border: 1px dashed var(--input-border);
    border-radius: 10px;
    background: var(--chart-background);
    color: var(--muted-text-color);
    place-items: center;
  }

  #chart span {
    font-size: 0.9rem;
  }

  .content-section {
    margin-top: 1.25rem;
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .content-section:has(.faq-list) {
    background: var(--faq-background);
  }

  .faq-list {
    border-top: 1px solid var(--border-subtle);
    background: var(--faq-background);
  }

  details {
    border-bottom: 1px solid var(--border-subtle);
    padding: 1rem 0;
  }

  summary {
    cursor: pointer;
    font-weight: 700;
  }

  details p {
    max-width: 760px;
    margin: 0.65rem 0 0;
    color: var(--muted-text-color);
  }

  .related-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .related-links a {
    border: 1px solid var(--border-color);
    border-radius: 10px;
    color: var(--link-color);
    font-weight: 650;
    padding: 0.9rem 1rem;
    text-decoration: none;
  }

  .related-links a:hover {
    border-color: var(--link-color);
    background: var(--subtle-background);
  }

  @media (max-width: 760px) {
    main {
      padding: 2.75rem 0;
    }

    .calculator,
    .related-links {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .form-grid {
      grid-template-columns: 1fr;
    }

    .field-wide {
      grid-column: auto;
    }

    .results dl > div {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.2rem;
    }

    .results dd {
      text-align: left;
    }
  }
</style>
