---
import type { CalculatorConfig } from '../data/calculators';
import { contentItems } from '../data/content';
import { featuredInvestmentGrowthSeoRecords } from '../data/programmatic-seo/investment-growth';
import CalculatorPage from './CalculatorPage.astro';

interface Props {
  calculator: CalculatorConfig;
  periodsPerYear: number;
}

const { calculator, periodsPerYear } = Astro.props;
const relatedItems = calculator.relatedIds.flatMap((id) => {
  const item = contentItems.find((candidate) => candidate.id === id);
  return item ? [{ title: item.title, url: item.url }] : [];
});
const guideItems = [
  ...(calculator.id === 'investment-growth'
    ? [
        {
          title: 'Investment Growth Guide',
          url: '/guides/investment-growth/',
        },
      ]
    : []),
  {
    title: 'APR vs APY',
    url: '/guides/apr-vs-apy/',
  },
  {
    title: 'Daily vs Monthly Compounding',
    url: '/guides/daily-vs-monthly-compounding/',
  },
  {
    title: 'Effective Annual Rate Explained',
    url: '/guides/effective-annual-rate/',
  },
];
const exampleItems =
  calculator.id === 'investment-growth'
    ? [
        {
          title: 'Browse all 200 investment growth examples',
          url: '/calculators/investment-growth/examples/',
        },
        ...featuredInvestmentGrowthSeoRecords.map((record) => ({
          title: record.question,
          url: `/calculators/investment-growth/${record.slug}/`,
        })),
      ]
    : [];
---

<CalculatorPage
  title={calculator.title}
  eyebrow={calculator.eyebrow}
  description={calculator.description}
  inputs={calculator.inputs}
  outputs={calculator.outputs}
  faq={calculator.faq}
  relatedItems={relatedItems}
  guideItems={guideItems}
  exampleItems={exampleItems}
  exampleHeading="Investment Growth Examples"
  calculatorData={{
    'periods-per-year': periodsPerYear,
    'tracking-id': calculator.id,
  }}
>
  <script>
    import { trackSuccessfulCalculation } from '../lib/analytics';
    import { parseCalculatorNumber } from '../lib/input';
    import { calculateCompoundInterest } from '../lib/math';

    const form = document.querySelector<HTMLFormElement>('#calculator-form');
    const error = document.querySelector<HTMLElement>('#form-error');
    const finalBalance =
      document.querySelector<HTMLElement>('#final-balance');
    const totalContributions = document.querySelector<HTMLElement>(
      '#total-contributions',
    );
    const totalInterest =
      document.querySelector<HTMLElement>('#total-interest');
    const periodsPerYear = Number(form?.dataset.periodsPerYear ?? 12);
    const trackingId =
      form?.dataset.trackingId ?? 'compound_growth_variant';
    const currency = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 2,
    });

    function calculate() {
      if (
        !form ||
        !error ||
        !finalBalance ||
        !totalContributions ||
        !totalInterest
      ) {
        return false;
      }

      const data = new FormData(form);
      const principal = parseCalculatorNumber(data.get('principal'));
      const monthlyContribution = parseCalculatorNumber(
        data.get('monthlyContribution'),
      );
      const annualRatePercent = parseCalculatorNumber(
        data.get('interestRate'),
      );
      const years = parseCalculatorNumber(data.get('years'));

      if (
        !Number.isFinite(principal) ||
        !Number.isFinite(monthlyContribution) ||
        !Number.isFinite(annualRatePercent) ||
        !Number.isFinite(years) ||
        principal < 0 ||
        monthlyContribution < 0 ||
        annualRatePercent < 0 ||
        years <= 0
      ) {
        error.textContent =
          'Starting amount, contribution, and rate cannot be negative. Years must be greater than 0.';
        error.hidden = false;
        return false;
      }

      error.hidden = true;
      const result = calculateCompoundInterest({
        principal,
        monthlyContribution,
        annualRatePercent,
        years,
        periodsPerYear,
      });

      finalBalance.textContent = currency.format(result.finalBalance);
      totalContributions.textContent = currency.format(
        result.totalContributions,
      );
      totalInterest.textContent = currency.format(result.totalInterest);
      return true;
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      trackSuccessfulCalculation(trackingId, calculate);
    });

    calculate();
  </script>
</CalculatorPage>
