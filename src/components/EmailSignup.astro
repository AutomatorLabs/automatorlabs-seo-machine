<section class="email-signup" aria-labelledby="email-signup-heading">
  <div class="email-signup-copy">
    <p class="email-signup-label">Stay in the loop</p>
    <h2 id="email-signup-heading">
      Get new calculators, guides, and money tools when they launch.
    </h2>
    <p>
      A simple launch update for useful new resources. No account is required.
    </p>
  </div>

  <form class="email-signup-form" data-email-signup-form>
    <label for="email-signup-address">Email address</label>
    <div class="email-signup-fields">
      <input
        id="email-signup-address"
        name="email"
        type="email"
        autocomplete="email"
        inputmode="email"
        placeholder="you@example.com"
        required
      />
      <button type="submit">Notify me</button>
    </div>
    <p
      class="email-signup-status"
      data-email-signup-status
      role="status"
      aria-live="polite"
    ></p>
  </form>
</section>

<script>
  document
    .querySelectorAll<HTMLFormElement>('[data-email-signup-form]')
    .forEach((form) => {
      if (form.dataset.ready === 'true') return;
      form.dataset.ready = 'true';

      form.addEventListener('submit', (event) => {
        event.preventDefault();
        if (!form.reportValidity()) return;

        const status = form.querySelector<HTMLElement>(
          '[data-email-signup-status]',
        );
        if (status) {
          status.textContent =
            'Signup form coming soon. Bookmark this page for now.';
        }
      });
    });
</script>

<style>
