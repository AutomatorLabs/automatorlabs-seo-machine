---
import type { GuideHub } from '../data/guide-hubs';
import { contentItems } from '../data/content';
import Layout from '../layouts/Layout.astro';
import NewsletterSignup from './NewsletterSignup.astro';

interface Props {
  guide: GuideHub;
}

const { guide } = Astro.props;
const calculatorIds = new Set(guide.calculatorIds);
const calculators = contentItems
  .filter(
    (item) =>
      item.category === 'calculator' && calculatorIds.has(item.id),
  )
  .sort(
    (a, b) =>
      guide.calculatorIds.indexOf(a.id) -
      guide.calculatorIds.indexOf(b.id),
  );
const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: guide.faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
const faqStructuredDataJson = JSON.stringify(faqStructuredData).replace(
  /</g,
  '\\u003c',
);
---

<Layout title={guide.seoTitle} description={guide.metaDescription}>
  <script
    type="application/ld+json"
    set:html={faqStructuredDataJson}
  />

  <main id="main-content">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/guides/">Guides</a></li>
        <li aria-current="page">{guide.title}</li>
      </ol>
    </nav>

    <article>
      <header class="page-header">
        <p class="eyebrow">{guide.eyebrow}</p>
        <h1>{guide.title}</h1>
        <p class="intro">{guide.description}</p>
      </header>

      <aside class="calculator-callout" aria-labelledby="calculator-callout-heading">
        <div>
          <p class="callout-label">Explore the numbers</p>
          <h2 id="calculator-callout-heading">{guide.categoryTitle}</h2>
          <p>
            Use the related calculators to compare assumptions and turn the
            concepts in this guide into practical scenarios.
          </p>
        </div>
        <a href={guide.categoryUrl}>View calculator collection</a>
      </aside>

      <div class="article-body">
        {guide.sections.map((section) => (
          <section>
            <h2>{section.heading}</h2>
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </section>
        ))}
      </div>

      <section class="related-calculators" aria-labelledby="related-calculators-heading">
        <h2 id="related-calculators-heading">Related calculators</h2>
        <div class="calculator-links">
          {calculators.map((calculator) => (
            <a href={calculator.url}>
              <span>{calculator.title}</span>
              <small>{calculator.description}</small>
            </a>
          ))}
        </div>
      </section>

      {guide.exampleCollectionLinks && guide.exampleCollectionLinks.length > 0 && (
        <section class="worked-examples" aria-labelledby="worked-examples-heading">
          <h2 id="worked-examples-heading">Worked examples</h2>
          <div class="calculator-links">
            {guide.exampleCollectionLinks.map((link) => (
              <a href={link.url}>
                <span>{link.title}</span>
                <small>{link.description}</small>
              </a>
            ))}
          </div>
        </section>
      )}

      {guide.comparisonGuideLinks && guide.comparisonGuideLinks.length > 0 && (
        <section class="related-guides" aria-labelledby="related-guides-heading">
          <h2 id="related-guides-heading">Related guides</h2>
          <div class="calculator-links">
            {guide.comparisonGuideLinks.map((link) => (
              <a href={link.url}>
                <span>{link.title}</span>
                <small>{link.description}</small>
              </a>
            ))}
          </div>
        </section>
      )}

      <section class="faq-section" aria-labelledby="faq-heading">
        <h2 id="faq-heading">Frequently asked questions</h2>
        <div class="faq-list">
          {guide.faq.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <NewsletterSignup />

      <a class="back-link" href="/guides/">Browse all guides</a>
    </article>
  </main>
</Layout>

<style>
  main {
    width: min(1040px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  article {
    max-width: 820px;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .breadcrumbs li + li::before {
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a,
  .back-link {
    color: var(--link-color);
  }

  .breadcrumbs a {
    text-decoration: none;
  }

  .breadcrumbs a:hover,
  .back-link:hover {
    text-decoration: underline;
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--text-color);
    font-weight: 650;
  }

  .page-header {
    max-width: 760px;
    margin-bottom: 2.25rem;
  }

  .eyebrow,
  .callout-label {
    margin: 0 0 0.5rem;
    color: var(--link-color);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.35rem, 7vw, 4rem);
    letter-spacing: -0.045em;
    line-height: 1.06;
  }

  .intro {
    margin: 1rem 0 0;
    color: var(--muted-text-color);
    font-size: 1.12rem;
    line-height: 1.7;
  }

  .calculator-callout {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    justify-content: space-between;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--card-background);
    box-shadow: 0 12px 35px var(--shadow-color);
    margin-bottom: 3rem;
    padding: 1.4rem;
  }

  .calculator-callout h2,
  .calculator-callout p {
    margin-top: 0;
  }

  .calculator-callout h2 {
    margin-bottom: 0.4rem;
    font-size: 1.2rem;
  }

  .calculator-callout p:last-child {
    max-width: 590px;
    margin-bottom: 0;
    color: var(--muted-text-color);
  }

  .calculator-callout > a {
    flex: 0 0 auto;
    border-radius: 9px;
    background: var(--button-background);
    color: var(--button-text);
    font-weight: 750;
    padding: 0.75rem 0.95rem;
    text-decoration: none;
  }

  .calculator-callout > a:hover {
    background: var(--button-hover-background);
  }

  .article-body {
    display: grid;
    gap: 2rem;
  }

  .article-body section {
    max-width: 760px;
  }

  .article-body h2,
  .related-calculators h2,
  .worked-examples h2,
  .related-guides h2,
  .faq-section h2 {
    margin: 0 0 0.75rem;
    font-size: 1.55rem;
    letter-spacing: -0.02em;
  }

  .article-body p {
    margin: 0 0 1rem;
    color: var(--text-color);
    font-size: 1rem;
    line-height: 1.78;
  }

  .related-calculators,
  .worked-examples,
  .related-guides,
  .faq-section {
    margin-top: 3rem;
    border-top: 1px solid var(--border-color);
    padding-top: 2rem;
  }

  .calculator-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .calculator-links a {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--card-background);
    color: var(--link-color);
    font-weight: 750;
    padding: 1rem;
    text-decoration: none;
  }

  .calculator-links a:hover {
    border-color: var(--link-color);
    background: var(--subtle-background);
  }

  .calculator-links small {
    margin-top: 0.35rem;
    color: var(--muted-text-color);
    font-size: 0.86rem;
    font-weight: 400;
    line-height: 1.5;
  }

  .faq-section {
    border-radius: 16px;
    background: var(--faq-background);
    padding: 2rem;
  }

  .faq-list {
    border-top: 1px solid var(--border-subtle);
  }

  details {
    border-bottom: 1px solid var(--border-subtle);
    padding: 1rem 0;
  }

  summary {
    cursor: pointer;
    color: var(--text-color);
    font-weight: 750;
  }

  details p {
    margin: 0.65rem 0 0;
    color: var(--muted-text-color);
    line-height: 1.65;
  }

  .back-link {
    display: inline-block;
    margin-top: 2rem;
    font-weight: 700;
  }

  @media (max-width: 680px) {
    main {
      padding: 3rem 0;
    }

    .calculator-callout {
      align-items: flex-start;
      flex-direction: column;
    }

    .calculator-links {
      grid-template-columns: 1fr;
    }

    .faq-section {
      padding: 1.25rem;
    }
  }
</style>
