---
interface Props {
  headline?: string;
  description?: string;
  compact?: boolean;
}

const {
  headline = 'Get practical financial tools in your inbox',
  description = 'Follow new calculator launches, investing tools, retirement planning resources, mortgage calculators, and useful personal finance guides.',
  compact = false,
} = Astro.props;
---

<aside
  class:list={['newsletter-cta', { compact }]}
  aria-label="AutomatorLabs newsletter"
>
  <div>
    <p class="newsletter-label">AutomatorLabs newsletter</p>
    <h2>{headline}</h2>
    <p>{description}</p>
  </div>
  <a href="/newsletter/">Explore the newsletter</a>
</aside>

<style>
  .newsletter-cta {
    display: flex;
    gap: clamp(1.25rem, 4vw, 2.5rem);
    align-items: center;
    justify-content: space-between;
    margin-top: 3rem;
    border: 1px solid var(--border-color);
    border-radius: 18px;
    background: var(--card-background);
    box-shadow: 0 12px 35px var(--shadow-color);
    padding: clamp(1.4rem, 5vw, 2.25rem);
  }

  .newsletter-cta.compact {
    margin-top: 2.5rem;
    padding: 1.25rem;
  }

  .newsletter-label {
    margin: 0 0 0.45rem;
    color: var(--link-color);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .newsletter-cta h2 {
    margin: 0;
    color: var(--heading-color);
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    letter-spacing: -0.025em;
    line-height: 1.2;
  }

  .newsletter-cta.compact h2 {
    font-size: 1.35rem;
  }

  .newsletter-cta div > p:last-child {
    max-width: 700px;
    margin: 0.7rem 0 0;
    color: var(--muted-text-color);
    line-height: 1.6;
  }

  .newsletter-cta a {
    flex: 0 0 auto;
    border-radius: 10px;
    background: var(--button-background);
    color: var(--button-text);
    font-weight: 750;
    padding: 0.8rem 1rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .newsletter-cta a:hover {
    background: var(--button-hover-background);
  }

  .newsletter-cta a:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: 2px;
  }

  @media (max-width: 720px) {
    .newsletter-cta {
      align-items: stretch;
      flex-direction: column;
    }

    .newsletter-cta a {
      text-align: center;
    }
  }
</style>
