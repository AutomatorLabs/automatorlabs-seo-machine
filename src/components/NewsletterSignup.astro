---
import { newsletterConfig } from '../data/newsletter';

interface Props {
  headline?: string;
  description?: string;
  compact?: boolean;
}

const {
  headline = 'Get practical financial tools in your inbox',
  description = 'Follow new calculator launches, investing tools, retirement planning resources, mortgage calculators, and useful personal finance guides.',
  compact = false,
} = Astro.props;

const newsletterUrl =
  newsletterConfig.publicationUrl ?? 'https://newsletter.automatorlabs.co/';
---

<aside
  class:list={['newsletter-signup', { compact }]}
  aria-label="AutomatorLabs newsletter signup"
>
  <div class="newsletter-copy">
    <p class="newsletter-label">AutomatorLabs newsletter</p>
    <h2>{headline}</h2>
    <p>{description}</p>
  </div>

  <div class="signup-panel">
    <a class="newsletter-button" href={newsletterUrl}>
      Subscribe to the newsletter
    </a>

    <p class="signup-note">
      Opens the AutomatorLabs newsletter signup page. Free updates. Unsubscribe whenever you like.
    </p>
  </div>
</aside>

<style>
  .newsletter-signup {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(240px, 0.6fr);
    gap: clamp(1.25rem, 4vw, 2.5rem);
    align-items: center;
    margin-top: 3rem;
    border: 1px solid var(--border-color);
    border-radius: 18px;
    background: var(--card-background);
    box-shadow: 0 12px 35px var(--shadow-color);
    padding: clamp(1.4rem, 5vw, 2.25rem);
  }

  .newsletter-signup.compact {
    margin-top: 2.5rem;
    padding: 1.25rem;
  }

  .newsletter-label {
    margin: 0 0 0.45rem;
    color: var(--link-color);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .newsletter-signup h2 {
    margin: 0;
    color: var(--heading-color);
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    letter-spacing: -0.025em;
    line-height: 1.2;
  }

  .newsletter-signup.compact h2 {
    font-size: 1.35rem;
  }

  .newsletter-copy > p:last-child {
    max-width: 700px;
    margin: 0.7rem 0 0;
    color: var(--muted-text-color);
    line-height: 1.6;
  }

  .signup-panel {
    min-width: 0;
  }

  .newsletter-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    border-radius: 10px;
    background: var(--button-background);
    color: var(--button-text);
    font-weight: 750;
    padding: 0.72rem 1rem;
    text-decoration: none;
  }

  .newsletter-button:hover {
    background: var(--button-hover-background);
    color: var(--button-text);
  }

  .newsletter-button:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: 2px;
  }

  .signup-note {
    margin: 0.65rem 0 0;
    color: var(--muted-text-color);
    font-size: 0.82rem;
    line-height: 1.5;
  }

  @media (max-width: 780px) {
    .newsletter-signup {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .newsletter-button {
      width: 100%;
    }
  }
</style>