---
import type { CalculatorConfig } from '../data/calculators';
import { contentItems } from '../data/content';
import { featuredFourOhOneKSeoRecords } from '../data/programmatic-seo/401k';
import { featuredRothIraSeoRecords } from '../data/programmatic-seo/roth-ira';
import { featuredRothEarlyWithdrawalSeoRecords } from '../data/programmatic-seo/roth-ira-early-withdrawal';
import CalculatorPage from './CalculatorPage.astro';

interface Props {
  calculator: CalculatorConfig;
  periodsPerYear?: number;
}

const { calculator, periodsPerYear = 1 } = Astro.props;
const isFourOhOneK = calculator.id.includes('401k') || calculator.id === 'employer-match';
const isRothEarlyWithdrawal = calculator.id === 'roth-ira-early-withdrawal';
const isRothFamily =
  !isRothEarlyWithdrawal &&
  (calculator.id.startsWith('roth-ira') || calculator.id === 'roth-vs-traditional-ira');
const relatedItems = calculator.relatedIds.flatMap((id) => {
  const item = contentItems.find((candidate) => candidate.id === id);
  return item ? [{ title: item.title, url: item.url }] : [];
});
const guideItems = [
  {
    title: 'Roth IRA vs Traditional IRA',
    url: '/guides/roth-vs-traditional-ira/',
  },
  {
    title: 'Planning Retirement Withdrawals',
    url: '/guides/retirement-withdrawals/',
  },
  {
    title: 'A Beginner’s Guide to FIRE',
    url: '/guides/fire/',
  },
];
const retirementToolItems = isFourOhOneK
  ? [
      {
        title: 'Browse all 200 401(k) examples',
        url: '/calculators/401k/examples/',
      },
      ...featuredFourOhOneKSeoRecords.map((record) => ({
        title: record.question,
        url: `/calculators/401k/${record.slug}/`,
      })),
    ]
  : isRothEarlyWithdrawal
    ? [
        {
          title: 'Browse all 200 Roth IRA Early Withdrawal examples',
          url: '/calculators/roth-ira-early-withdrawal/examples/',
        },
        ...featuredRothEarlyWithdrawalSeoRecords.map((record) => ({
          title: record.question,
          url: `/calculators/roth-ira-early-withdrawal/${record.slug}/`,
        })),
      ]
    : isRothFamily
      ? [
          {
            title: 'Browse all 200 Roth IRA examples',
            url: '/calculators/roth-ira/examples/',
          },
          ...featuredRothIraSeoRecords.map((record) => ({
            title: record.question,
            url: `/calculators/roth-ira/${record.slug}/`,
          })),
        ]
      : [
          {
            title: 'FIRE Calculator',
            url: '/calculators/fire-calculator/',
          },
          {
            title: 'Retirement Withdrawal Calculator',
            url: '/calculators/retirement-withdrawal-calculator/',
          },
        ];
---

<CalculatorPage
  title={calculator.title}
  eyebrow={calculator.eyebrow}
  description={calculator.description}
  inputs={calculator.inputs}
  outputs={calculator.outputs}
  faq={calculator.faq}
  relatedItems={relatedItems}
  guideItems={guideItems}
  exampleItems={retirementToolItems}
  exampleHeading="More Retirement Planning Tools"
  calculatorData={{
    'calculator-id': calculator.id,
    'periods-per-year': periodsPerYear,
  }}
>
  <script>
    import { trackSuccessfulCalculation } from '../lib/analytics';
    import { parseCalculatorNumber } from '../lib/input';
    import {
      calculate401kContributionPlan,
      calculate401kEmployerMatch,
      calculate401kGrowth,
      calculate401kMaxContribution,
      calculateRothContributionPlan,
      calculateRothEarlyWithdrawal,
      calculateRothIraProjection,
      calculateRothMaxContribution,
      calculateRothVsTaxable,
      calculateRothVsTraditionalIra,
    } from '../lib/math';

    const form = document.querySelector<HTMLFormElement>('#calculator-form');
    const error = document.querySelector<HTMLElement>('#form-error');
    const calculatorId = form?.dataset.calculatorId ?? '';
    const periodsPerYear = Number(form?.dataset.periodsPerYear ?? 1);
    const currency = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 2,
    });
    const percentage = new Intl.NumberFormat('en-US', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    });

    function setText(id: string, value: string) {
      const element = document.querySelector<HTMLElement>(`#${id}`);
      if (element) element.textContent = value;
    }

    function number(data: FormData, name: string) {
      return parseCalculatorNumber(data.get(name));
    }

    function calculate() {
      if (!form || !error) return false;
      const data = new FormData(form);
      const values = Array.from(data.values()).map((value) =>
        parseCalculatorNumber(value),
      );

      if (values.some((value) => !Number.isFinite(value) || value < 0)) {
        error.textContent =
          'Enter valid values greater than or equal to zero in every field.';
        error.hidden = false;
        return false;
      }

      error.hidden = true;

      if (
        calculatorId === 'roth-ira' ||
        calculatorId === 'roth-ira-growth'
      ) {
        const years = number(data, 'years');
        if (years <= 0 || !Number.isInteger(years)) {
          error.textContent = 'Years invested must be a whole number above 0.';
          error.hidden = false;
          return false;
        }
        const contribution =
          calculatorId === 'roth-ira'
            ? number(data, 'monthlyContribution')
            : number(data, 'annualContribution');
        const currentBalance = number(data, 'currentBalance');
        const result = calculateRothIraProjection({
          currentBalance,
          contributionPerPeriod: contribution,
          expectedAnnualReturnPercent: number(
            data,
            'expectedAnnualReturn',
          ),
          years,
          periodsPerYear,
        });
        setText(
          'roth-ending-balance-result',
          currency.format(result.endingBalance),
        );
        setText(
          'roth-future-contributions-result',
          currency.format(result.futureContributions),
        );
        setText(
          'roth-investment-growth-result',
          currency.format(result.investmentGrowth),
        );
        setText(
          'roth-total-funded-result',
          currency.format(currentBalance + result.futureContributions),
        );
      } else if (calculatorId === 'roth-ira-contribution') {
        const result = calculateRothContributionPlan({
          annualTarget: number(data, 'annualTarget'),
          contributedSoFar: number(data, 'contributedSoFar'),
          contributionPerPaycheck: number(data, 'contributionPerPaycheck'),
          remainingPaychecks: number(data, 'remainingPaychecks'),
        });
        setText(
          'projected-annual-contribution-result',
          currency.format(result.projectedAnnualContribution),
        );
        setText(
          'remaining-to-target-result',
          currency.format(result.remainingToTarget),
        );
        setText(
          'target-progress-result',
          `${percentage.format(result.targetProgressPercent)}%`,
        );
      } else if (calculatorId === 'roth-ira-max-contribution') {
        const monthsRemaining = number(data, 'monthsRemaining');
        if (monthsRemaining > 12 || !Number.isInteger(monthsRemaining)) {
          error.textContent =
            'Months remaining must be a whole number from 0 through 12.';
          error.hidden = false;
          return false;
        }
        const result = calculateRothMaxContribution({
          assumedAnnualLimit: number(data, 'assumedAnnualLimit'),
          contributedSoFar: number(data, 'contributedSoFar'),
          monthsRemaining,
        });
        setText(
          'remaining-available-result',
          currency.format(result.remainingAvailable),
        );
        setText(
          'monthly-to-limit-result',
          currency.format(result.monthlyAmountToReachLimit),
        );
        setText(
          'weekly-to-limit-result',
          currency.format(result.weeklyAmountToReachLimit),
        );
      } else if (calculatorId === 'roth-ira-vs-taxable') {
        const years = number(data, 'years');
        if (years <= 0 || !Number.isInteger(years)) {
          error.textContent = 'Years invested must be a whole number above 0.';
          error.hidden = false;
          return false;
        }
        const result = calculateRothVsTaxable({
          startingBalance: number(data, 'startingBalance'),
          annualContribution: number(data, 'annualContribution'),
          expectedAnnualReturnPercent: number(
            data,
            'expectedAnnualReturn',
          ),
          taxableAccountTaxDragPercent: number(data, 'taxableTaxDrag'),
          years,
        });
        setText(
          'roth-comparison-ending-result',
          currency.format(result.rothEndingBalance),
        );
        setText(
          'taxable-comparison-ending-result',
          currency.format(result.taxableEndingBalance),
        );
        setText(
          'estimated-roth-advantage-result',
          currency.format(result.estimatedRothAdvantage),
        );
        setText(
          'taxable-growth-drag-result',
          currency.format(result.taxableGrowthDrag),
        );
      } else if (calculatorId === 'roth-ira-early-withdrawal') {
        const assumedTaxRatePercent = number(data, 'assumedTaxRate');
        const assumedPenaltyRatePercent = number(data, 'assumedPenaltyRate');
        if (
          assumedTaxRatePercent > 100 ||
          assumedPenaltyRatePercent > 100
        ) {
          error.textContent = 'Tax and penalty rates cannot exceed 100%.';
          error.hidden = false;
          return false;
        }
        const result = calculateRothEarlyWithdrawal({
          withdrawalAmount: number(data, 'withdrawalAmount'),
          contributionBasisAvailable: number(
            data,
            'contributionBasisAvailable',
          ),
          earningsAmountSubjectToTaxAndPenalty: number(
            data,
            'earningsSubject',
          ),
          assumedTaxRatePercent,
          assumedPenaltyRatePercent,
        });
        setText(
          'withdrawal-contribution-portion-result',
          currency.format(result.contributionPortion),
        );
        setText(
          'withdrawal-earnings-portion-result',
          currency.format(result.earningsPortion),
        );
        setText('withdrawal-tax-result', currency.format(result.estimatedTax));
        setText(
          'withdrawal-penalty-result',
          currency.format(result.estimatedPenalty),
        );
        setText(
          'withdrawal-net-result',
          currency.format(result.estimatedNetWithdrawal),
        );
      } else if (
        calculatorId === '401k' ||
        calculatorId === '401k-growth'
      ) {
        const years = number(data, 'years');
        if (years <= 0 || !Number.isInteger(years)) {
          error.textContent = 'Years invested must be a whole number above 0.';
          error.hidden = false;
          return false;
        }
        const result = calculate401kGrowth({
          currentBalance: number(data, 'currentBalance'),
          employeeMonthlyContribution: number(
            data,
            'employeeMonthlyContribution',
          ),
          employerMonthlyMatch: number(data, 'employerMonthlyMatch'),
          expectedAnnualReturnPercent: number(
            data,
            'expectedAnnualReturn',
          ),
          years,
        });
        setText('ending-balance-result', currency.format(result.endingBalance));
        setText(
          'employee-contributions-result',
          currency.format(result.totalEmployeeContributions),
        );
        setText(
          'employer-match-result',
          currency.format(result.totalEmployerMatch),
        );
        setText(
          'investment-growth-result',
          currency.format(result.investmentGrowth),
        );
      } else if (calculatorId === '401k-contribution') {
        const result = calculate401kContributionPlan({
          annualSalary: number(data, 'annualSalary'),
          employeeContributionPercent: number(
            data,
            'employeeContributionPercent',
          ),
          employerContributionPercent: number(
            data,
            'employerContributionPercent',
          ),
          payPeriodsPerYear: number(data, 'payPeriodsPerYear'),
        });
        setText(
          'employee-annual-contribution-result',
          currency.format(result.employeeAnnualContribution),
        );
        setText(
          'employee-per-paycheck-result',
          currency.format(result.employeeContributionPerPaycheck),
        );
        setText(
          'employer-annual-contribution-result',
          currency.format(result.employerAnnualContribution),
        );
        setText(
          'combined-annual-contribution-result',
          currency.format(result.combinedAnnualContribution),
        );
      } else if (calculatorId === 'employer-match') {
        const result = calculate401kEmployerMatch({
          annualSalary: number(data, 'annualSalary'),
          employeeContributionPercent: number(
            data,
            'employeeContributionPercent',
          ),
          employerMatchRatePercent: number(data, 'employerMatchRatePercent'),
          employerMatchCapPercentOfSalary: number(
            data,
            'employerMatchCapPercentOfSalary',
          ),
        });
        setText(
          'employee-annual-deferral-result',
          currency.format(result.employeeAnnualContribution),
        );
        setText(
          'eligible-contribution-result',
          currency.format(result.eligibleEmployeeContribution),
        );
        setText(
          'estimated-employer-match-result',
          currency.format(result.estimatedEmployerMatch),
        );
        setText(
          'combined-contribution-result',
          currency.format(result.combinedAnnualContribution),
        );
      } else if (calculatorId === 'traditional-vs-roth-401k') {
        const years = number(data, 'years');
        if (years <= 0 || !Number.isInteger(years)) {
          error.textContent = 'Years invested must be a whole number above 0.';
          error.hidden = false;
          return false;
        }
        const result = calculateRothVsTraditionalIra({
          annualContribution: number(data, 'annualContribution'),
          currentTaxRatePercent: number(data, 'currentTaxRate'),
          retirementTaxRatePercent: number(data, 'retirementTaxRate'),
          expectedAnnualReturnPercent: number(
            data,
            'expectedAnnualReturn',
          ),
          years,
        });
        setText(
          'roth-401k-ending-result',
          currency.format(result.rothEndingValue),
        );
        setText(
          'traditional-401k-after-tax-result',
          currency.format(result.traditionalAfterTaxEndingValue),
        );
        setText(
          'comparison-401k-difference-result',
          currency.format(result.difference),
        );
        setText(
          'comparison-401k-result',
          result.betterOption === 'roth'
            ? 'Roth 401(k)'
            : result.betterOption === 'traditional'
              ? 'Traditional 401(k)'
              : 'Equivalent under these assumptions',
        );
      } else if (calculatorId === '401k-catch-up-contribution') {
        const monthsRemaining = number(data, 'monthsRemaining');
        if (monthsRemaining > 12 || !Number.isInteger(monthsRemaining)) {
          error.textContent =
            'Months remaining must be a whole number from 0 through 12.';
          error.hidden = false;
          return false;
        }
        const result = calculate401kMaxContribution({
          assumedRegularLimit: number(data, 'assumedRegularLimit'),
          assumedCatchUpAmount: number(data, 'assumedCatchUpAmount'),
          contributedSoFar: number(data, 'contributedSoFar'),
          monthsRemaining,
        });
        setText(
          'assumed-total-limit-result',
          currency.format(result.assumedTotalLimit),
        );
        setText(
          'catch-up-remaining-result',
          currency.format(result.remainingAvailable),
        );
        setText(
          'catch-up-monthly-result',
          currency.format(result.monthlyAmountToReachAssumedLimit),
        );
        setText(
          'catch-up-per-paycheck-result',
          currency.format(result.semimonthlyAmountToReachAssumedLimit),
        );
      }

      return true;
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      trackSuccessfulCalculation(calculatorId, calculate);
    });

    calculate();
  </script>
</CalculatorPage>
