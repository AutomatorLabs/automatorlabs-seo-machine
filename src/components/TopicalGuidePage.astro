---
import type { TopicalGuide } from '../data/topical-guides';
import Layout from '../layouts/Layout.astro';

interface Props {
  guide: TopicalGuide;
}

const { guide } = Astro.props;
const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: guide.faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
const faqStructuredDataJson = JSON.stringify(faqStructuredData).replace(
  /</g,
  '\\u003c',
);
---

<Layout title={guide.seoTitle} description={guide.metaDescription}>
  <script type="application/ld+json" set:html={faqStructuredDataJson} />

  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/guides/">Guides</a></li>
        <li aria-current="page">{guide.title}</li>
      </ol>
    </nav>

    <article>
      <header class="page-header">
        <p class="eyebrow">Investing guide</p>
        <h1>{guide.title}</h1>
        <p class="intro">{guide.intro}</p>
      </header>

      <div class="article-body">
        {guide.sections.map((section) => (
          <section>
            <h2>{section.heading}</h2>
            {section.intro && <p>{section.intro}</p>}
            {section.subsections?.map((subsection) => (
              <div class="subsection">
                <h3>{subsection.heading}</h3>
                {subsection.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            ))}
            {section.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
          </section>
        ))}
      </div>

      <section class="internal-links" aria-labelledby="related-heading">
        <h2 id="related-heading">Related calculators and guides</h2>
        <div class="link-grid">
          {guide.links.map((link) => (
            <a href={link.url}>
              <strong>{link.title}</strong>
              <span>{link.description}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="faq-section" aria-labelledby="faq-heading">
        <h2 id="faq-heading">Frequently asked questions</h2>
        <div class="faq-list">
          {guide.faq.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <a class="back-link" href="/guides/">Browse all guides</a>
    </article>
  </main>
</Layout>

<style>
  main {
    width: min(1040px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  article {
    max-width: 820px;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .breadcrumbs li + li::before {
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a,
  .back-link {
    color: var(--link-color);
  }

  .breadcrumbs a {
    text-decoration: none;
  }

  .breadcrumbs a:hover,
  .back-link:hover {
    text-decoration: underline;
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--text-color);
    font-weight: 650;
  }

  .page-header {
    max-width: 800px;
    margin-bottom: 3rem;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: var(--link-color);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.35rem, 7vw, 4rem);
    letter-spacing: -0.045em;
    line-height: 1.06;
  }

  .intro {
    margin: 1rem 0 0;
    color: var(--muted-text-color);
    font-size: 1.12rem;
    line-height: 1.72;
  }

  .article-body {
    display: grid;
    gap: 2.5rem;
  }

  .article-body section {
    max-width: 800px;
  }

  .article-body h2,
  .internal-links h2,
  .faq-section h2 {
    margin: 0 0 0.9rem;
    color: var(--heading-color);
    font-size: 1.55rem;
    letter-spacing: -0.02em;
  }

  .article-body h3 {
    margin: 1.5rem 0 0.55rem;
    color: var(--heading-color);
    font-size: 1.12rem;
  }

  .article-body p {
    margin: 0 0 1rem;
    color: var(--text-color);
    font-size: 1rem;
    line-height: 1.8;
  }

  .internal-links,
  .faq-section {
    margin-top: 3rem;
    border-top: 1px solid var(--border-color);
    padding-top: 2rem;
  }

  .link-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .link-grid a {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--card-background);
    color: var(--link-color);
    padding: 1rem;
    text-decoration: none;
  }

  .link-grid a:hover {
    border-color: var(--link-color);
    background: var(--subtle-background);
  }

  .link-grid span {
    margin-top: 0.35rem;
    color: var(--muted-text-color);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .faq-section {
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--faq-background);
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .faq-list {
    border-top: 1px solid var(--border-subtle);
  }

  details {
    border-bottom: 1px solid var(--border-subtle);
    padding: 1rem 0;
  }

  summary {
    cursor: pointer;
    color: var(--text-color);
    font-weight: 750;
  }

  details p {
    margin: 0.65rem 0 0;
    color: var(--muted-text-color);
    line-height: 1.68;
  }

  .back-link {
    display: inline-block;
    margin-top: 2rem;
    font-weight: 700;
  }

  @media (max-width: 680px) {
    main {
      padding: 3rem 0;
    }

    .link-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
