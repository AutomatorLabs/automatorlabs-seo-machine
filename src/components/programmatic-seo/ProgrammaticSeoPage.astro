---
import EmailSignup from '../EmailSignup.astro';
import Layout from '../../layouts/Layout.astro';
import {
  createBreadcrumbSchema,
  createFaqSchema,
  serializeJsonLd,
} from '../../lib/programmatic-seo/schema';
import type { ProgrammaticSeoPageModel } from '../../lib/programmatic-seo/types';
import ProjectionChart from './ProjectionChart.astro';

interface Props {
  page: ProgrammaticSeoPageModel;
}

const { page } = Astro.props;
const site = Astro.site ?? new URL('https://automatorlabs.co');
const faqSchema = serializeJsonLd(createFaqSchema(page.faq));
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(page.breadcrumbs, site),
);
const currency = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 2,
});
const formulaHeading = page.formula.heading ?? 'Compound Interest Formula';
const showChart = page.showChart ?? true;
const chartHeading = page.chartHeading ?? 'Growth Over Time';
const chartDescription =
  page.chartDescription ??
  'The chart shows the estimated ending balance after each year under the fixed assumptions used on this page.';
const calculatorCta = page.calculatorCta ?? {
  heading: 'Try Your Own Numbers',
  description:
    'Use the full calculator to change the starting amount, contribution, return, time period, or compounding frequency.',
  url: '/calculators/compound-interest/',
  label: 'Open the Compound Interest Calculator',
  examplesUrl: '/calculators/compound-interest/examples/',
  examplesLabel: 'Browse All Compound Interest Examples',
};
const relatedPagesHeading =
  page.relatedPagesHeading ?? 'Related Compound Interest Examples';
---

<Layout title={page.seoTitle} description={page.metaDescription}>
  <script type="application/ld+json" set:html={faqSchema} />
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        {page.breadcrumbs.map((item, index) => (
          <li aria-current={index === page.breadcrumbs.length - 1 ? 'page' : undefined}>
            {index === page.breadcrumbs.length - 1 ? (
              item.name
            ) : (
              <a href={item.url}>{item.name}</a>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <article>
      <header class="page-header">
        <p class="eyebrow">{page.eyebrow}</p>
        <h1>{page.title}</h1>
        <p class="intro">{page.intro}</p>
      </header>

      <section class="summary-panel" aria-labelledby="answer-heading">
        <div>
          <p class="section-label">Calculated answer</p>
          <h2 id="answer-heading">{page.results[0].value}</h2>
          <p>{page.summary}</p>
        </div>
        <dl class="result-list">
          {page.results.map((result) => (
            <div class:list={{ primary: result.primary }}>
              <dt>{result.label}</dt>
              <dd>{result.value}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="content-panel" aria-labelledby="formula-heading">
        <h2 id="formula-heading">{formulaHeading}</h2>
        <p class="formula">{page.formula.expression}</p>
        <p>{page.formula.explanation}</p>
        <ol>
          {page.formula.steps.map((step) => <li>{step}</li>)}
        </ol>
      </section>

      {showChart && (
        <section class="content-panel" aria-labelledby="chart-heading">
          <h2 id="chart-heading">{chartHeading}</h2>
          <p>{chartDescription}</p>
          <ProjectionChart
            points={page.chartPoints}
            ariaLabel={page.chartLabel}
          />
        </section>
      )}

      <section class="content-panel" aria-labelledby="projection-heading">
        <h2 id="projection-heading">
          {page.table?.heading ?? page.projectionHeading}
        </h2>
        <div class="table-scroll">
          <table>
            <thead>
              {page.table ? (
                <tr>
                  {page.table.columns.map((column) => (
                    <th scope="col">{column}</th>
                  ))}
                </tr>
              ) : (
                <tr>
                  <th scope="col">Year</th>
                  <th scope="col">Contributions</th>
                  <th scope="col">Interest / Growth</th>
                  <th scope="col">Ending Balance</th>
                </tr>
              )}
            </thead>
            <tbody>
              {page.table ? (
                page.table.rows.map((row) => (
                  <tr>
                    <th scope="row">{row.label}</th>
                    {row.cells.map((cell) => <td>{cell}</td>)}
                  </tr>
                ))
              ) : (
                page.projectionRows.map((row) => (
                  <tr>
                    <th scope="row">{row.period}</th>
                    <td>{currency.format(row.contributions)}</td>
                    <td>{currency.format(row.growth)}</td>
                    <td>{currency.format(row.endingBalance)}</td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </section>

      <div class="article-body">
        {page.sections.map((section) => (
          <section>
            <h2>{section.heading}</h2>
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </section>
        ))}
      </div>

      <section class="link-section" aria-labelledby="main-calculator-heading">
        <h2 id="main-calculator-heading">{calculatorCta.heading}</h2>
        <p>{calculatorCta.description}</p>
        <a class="primary-link" href={calculatorCta.url}>
          {calculatorCta.label}
        </a>
        {calculatorCta.examplesUrl && calculatorCta.examplesLabel && (
          <a
            class="secondary-link"
            href={calculatorCta.examplesUrl}
          >
            {calculatorCta.examplesLabel}
          </a>
        )}
      </section>

      {page.relatedPages.length > 0 && (
        <section class="link-section" aria-labelledby="related-examples-heading">
          <h2 id="related-examples-heading">{relatedPagesHeading}</h2>
          <div class="link-grid">
            {page.relatedPages.map((link) => (
              <a href={link.url}>
                <strong>{link.title}</strong>
                <span>{link.description}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <section class="link-section" aria-labelledby="related-tools-heading">
        <h2 id="related-tools-heading">Related Calculators</h2>
        <div class="link-grid">
          {page.relatedCalculators.map((link) => (
            <a href={link.url}>
              <strong>{link.title}</strong>
              <span>{link.description}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="link-section" aria-labelledby="related-guides-heading">
        <h2 id="related-guides-heading">Related Guides</h2>
        <div class="link-grid">
          {page.relatedGuides.map((link) => (
            <a href={link.url}>
              <strong>{link.title}</strong>
              <span>{link.description}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="faq-section" aria-labelledby="faq-heading">
        <h2 id="faq-heading">Frequently Asked Questions</h2>
        <div class="faq-list">
          {page.faq.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <EmailSignup />
    </article>
  </main>
</Layout>

<style>
  main {
    width: min(1080px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  article {
    max-width: 880px;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .breadcrumbs li + li::before {
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a {
    color: var(--link-color);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--text-color);
    font-weight: 650;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .eyebrow,
  .section-label {
    margin: 0 0 0.5rem;
    color: var(--link-color);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 850px;
    margin: 0;
    font-size: clamp(2.35rem, 7vw, 4rem);
    letter-spacing: -0.045em;
    line-height: 1.06;
  }

  .intro {
    max-width: 800px;
    margin: 1rem 0 0;
    color: var(--muted-text-color);
    font-size: 1.12rem;
    line-height: 1.72;
  }

  .summary-panel,
  .content-panel,
  .faq-section {
    margin-top: 1.5rem;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--card-background);
    box-shadow: 0 12px 35px var(--shadow-color);
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .summary-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(260px, 0.85fr);
    gap: 1.5rem;
    align-items: start;
  }

  .summary-panel h2 {
    margin: 0;
    color: var(--link-color);
    font-size: clamp(2rem, 6vw, 3.1rem);
    letter-spacing: -0.04em;
  }

  .summary-panel p,
  .content-panel p,
  .link-section p {
    color: var(--muted-text-color);
    line-height: 1.7;
  }

  .result-list {
    margin: 0;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
  }

  .result-list div {
    border-bottom: 1px solid var(--border-subtle);
    padding: 0.9rem;
  }

  .result-list div:last-child {
    border-bottom: 0;
  }

  .result-list dt {
    color: var(--muted-text-color);
    font-size: 0.84rem;
  }

  .result-list dd {
    margin: 0.25rem 0 0;
    color: var(--heading-color);
    font-size: 1.05rem;
    font-weight: 750;
  }

  .content-panel h2,
  .article-body h2,
  .link-section h2,
  .faq-section h2 {
    margin: 0 0 0.85rem;
    font-size: 1.55rem;
    letter-spacing: -0.02em;
  }

  .formula {
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: var(--subtle-background);
    color: var(--heading-color) !important;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: clamp(1rem, 3vw, 1.2rem);
    font-weight: 700;
    padding: 1rem;
    overflow-wrap: anywhere;
  }

  .content-panel ol {
    display: grid;
    gap: 0.65rem;
    color: var(--text-color);
    padding-left: 1.25rem;
  }

  .content-panel li::marker {
    color: var(--link-color);
    font-weight: 750;
  }

  .table-scroll {
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  table {
    width: 100%;
    min-width: 650px;
    border-collapse: collapse;
    color: var(--text-color);
    font-variant-numeric: tabular-nums;
  }

  th,
  td {
    border-bottom: 1px solid var(--border-subtle);
    padding: 0.75rem 0.85rem;
    text-align: right;
    white-space: nowrap;
  }

  th:first-child,
  td:first-child {
    text-align: left;
  }

  thead th {
    background: var(--subtle-background);
    color: var(--heading-color);
    font-size: 0.85rem;
  }

  tbody tr:last-child th,
  tbody tr:last-child td {
    border-bottom: 0;
  }

  .article-body {
    display: grid;
    gap: 2.25rem;
    margin-top: 3rem;
  }

  .article-body section {
    max-width: 800px;
  }

  .article-body p {
    margin: 0 0 1rem;
    color: var(--text-color);
    line-height: 1.8;
  }

  .link-section {
    margin-top: 3rem;
    border-top: 1px solid var(--border-color);
    padding-top: 2rem;
  }

  .primary-link {
    display: inline-block;
    border-radius: 10px;
    background: var(--button-background);
    color: var(--button-text);
    font-weight: 750;
    padding: 0.8rem 1rem;
    text-decoration: none;
  }

  .primary-link:hover {
    background: var(--button-hover-background);
  }

  .secondary-link {
    display: inline-block;
    margin-left: 0.75rem;
    color: var(--link-color);
    font-weight: 750;
  }

  .link-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .link-grid a {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--card-background);
    color: var(--link-color);
    padding: 1rem;
    text-decoration: none;
  }

  .link-grid a:hover {
    border-color: var(--link-color);
    background: var(--subtle-background);
  }

  .link-grid span {
    margin-top: 0.35rem;
    color: var(--muted-text-color);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .faq-section {
    margin-top: 3rem;
    background: var(--faq-background);
    box-shadow: none;
  }

  .faq-list {
    border-top: 1px solid var(--border-subtle);
  }

  details {
    border-bottom: 1px solid var(--border-subtle);
    padding: 1rem 0;
  }

  summary {
    cursor: pointer;
    color: var(--text-color);
    font-weight: 750;
  }

  details p {
    margin: 0.65rem 0 0;
    color: var(--muted-text-color);
    line-height: 1.68;
  }

  @media (max-width: 720px) {
    main {
      padding: 3rem 0;
    }

    .summary-panel,
    .link-grid {
      grid-template-columns: 1fr;
    }

    .secondary-link {
      display: block;
      margin: 1rem 0 0;
    }
  }
</style>
