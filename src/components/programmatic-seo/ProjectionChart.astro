---
import type { ProgrammaticSeoChartPoint } from '../../lib/programmatic-seo/types';

interface Props {
  points: ProgrammaticSeoChartPoint[];
  ariaLabel: string;
  xAxisLabel?: string;
  yAxisLabel?: string;
}

const {
  points,
  ariaLabel,
  xAxisLabel = 'Years',
  yAxisLabel = 'Balance',
} = Astro.props;
const width = 760;
const height = 400;
const margin = { top: 36, right: 28, bottom: 64, left: 104 };
const plotWidth = width - margin.left - margin.right;
const plotHeight = height - margin.top - margin.bottom;
const maximumPeriod = Math.max(...points.map((point) => point.period), 1);
const maximumValue = Math.max(...points.map((point) => point.value), 1);
const xPosition = (period: number) =>
  margin.left + (period / maximumPeriod) * plotWidth;
const yPosition = (value: number) =>
  margin.top + plotHeight - (value / maximumValue) * plotHeight;
const linePath = points
  .map(
    (point, index) =>
      `${index === 0 ? 'M' : 'L'} ${xPosition(point.period)} ${yPosition(point.value)}`,
  )
  .join(' ');
const areaPath = `${linePath} L ${xPosition(maximumPeriod)} ${margin.top + plotHeight} L ${margin.left} ${margin.top + plotHeight} Z`;
const compactCurrency = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  notation: 'compact',
  maximumFractionDigits: 1,
});
const yTicks = Array.from({ length: 5 }, (_, index) => {
  const ratio = index / 4;
  return {
    y: margin.top + plotHeight - ratio * plotHeight,
    value: maximumValue * ratio,
  };
});
const xTickCount = Math.min(6, maximumPeriod + 1);
const xTicks = Array.from({ length: xTickCount }, (_, index) => {
  const ratio = xTickCount === 1 ? 0 : index / (xTickCount - 1);
  return {
    x: margin.left + ratio * plotWidth,
    period: Math.round(maximumPeriod * ratio),
  };
});
---

<div class="projection-chart" role="img" aria-label={ariaLabel}>
  <svg viewBox={`0 0 ${width} ${height}`} aria-hidden="true" focusable="false">
    {yTicks.map((tick) => (
      <>
        <line
          x1={margin.left}
          y1={tick.y}
          x2={width - margin.right}
          y2={tick.y}
          class="grid-line"
        />
        <text
          x={margin.left - 12}
          y={tick.y + 5}
          class="tick-label"
          text-anchor="end"
        >
          {compactCurrency.format(tick.value)}
        </text>
      </>
    ))}

    {xTicks.map((tick) => (
      <text
        x={tick.x}
        y={height - 24}
        class="tick-label"
        text-anchor="middle"
      >
        {tick.period}
      </text>
    ))}

    <path d={areaPath} class="chart-area" />
    <path d={linePath} class="chart-line" />

    {points.map((point) => (
      <circle
        cx={xPosition(point.period)}
        cy={yPosition(point.value)}
        r={points.length > 25 ? 3 : 4}
        class="chart-point"
      />
    ))}

    <text
      x={margin.left + plotWidth / 2}
      y={height - 4}
      class="axis-label"
      text-anchor="middle"
    >
      {xAxisLabel}
    </text>
    <text
      x="22"
      y={margin.top + plotHeight / 2}
      class="axis-label"
      text-anchor="middle"
      transform={`rotate(-90 22 ${margin.top + plotHeight / 2})`}
    >
      {yAxisLabel}
    </text>
  </svg>
</div>

<style>
  .projection-chart {
    height: clamp(340px, 50vw, 410px);
    min-height: 340px;
    border: 1px solid var(--border-color);
    border-radius: 14px;
    background: var(--chart-background);
    padding: 0.75rem;
    overflow: hidden;
  }

  svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .grid-line {
    stroke: var(--border-subtle);
    stroke-width: 1;
  }

  .tick-label {
    fill: var(--muted-text-color);
    font-size: 14px;
  }

  .axis-label {
    fill: var(--muted-text-color);
    font-size: 15px;
    font-weight: 700;
  }

  .chart-area {
    fill: var(--focus-ring);
    stroke: none;
  }

  .chart-line {
    fill: none;
    stroke: var(--link-color);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 4;
  }

  .chart-point {
    fill: var(--card-background);
    stroke: var(--link-color);
    stroke-width: 2.5;
  }

  @media (max-width: 620px) {
    .projection-chart {
      height: 330px;
      min-height: 330px;
      padding: 0.35rem;
    }
  }
</style>
