---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'AutomatorLabs',
	description = 'Free calculators, tools, and practical guides for money, data, and automation.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="google-site-verification" content="Zn28Zp1xSsFTgvQj44O4oS1mdtKfQPqLFJ0Hsmr9OqY" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
	</head>
	<body>
		<header class="site-header">
			<nav class="site-nav" aria-label="Main navigation">
				<a class="brand" href="/">AutomatorLabs</a>
				<div class="nav-links">
					<a href="/">Home</a>
					<a href="/calculators/">Calculators</a>
					<a href="/tools/">Tools</a>
					<a href="/guides/">Guides</a>
				</div>
			</nav>
		</header>

		<slot />

		<footer class="site-footer">
			<div class="footer-inner">
				<a class="brand" href="/">AutomatorLabs</a>
				<nav class="footer-links" aria-label="Footer navigation">
					<a href="/privacy/">Privacy</a>
					<a href="/contact/">Contact</a>
					<a
						href="https://github.com/AutomatorLabs/automatorlabs-seo-machine"
						target="_blank"
						rel="noreferrer"
					>
						GitHub
					</a>
				</nav>
			</div>
		</footer>
	</body>
</html>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	:global(body) {
		display: flex;
		min-height: 100vh;
		flex-direction: column;
		color: #172033;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	:global(body > main) {
		flex: 1;
	}

	.site-header,
	.site-footer {
		background: #fff;
	}

	.site-header {
		border-bottom: 1px solid #e5e7eb;
	}

	.site-nav,
	.footer-inner {
		display: flex;
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}

	.site-nav {
		min-height: 68px;
	}

	.brand {
		color: #172033;
		font-weight: 800;
		letter-spacing: -0.02em;
		text-decoration: none;
	}

	.nav-links,
	.footer-links {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.nav-links a,
	.footer-links a {
		color: #4b5563;
		font-size: 0.94rem;
		font-weight: 600;
		text-decoration: none;
	}

	.nav-links a:hover,
	.footer-links a:hover {
		color: #3158d3;
	}

	.site-footer {
		margin-top: auto;
		border-top: 1px solid #e5e7eb;
	}

	.footer-inner {
		min-height: 92px;
	}

	@media (max-width: 620px) {
		.site-nav,
		.footer-inner {
			padding: 1rem 0;
			align-items: flex-start;
			flex-direction: column;
			gap: 0.75rem;
		}

		.site-nav {
			min-height: auto;
		}

		.nav-links,
		.footer-links {
			width: 100%;
			flex-wrap: wrap;
			gap: 0.75rem 1rem;
		}
	}
</style>
