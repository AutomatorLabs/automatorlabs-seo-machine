---
import CalculatorPage from '../../../components/CalculatorPage.astro';
import { fourOhOneKGrowthCalculator } from '../../../data/calculators';
import { contentItems } from '../../../data/content';

const relatedItems = fourOhOneKGrowthCalculator.relatedIds.flatMap((id) => {
  const item = contentItems.find((contentItem) => contentItem.id === id);
  return item ? [{ title: item.title, url: item.url }] : [];
});
---

<CalculatorPage
  title={fourOhOneKGrowthCalculator.title}
  eyebrow={fourOhOneKGrowthCalculator.eyebrow}
  description={fourOhOneKGrowthCalculator.description}
  inputs={fourOhOneKGrowthCalculator.inputs}
  outputs={fourOhOneKGrowthCalculator.outputs}
  faq={fourOhOneKGrowthCalculator.faq}
  relatedItems={relatedItems}
>
  <script>
    import { trackSuccessfulCalculation } from '../../../lib/analytics';
    import { parseCalculatorNumber } from '../../../lib/input';
    import { calculate401kGrowth } from '../../../lib/math';

    const form = document.querySelector<HTMLFormElement>('#calculator-form');
    const error = document.querySelector<HTMLElement>('#form-error');
    const endingBalanceResult = document.querySelector<HTMLElement>(
      '#ending-balance-result',
    );
    const employeeContributionsResult = document.querySelector<HTMLElement>(
      '#employee-contributions-result',
    );
    const employerMatchResult = document.querySelector<HTMLElement>(
      '#employer-match-result',
    );
    const investmentGrowthResult = document.querySelector<HTMLElement>(
      '#investment-growth-result',
    );

    const currency = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 2,
    });

    function calculate() {
      if (
        !form ||
        !error ||
        !endingBalanceResult ||
        !employeeContributionsResult ||
        !employerMatchResult ||
        !investmentGrowthResult
      ) {
        return false;
      }

      const data = new FormData(form);
      const currentBalance = parseCalculatorNumber(data.get('currentBalance'));
      const employeeMonthlyContribution = parseCalculatorNumber(
        data.get('employeeMonthlyContribution'),
      );
      const employerMonthlyMatch = parseCalculatorNumber(
        data.get('employerMonthlyMatch'),
      );
      const expectedAnnualReturnPercent = parseCalculatorNumber(
        data.get('expectedAnnualReturn'),
      );
      const years = parseCalculatorNumber(data.get('years'));

      if (
        !Number.isFinite(currentBalance) ||
        !Number.isFinite(employeeMonthlyContribution) ||
        !Number.isFinite(employerMonthlyMatch) ||
        !Number.isFinite(expectedAnnualReturnPercent) ||
        !Number.isFinite(years) ||
        currentBalance < 0 ||
        employeeMonthlyContribution < 0 ||
        employerMonthlyMatch < 0 ||
        expectedAnnualReturnPercent < 0 ||
        years <= 0 ||
        !Number.isInteger(years)
      ) {
        error.textContent =
          'Balance, contributions, employer match, and expected return cannot be negative. Whole years must be greater than 0.';
        error.hidden = false;
        return false;
      }

      error.hidden = true;

      const result = calculate401kGrowth({
        currentBalance,
        employeeMonthlyContribution,
        employerMonthlyMatch,
        expectedAnnualReturnPercent,
        years,
      });

      endingBalanceResult.textContent = currency.format(result.endingBalance);
      employeeContributionsResult.textContent = currency.format(
        result.totalEmployeeContributions,
      );
      employerMatchResult.textContent = currency.format(
        result.totalEmployerMatch,
      );
      investmentGrowthResult.textContent = currency.format(
        result.investmentGrowth,
      );

      return true;
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      trackSuccessfulCalculation('401k_growth', calculate);
    });

    calculate();
  </script>
</CalculatorPage>
