---
import Layout from '../../../../layouts/Layout.astro';
import {
  balanceTransferSeoRecords,
  EXPECTED_BALANCE_TRANSFER_SEO_PAGE_COUNT,
} from '../../../../data/programmatic-seo/debt';
import { auditBalanceTransferSeoRecords } from '../../../../lib/programmatic-seo/debt';
import { createProgrammaticExampleGroups } from '../../../../lib/programmatic-seo/examples';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../../../lib/programmatic-seo/schema';

const audit = auditBalanceTransferSeoRecords(
  balanceTransferSeoRecords,
  EXPECTED_BALANCE_TRANSFER_SEO_PAGE_COUNT,
);
const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Calculators', url: '/calculators/' },
      {
        name: 'Balance Transfer Calculator',
        url: '/calculators/balance-transfer-calculator/',
      },
      {
        name: 'Balance Transfer Examples',
        url: '/calculators/balance-transfer/examples/',
      },
    ],
    site,
  ),
);
const currency = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});
const groups = createProgrammaticExampleGroups(
  balanceTransferSeoRecords,
  [
    {
      id: 'three-percent-fee',
      title: '3% Balance Transfer Fee Examples',
      description:
        'Compare common 3% transfer-fee scenarios across balances, APRs, and promotional periods.',
      matches: (record) => record.transferFeePercent === 3,
    },
    {
      id: 'higher-fee',
      title: '4% and 5% Fee Examples',
      description:
        'See when a larger transfer fee can still be offset by a lower promotional APR.',
      matches: (record) => record.transferFeePercent > 3,
    },
  ],
  (a, b) =>
    a.balance - b.balance ||
    a.currentAprPercent - b.currentAprPercent ||
    a.transferFeePercent - b.transferFeePercent,
);
---

<Layout
  title="Balance Transfer Examples | AutomatorLabs"
  description={`Browse ${audit.actualCount} balance transfer examples comparing current card payoff costs with promotional APR offers, transfer fees, and payoff timelines.`}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main id="main-content">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li>
          <a href="/calculators/balance-transfer-calculator/">
            Balance Transfer Calculator
          </a>
        </li>
        <li aria-current="page">Balance Transfer Examples</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Debt savings examples</p>
      <h1>Balance Transfer Examples</h1>
      <p class="intro">
        Browse {audit.actualCount} worked balance transfer examples comparing
        current credit card payoff costs with promotional APR offers and
        transfer fees.
      </p>
      <a class="primary-link" href="/calculators/balance-transfer-calculator/">
        Calculate your balance transfer
      </a>
      <a class="secondary-link" href="/examples/">
        Browse all financial examples
      </a>
    </header>

    <section class="example-search" aria-label="Search balance transfer examples">
      <label for="balance-transfer-example-search">
        Search balance transfer examples
      </label>
      <div class="search-row">
        <input
          id="balance-transfer-example-search"
          type="search"
          placeholder="Try 8000, 24.99, 3% fee, or 18 months"
          autocomplete="off"
          aria-controls="balance-transfer-example-groups"
          aria-describedby="balance-transfer-example-count"
        />
        <button id="clear-balance-transfer-example-search" type="button" hidden>
          Clear search
        </button>
      </div>
      <p id="balance-transfer-example-count" aria-live="polite">
        Showing {audit.actualCount} examples
      </p>
    </section>

    <div id="balance-transfer-example-groups" class="example-groups">
      {groups.map((group) => (
        <section
          class="example-group"
          aria-labelledby={`${group.id}-heading`}
          data-balance-transfer-example-group
        >
          <header>
            <div>
              <h2 id={`${group.id}-heading`}>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            <span>{group.records.length} examples</span>
          </header>
          <ul>
            {group.records.map((record) => (
              <li
                data-balance-transfer-example-card
                data-search-text={[
                  record.question,
                  record.slug,
                  record.balance,
                  record.balance.toLocaleString('en-US'),
                  record.currentAprPercent,
                  record.transferFeePercent,
                  record.promotionalMonths,
                  'balance transfer fee promo promotional',
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <a href={`/calculators/balance-transfer/${record.slug}/`}>
                  <strong>{record.question}</strong>
                  <span>
                    {currency.format(record.balance)} balance · {record.promotionalMonths}-month promo · {record.transferFeePercent}% fee
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p id="no-balance-transfer-examples" class="no-results" role="status" hidden>
      No balance transfer examples found. Try a balance, APR, fee, or promo length.
    </p>
  </main>
</Layout>

<script>
  const input = document.querySelector<HTMLInputElement>(
    '#balance-transfer-example-search',
  );
  const clearButton = document.querySelector<HTMLButtonElement>(
    '#clear-balance-transfer-example-search',
  );
  const count = document.querySelector<HTMLElement>(
    '#balance-transfer-example-count',
  );
  const noResults = document.querySelector<HTMLElement>(
    '#no-balance-transfer-examples',
  );
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>(
      '[data-balance-transfer-example-card]',
    ),
  );
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>(
      '[data-balance-transfer-example-group]',
    ),
  );

  function updateExamples() {
    if (!input || !count || !noResults) return;

    const query = input.value.trim().toLocaleLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches =
        query === '' || (card.dataset.searchText ?? '').includes(query);
      card.hidden = !matches;
      if (matches) visibleCount += 1;
    });

    groups.forEach((group) => {
      group.hidden = !group.querySelector(
        '[data-balance-transfer-example-card]:not([hidden])',
      );
    });

    count.textContent = `Showing ${visibleCount} ${visibleCount === 1 ? 'example' : 'examples'}`;
    noResults.hidden = visibleCount !== 0;
    if (clearButton) clearButton.hidden = query === '';
  }

  input?.addEventListener('input', updateExamples);
  clearButton?.addEventListener('click', () => {
    if (!input) return;
    input.value = '';
    updateExamples();
    input.focus();
  });
</script>

<style>
  main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .breadcrumbs li + li::before {
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a,
  .secondary-link {
    color: var(--link-color);
  }

  .page-header {
    max-width: 850px;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: var(--link-color);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    letter-spacing: -0.045em;
    line-height: 1.05;
  }

  .intro {
    margin: 1rem 0 1.25rem;
    color: var(--muted-text-color);
    font-size: 1.12rem;
    line-height: 1.72;
  }

  .primary-link {
    display: inline-block;
    border-radius: 10px;
    background: var(--button-background);
    color: var(--button-text);
    font-weight: 750;
    padding: 0.8rem 1rem;
    text-decoration: none;
  }

  .secondary-link {
    display: inline-block;
    margin-left: 0.75rem;
    font-weight: 750;
  }

  .example-search {
    margin: 3rem 0;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--card-background);
    padding: 1.25rem;
  }

  .example-search label {
    display: block;
    margin-bottom: 0.6rem;
    color: var(--heading-color);
    font-weight: 750;
  }

  .search-row {
    display: flex;
    gap: 0.7rem;
  }

  .search-row input {
    width: 100%;
    border: 1px solid var(--input-border);
    border-radius: 10px;
    background: var(--input-background);
    color: var(--input-text);
    font: inherit;
    padding: 0.8rem 0.9rem;
  }

  .search-row button {
    border: 1px solid var(--input-border);
    border-radius: 10px;
    background: var(--subtle-background);
    color: var(--text-color);
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    padding: 0.8rem 1rem;
    white-space: nowrap;
  }

  #balance-transfer-example-count {
    margin: 0.75rem 0 0;
    color: var(--muted-text-color);
    font-size: 0.92rem;
  }

  .example-groups {
    display: grid;
    gap: 2.5rem;
  }

  .example-group > header {
    display: flex;
    gap: 1rem;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .example-group h2 {
    margin: 0;
    color: var(--heading-color);
    font-size: 1.65rem;
  }

  .example-group header p {
    margin: 0.35rem 0 0;
    color: var(--muted-text-color);
  }

  .example-group header span {
    color: var(--muted-text-color);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .example-group ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .example-group a {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--card-background);
    color: var(--link-color);
    padding: 1rem;
    text-decoration: none;
  }

  .example-group a span {
    margin-top: 0.4rem;
    color: var(--muted-text-color);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .no-results {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--subtle-background);
    padding: 1rem;
  }

  @media (max-width: 720px) {
    main {
      padding: 3rem 0;
    }

    .search-row,
    .example-group > header {
      align-items: stretch;
      flex-direction: column;
    }

    .example-group ul {
      grid-template-columns: 1fr;
    }

    .secondary-link {
      display: block;
      margin: 1rem 0 0;
    }
  }
</style>
