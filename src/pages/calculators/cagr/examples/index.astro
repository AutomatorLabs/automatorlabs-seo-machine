---
import Layout from '../../../../layouts/Layout.astro';
import {
  cagrSeoRecords,
  EXPECTED_CAGR_SEO_PAGE_COUNT,
} from '../../../../data/programmatic-seo/cagr';
import { createProgrammaticExampleGroups } from '../../../../lib/programmatic-seo/examples';
import { auditCagrSeoRecords } from '../../../../lib/programmatic-seo/cagr';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../../../lib/programmatic-seo/schema';

const audit = auditCagrSeoRecords(
  cagrSeoRecords,
  EXPECTED_CAGR_SEO_PAGE_COUNT,
);
const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Calculators', url: '/calculators/' },
      {
        name: 'CAGR Calculator',
        url: '/calculators/cagr-calculator/',
      },
      {
        name: 'Examples',
        url: '/calculators/cagr/examples/',
      },
    ],
    site,
  ),
);
const currency = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});
const groups = createProgrammaticExampleGroups(cagrSeoRecords, [
  {
    id: 'market-assets',
    title: 'Stocks, ETFs, and Index Fund Examples',
    description:
      'Compare annualized growth across public-market holdings with different entry values, exit values, and time periods.',
    matches: (record) =>
      record.intent === 'stocks' ||
      record.intent === 'etfs' ||
      record.intent === 'index-funds',
  },
  {
    id: 'real-assets',
    title: 'Real Estate and Cryptocurrency Examples',
    description:
      'Browse alternative-asset CAGR examples that cover property appreciation and more volatile crypto outcomes.',
    matches: (record) =>
      record.intent === 'real-estate' ||
      record.intent === 'cryptocurrency',
  },
  {
    id: 'business-metrics',
    title: 'Business and Revenue Growth Examples',
    description:
      'Measure annualized operating growth across business-value and revenue scenarios.',
    matches: (record) =>
      record.intent === 'business-growth' ||
      record.intent === 'revenue-growth',
  },
  {
    id: 'portfolio-growth',
    title: 'Portfolio Growth Examples',
    description:
      'Review investment portfolio CAGR examples over medium and long holding periods.',
    matches: (record) => record.intent === 'portfolio-growth',
  },
]);
---

<Layout
  title="CAGR Examples | AutomatorLabs"
  description={`Browse ${audit.actualCount} CAGR examples covering stocks, ETFs, index funds, real estate, cryptocurrency, business growth, revenue growth, and portfolio growth.`}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main id="main-content">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li>
          <a href="/calculators/cagr-calculator/">CAGR Calculator</a>
        </li>
        <li aria-current="page">Examples</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Annualized growth example library</p>
      <h1>CAGR Examples</h1>
      <p class="intro">
        Browse {audit.actualCount} worked examples covering stocks, ETFs,
        index funds, real estate, cryptocurrency, business growth, revenue
        growth, and portfolio growth.
      </p>
      <a class="primary-link" href="/calculators/cagr-calculator/">
        Calculate your own CAGR
      </a>
      <a class="secondary-link" href="/examples/">
        Browse all financial examples
      </a>
    </header>

    <section class="example-search" aria-label="Search CAGR examples">
      <label for="cagr-example-search">Search CAGR examples</label>
      <div class="search-row">
        <input
          id="cagr-example-search"
          type="search"
          placeholder="Try stock, ETF, revenue, crypto, or 10 years"
          autocomplete="off"
          aria-controls="cagr-example-groups"
          aria-describedby="cagr-example-count"
        />
        <button id="clear-cagr-example-search" type="button" hidden>
          Clear search
        </button>
      </div>
      <p id="cagr-example-count" aria-live="polite">
        Showing {audit.actualCount} examples
      </p>
    </section>

    <div id="cagr-example-groups" class="example-groups">
      {groups.map((group) => (
        <section
          class="example-group"
          aria-labelledby={`${group.id}-heading`}
          data-cagr-example-group
        >
          <header>
            <div>
              <h2 id={`${group.id}-heading`}>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            <span>{group.records.length} examples</span>
          </header>

          <ul>
            {group.records.map((record) => (
              <li
                data-cagr-example-card
                data-search-text={[
                  record.question,
                  record.slug,
                  record.intent,
                  record.assetLabel,
                  record.startingValue,
                  record.startingValue.toLocaleString('en-US'),
                  record.endingValue,
                  record.endingValue.toLocaleString('en-US'),
                  record.years,
                  `${record.years} years`,
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <a href={`/calculators/cagr/${record.slug}/`}>
                  <strong>{record.question}</strong>
                  <span>
                    {currency.format(record.startingValue)} start
                    {' · '}
                    {currency.format(record.endingValue)} end
                    {' · '}
                    {record.years} years
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p id="no-cagr-examples" class="no-results" role="status" hidden>
      No CAGR examples found. Try an asset type, value, or time period.
    </p>
  </main>
</Layout>

<script>
  const input = document.querySelector<HTMLInputElement>('#cagr-example-search');
  const clearButton = document.querySelector<HTMLButtonElement>(
    '#clear-cagr-example-search',
  );
  const count = document.querySelector<HTMLElement>('#cagr-example-count');
  const noResults = document.querySelector<HTMLElement>('#no-cagr-examples');
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('[data-cagr-example-card]'),
  );
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>('[data-cagr-example-group]'),
  );

  function updateExamples() {
    if (!input || !count || !noResults) return;

    const query = input.value.trim().toLocaleLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches =
        query === '' || (card.dataset.searchText ?? '').includes(query);
      card.hidden = !matches;
      if (matches) visibleCount += 1;
    });

    groups.forEach((group) => {
      const visibleCards = group.querySelectorAll(
        '[data-cagr-example-card]:not([hidden])',
      ).length;
      group.hidden = visibleCards === 0;
      const badge = group.querySelector('header span');
      if (badge) {
        badge.textContent = `${visibleCards} example${visibleCards === 1 ? '' : 's'}`;
      }
    });

    count.textContent = `Showing ${visibleCount} example${visibleCount === 1 ? '' : 's'}`;
    noResults.hidden = visibleCount !== 0;

    if (clearButton) {
      clearButton.hidden = query === '';
    }
  }

  input?.addEventListener('input', updateExamples);
  clearButton?.addEventListener('click', () => {
    if (!input) return;
    input.value = '';
    input.focus();
    updateExamples();
  });

  updateExamples();
</script>

<style>
  main {
    width: min(1080px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li + li::before {
    margin-right: 0.45rem;
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a {
    color: var(--link-color);
    text-decoration: none;
  }

  .page-header {
    max-width: 860px;
    margin-bottom: 2rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--link-color);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0.6rem 0 1rem;
    font-size: clamp(2.6rem, 8vw, 4.8rem);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .intro {
    margin: 0;
    color: var(--muted-text-color);
    font-size: 1.1rem;
    line-height: 1.75;
  }

  .primary-link,
  .secondary-link {
    display: inline-flex;
    margin-top: 1.25rem;
    border-radius: 999px;
    padding: 0.8rem 1.15rem;
    font-weight: 700;
    text-decoration: none;
  }

  .primary-link {
    background: var(--button-background);
    color: var(--button-text);
  }

  .secondary-link {
    margin-left: 0.85rem;
    border: 1px solid var(--border-color);
    color: var(--link-color);
  }

  .example-search {
    margin: 2rem 0;
    border: 1px solid var(--border-color);
    border-radius: 20px;
    background: var(--card-background);
    box-shadow: 0 16px 40px var(--shadow-color);
    padding: 1.5rem;
  }

  .example-search label {
    display: block;
    margin-bottom: 0.7rem;
    color: var(--heading-color);
    font-weight: 700;
  }

  .search-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .search-row input {
    flex: 1 1 320px;
    min-width: 0;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--background-color);
    color: var(--text-color);
    font: inherit;
    padding: 0.85rem 1rem;
  }

  .search-row button {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: transparent;
    color: var(--text-color);
    font: inherit;
    font-weight: 700;
    padding: 0.85rem 1rem;
    cursor: pointer;
  }

  #cagr-example-count {
    margin: 0.85rem 0 0;
    color: var(--muted-text-color);
  }

  .example-groups {
    display: grid;
    gap: 1.5rem;
  }

  .example-group {
    border: 1px solid var(--border-color);
    border-radius: 20px;
    background: var(--card-background);
    box-shadow: 0 16px 40px var(--shadow-color);
    padding: 1.5rem;
  }

  .example-group header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
    margin-bottom: 1rem;
  }

  .example-group h2 {
    margin: 0;
    font-size: 1.35rem;
  }

  .example-group header p {
    margin: 0.5rem 0 0;
    color: var(--muted-text-color);
    line-height: 1.6;
  }

  .example-group header span {
    color: var(--link-color);
    font-size: 0.88rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .example-group ul {
    display: grid;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .example-group li a {
    display: grid;
    gap: 0.3rem;
    border: 1px solid var(--border-subtle);
    border-radius: 14px;
    padding: 1rem 1.05rem;
    color: inherit;
    text-decoration: none;
  }

  .example-group li a:hover {
    border-color: var(--link-color);
  }

  .example-group li strong {
    color: var(--heading-color);
  }

  .example-group li span,
  .no-results {
    color: var(--muted-text-color);
  }

  .no-results {
    margin: 1.5rem 0 0;
    text-align: center;
  }

  @media (max-width: 720px) {
    .primary-link,
    .secondary-link {
      width: 100%;
      justify-content: center;
      margin-left: 0;
    }

    .example-group header {
      flex-direction: column;
    }

    .example-group header span {
      white-space: normal;
    }
  }
</style>
