---
import ProgrammaticSeoPage from '../../../components/programmatic-seo/ProgrammaticSeoPage.astro';
import {
  compoundInterestSeoRecords,
  EXPECTED_COMPOUND_INTEREST_SEO_PAGE_COUNT,
  type CompoundInterestSeoRecord,
} from '../../../data/programmatic-seo/compound-interest';
import {
  auditCompoundInterestSeoRecords,
  createCompoundInterestSeoPage,
} from '../../../lib/programmatic-seo/compound-interest';

auditCompoundInterestSeoRecords(
  compoundInterestSeoRecords,
  EXPECTED_COMPOUND_INTEREST_SEO_PAGE_COUNT,
);

export function getStaticPaths() {
  return compoundInterestSeoRecords.map((record) => ({
    params: { slug: record.slug },
    props: { record },
  }));
}

interface Props {
  record: CompoundInterestSeoRecord;
}

const { record } = Astro.props;
const page = createCompoundInterestSeoPage(
  record,
  compoundInterestSeoRecords,
);
---

<ProgrammaticSeoPage page={page} />
