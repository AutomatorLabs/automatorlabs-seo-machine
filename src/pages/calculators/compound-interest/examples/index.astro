---
import Layout from '../../../../layouts/Layout.astro';
import {
  compoundInterestSeoRecords,
  EXPECTED_COMPOUND_INTEREST_SEO_PAGE_COUNT,
} from '../../../../data/programmatic-seo/compound-interest';
import { auditCompoundInterestSeoRecords } from '../../../../lib/programmatic-seo/compound-interest';
import { createProgrammaticExampleGroups } from '../../../../lib/programmatic-seo/examples';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../../../lib/programmatic-seo/schema';

const audit = auditCompoundInterestSeoRecords(
  compoundInterestSeoRecords,
  EXPECTED_COMPOUND_INTEREST_SEO_PAGE_COUNT,
);
const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Calculators', url: '/calculators/' },
      {
        name: 'Compound Interest Calculator',
        url: '/calculators/compound-interest/',
      },
      {
        name: 'Examples',
        url: '/calculators/compound-interest/examples/',
      },
    ],
    site,
  ),
);
const currency = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});

const groupDefinitions = [
  {
    id: 'starter',
    title: 'Starting amounts below $5,000',
    description: 'Smaller starting balances and shorter-term reference scenarios.',
    matches: (principal: number) => principal < 5000,
  },
  {
    id: 'building',
    title: '$5,000 to $24,999',
    description: 'Examples for early portfolio and savings milestones.',
    matches: (principal: number) => principal >= 5000 && principal < 25000,
  },
  {
    id: 'established',
    title: '$25,000 to $74,999',
    description: 'Mid-sized balances across a range of rates and time horizons.',
    matches: (principal: number) => principal >= 25000 && principal < 75000,
  },
  {
    id: 'large',
    title: '$75,000 and above',
    description: 'Larger starting amounts for long-range growth comparisons.',
    matches: (principal: number) => principal >= 75000,
  },
];

const groups = createProgrammaticExampleGroups(
  compoundInterestSeoRecords,
  groupDefinitions.map((group) => ({
    ...group,
    matches: (record: (typeof compoundInterestSeoRecords)[number]) =>
      group.matches(record.principal),
  })),
  (a, b) =>
    a.principal - b.principal ||
    a.annualRatePercent - b.annualRatePercent ||
    a.years - b.years,
);
---

<Layout
  title="Compound Interest Examples | AutomatorLabs"
  description="Browse and search 100 compound interest examples by starting amount, annual rate, and time period, with formulas, charts, and year-by-year projections."
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li><a href="/calculators/compound-interest/">Compound Interest Calculator</a></li>
        <li aria-current="page">Examples</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Compound interest library</p>
      <h1>Compound Interest Examples</h1>
      <p class="intro">
        Browse {audit.actualCount} worked examples covering different starting
        amounts, annual rates, and time periods. Every example includes the
        calculated result, formula, chart, assumptions, and year-by-year table.
      </p>
      <a class="primary-link" href="/calculators/compound-interest/">
        Try your own numbers
      </a>
      <a class="secondary-link" href="/examples/">
        Browse all financial examples
      </a>
    </header>

    <section
      class="example-search"
      aria-label="Search compound interest examples"
    >
      <label for="example-search">Search compound interest examples</label>
      <div class="search-row">
        <input
          id="example-search"
          type="search"
          placeholder="Try 10000, 8%, or 30 years"
          autocomplete="off"
          aria-controls="example-groups"
          aria-describedby="example-count"
        />
        <button id="clear-example-search" type="button" hidden>
          Clear search
        </button>
      </div>
      <p id="example-count" class="example-count" aria-live="polite">
        Showing {audit.actualCount} examples
      </p>
    </section>

    <div id="example-groups" class="example-groups">
      {groups.map((group) => (
        <section
          class="example-group"
          aria-labelledby={`${group.id}-heading`}
          data-example-group
        >
          <header>
            <div>
              <h2 id={`${group.id}-heading`}>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            <span>{group.records.length} examples</span>
          </header>

          <ul class="example-list">
            {group.records.map((record) => (
              <li
                data-example-card
                data-search-text={[
                  record.question,
                  record.slug,
                  record.principal,
                  record.principal.toLocaleString('en-US'),
                  record.annualRatePercent,
                  `${record.annualRatePercent}%`,
                  record.years,
                  `${record.years} years`,
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <a href={`/calculators/compound-interest/${record.slug}/`}>
                  <strong>{record.question}</strong>
                  <span>
                    {currency.format(record.principal)} · {record.annualRatePercent}% annual return · {record.years} years
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p id="no-examples-found" class="no-results" role="status" hidden>
      No examples found. Try a starting amount, rate, or number of years.
    </p>
  </main>
</Layout>

<script>
  const searchInput =
    document.querySelector<HTMLInputElement>('#example-search');
  const clearButton = document.querySelector<HTMLButtonElement>(
    '#clear-example-search',
  );
  const count = document.querySelector<HTMLElement>('#example-count');
  const noResults =
    document.querySelector<HTMLElement>('#no-examples-found');
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('[data-example-card]'),
  );
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>('[data-example-group]'),
  );

  function updateExamples() {
    if (!searchInput || !count || !noResults) return;

    const query = searchInput.value.trim().toLocaleLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches =
        query === '' || (card.dataset.searchText ?? '').includes(query);
      card.hidden = !matches;
      if (matches) visibleCount += 1;
    });

    groups.forEach((group) => {
      group.hidden = !group.querySelector('[data-example-card]:not([hidden])');
    });

    count.textContent = `Showing ${visibleCount} ${visibleCount === 1 ? 'example' : 'examples'}`;
    noResults.hidden = visibleCount !== 0;

    if (clearButton) {
      clearButton.hidden = query === '';
    }
  }

  searchInput?.addEventListener('input', updateExamples);
  clearButton?.addEventListener('click', () => {
    if (!searchInput) return;
    searchInput.value = '';
    updateExamples();
    searchInput.focus();
  });
</script>

<style>
  main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .breadcrumbs li + li::before {
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a {
    color: var(--link-color);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--text-color);
    font-weight: 650;
  }

  .page-header {
    max-width: 850px;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: var(--link-color);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    letter-spacing: -0.045em;
    line-height: 1.05;
  }

  .intro {
    margin: 1rem 0 1.25rem;
    color: var(--muted-text-color);
    font-size: 1.12rem;
    line-height: 1.72;
  }

  .primary-link {
    display: inline-block;
    border-radius: 10px;
    background: var(--button-background);
    color: var(--button-text);
    font-weight: 750;
    padding: 0.8rem 1rem;
    text-decoration: none;
  }

  .primary-link:hover {
    background: var(--button-hover-background);
  }

  .secondary-link {
    display: inline-block;
    margin-left: 0.75rem;
    color: var(--link-color);
    font-weight: 750;
  }

  .example-search {
    margin: 3rem 0;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--card-background);
    padding: 1.25rem;
  }

  .example-search label {
    display: block;
    margin-bottom: 0.6rem;
    color: var(--heading-color);
    font-weight: 750;
  }

  .search-row {
    display: flex;
    gap: 0.7rem;
  }

  .search-row input {
    width: 100%;
    border: 1px solid var(--input-border);
    border-radius: 10px;
    background: var(--input-background);
    color: var(--input-text);
    font: inherit;
    padding: 0.8rem 0.9rem;
  }

  .search-row input:focus {
    border-color: var(--link-color);
    box-shadow: 0 0 0 3px var(--focus-ring);
    outline: none;
  }

  .search-row button {
    border: 1px solid var(--input-border);
    border-radius: 10px;
    background: var(--subtle-background);
    color: var(--text-color);
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    padding: 0.8rem 1rem;
    white-space: nowrap;
  }

  .example-count {
    margin: 0.75rem 0 0;
    color: var(--muted-text-color);
    font-size: 0.92rem;
  }

  .example-groups {
    display: grid;
    gap: 2.5rem;
  }

  .example-group > header {
    display: flex;
    gap: 1rem;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .example-group h2 {
    margin: 0;
    color: var(--heading-color);
    font-size: 1.65rem;
  }

  .example-group header p {
    margin: 0.35rem 0 0;
    color: var(--muted-text-color);
  }

  .example-group header span {
    color: var(--muted-text-color);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .example-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .example-list a {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--card-background);
    color: var(--link-color);
    padding: 1rem;
    text-decoration: none;
  }

  .example-list a:hover {
    border-color: var(--link-color);
    background: var(--subtle-background);
  }

  .example-list span {
    margin-top: 0.4rem;
    color: var(--muted-text-color);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .no-results {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--subtle-background);
    color: var(--text-color);
    padding: 1rem;
  }

  @media (max-width: 720px) {
    main {
      padding: 3rem 0;
    }

    .search-row,
    .example-group > header {
      align-items: stretch;
      flex-direction: column;
    }

    .example-list {
      grid-template-columns: 1fr;
    }

    .secondary-link {
      display: block;
      margin: 1rem 0 0;
    }
  }
</style>
