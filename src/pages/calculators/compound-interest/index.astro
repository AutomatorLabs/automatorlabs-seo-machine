---
import CalculatorPage from '../../../components/CalculatorPage.astro';
import { compoundInterestCalculator } from '../../../data/calculators';
import { contentItems } from '../../../data/content';

const relatedItems = compoundInterestCalculator.relatedIds.flatMap((id) => {
  const item = contentItems.find((contentItem) => contentItem.id === id);
  return item ? [{ title: item.title, url: item.url }] : [];
});
---

<CalculatorPage
  title={compoundInterestCalculator.title}
  eyebrow={compoundInterestCalculator.eyebrow}
  description={compoundInterestCalculator.description}
  inputs={compoundInterestCalculator.inputs}
  outputs={compoundInterestCalculator.outputs}
  faq={compoundInterestCalculator.faq}
  relatedItems={relatedItems}
>
  <script>
    const form = document.querySelector<HTMLFormElement>('#calculator-form');
    const error = document.querySelector<HTMLElement>('#form-error');
    const finalBalance = document.querySelector<HTMLElement>('#final-balance');
    const totalContributions = document.querySelector<HTMLElement>('#total-contributions');
    const totalInterest = document.querySelector<HTMLElement>('#total-interest');

    const currency = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 2,
    });

    function calculate() {
      if (!form || !error || !finalBalance || !totalContributions || !totalInterest) {
        return;
      }

      const data = new FormData(form);
      const principal = Number(data.get('principal'));
      const monthlyContribution = Number(data.get('monthlyContribution'));
      const annualRate = Number(data.get('interestRate')) / 100;
      const years = Number(data.get('years'));
      const periodsPerYear = Number(data.get('frequency'));

      const values = [
        principal,
        monthlyContribution,
        annualRate,
        years,
        periodsPerYear,
      ];
      const isInvalid =
        values.some((value) => !Number.isFinite(value)) ||
        principal < 0 ||
        monthlyContribution < 0 ||
        annualRate < 0 ||
        years <= 0 ||
        periodsPerYear <= 0;

      if (isInvalid) {
        error.hidden = false;
        return;
      }

      error.hidden = true;

      const numberOfPeriods = periodsPerYear * years;
      const ratePerPeriod = annualRate / periodsPerYear;
      const contributionPerPeriod = (monthlyContribution * 12) / periodsPerYear;
      const growthFactor = Math.pow(1 + ratePerPeriod, numberOfPeriods);
      const contributionGrowth =
        ratePerPeriod === 0
          ? contributionPerPeriod * numberOfPeriods
          : contributionPerPeriod * ((growthFactor - 1) / ratePerPeriod);

      const balance = principal * growthFactor + contributionGrowth;
      const contributions = principal + monthlyContribution * 12 * years;
      const interest = balance - contributions;

      finalBalance.textContent = currency.format(balance);
      totalContributions.textContent = currency.format(contributions);
      totalInterest.textContent = currency.format(interest);
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      calculate();
    });

    calculate();
  </script>
</CalculatorPage>
