---
import { contentItems } from '../../../data/content';
import Layout from '../../../layouts/Layout.astro';

const contentItem = contentItems.find(
  (item) => item.id === 'compound-interest-calculator',
);

if (!contentItem) {
  throw new Error('Compound interest calculator is missing from the content manifest.');
}

const relatedCalculators = contentItem.relatedIds
  .map((id) => contentItems.find((item) => item.id === id))
  .filter((item) => item !== undefined);
---

<Layout title={contentItem.title} description={contentItem.description}>
  <main>
    <header class="page-header">
      <p class="eyebrow">Financial calculator</p>
      <h1>{contentItem.title}</h1>
      <p class="intro">
        Compound interest is interest earned on both your original investment and
        the interest it has already accumulated. Use this calculator to estimate
        how your savings could grow over time.
      </p>
    </header>

    <section class="calculator" aria-labelledby="calculator-heading">
      <div class="panel">
        <h2 id="calculator-heading">Calculate your investment growth</h2>

        <form id="compound-interest-form">
          <div class="form-grid">
            <div class="field">
              <label for="principal">Initial principal</label>
              <div class="input-with-prefix">
                <span aria-hidden="true">$</span>
                <input
                  id="principal"
                  name="principal"
                  type="number"
                  min="0"
                  step="100"
                  value="10000"
                  required
                />
              </div>
            </div>

            <div class="field">
              <label for="monthly-contribution">Monthly contribution</label>
              <div class="input-with-prefix">
                <span aria-hidden="true">$</span>
                <input
                  id="monthly-contribution"
                  name="monthlyContribution"
                  type="number"
                  min="0"
                  step="10"
                  value="500"
                  required
                />
              </div>
            </div>

            <div class="field">
              <label for="interest-rate">Annual interest rate (%)</label>
              <input
                id="interest-rate"
                name="interestRate"
                type="number"
                min="0"
                step="0.01"
                value="7"
                required
              />
            </div>

            <div class="field">
              <label for="years">Number of years</label>
              <input
                id="years"
                name="years"
                type="number"
                min="1"
                step="1"
                value="20"
                required
              />
            </div>

            <div class="field field-wide">
              <label for="frequency">Compounding frequency</label>
              <select id="frequency" name="frequency">
                <option value="12" selected>Monthly</option>
                <option value="4">Quarterly</option>
                <option value="1">Annually</option>
              </select>
            </div>
          </div>

          <p id="form-error" class="error" role="alert" hidden>
            Enter valid, non-negative values in every field.
          </p>

          <button type="submit">Calculate</button>
        </form>
      </div>

      <section class="results panel" aria-labelledby="results-heading" aria-live="polite">
        <h2 id="results-heading">Your results</h2>
        <dl>
          <div class="primary-result">
            <dt>Final balance</dt>
            <dd id="final-balance">$0.00</dd>
          </div>
          <div>
            <dt>Total contributions</dt>
            <dd id="total-contributions">$0.00</dd>
          </div>
          <div>
            <dt>Total interest earned</dt>
            <dd id="total-interest">$0.00</dd>
          </div>
        </dl>

        <div id="chart" aria-label="Investment growth chart placeholder">
          <span>Growth chart coming soon</span>
        </div>
      </section>
    </section>

    <section class="content-section" aria-labelledby="faq-heading">
      <h2 id="faq-heading">Frequently asked questions</h2>

      <div class="faq-list">
        <details>
          <summary>What is compound interest?</summary>
          <p>
            Compound interest is calculated on your starting balance plus any
            interest previously earned, allowing growth to build on itself.
          </p>
        </details>
        <details>
          <summary>How often should interest be compounded?</summary>
          <p>
            More frequent compounding generally produces a slightly higher
            balance when the annual rate and all other inputs are the same.
          </p>
        </details>
        <details>
          <summary>How do monthly contributions affect growth?</summary>
          <p>
            Regular contributions increase the amount earning interest. Starting
            early gives each contribution more time to compound.
          </p>
        </details>
        <details>
          <summary>Does this calculator account for taxes or fees?</summary>
          <p>
            No. The estimate does not include investment fees, taxes, inflation,
            or changes in the interest rate.
          </p>
        </details>
        <details>
          <summary>Is the calculated return guaranteed?</summary>
          <p>
            No. This calculator provides an estimate based on a fixed annual
            rate. Actual investment returns can rise or fall over time.
          </p>
        </details>
      </div>
    </section>

    <section class="content-section" aria-labelledby="related-heading">
      <h2 id="related-heading">Related Calculators</h2>
      <nav class="related-links" aria-label="Related calculators">
        {relatedCalculators.map((item) => (
          <a href={item.url}>{item.title}</a>
        ))}
      </nav>
    </section>
  </main>
</Layout>

<script>
  const form = document.querySelector<HTMLFormElement>('#compound-interest-form');
  const error = document.querySelector<HTMLElement>('#form-error');
  const finalBalance = document.querySelector<HTMLElement>('#final-balance');
  const totalContributions = document.querySelector<HTMLElement>('#total-contributions');
  const totalInterest = document.querySelector<HTMLElement>('#total-interest');

  const currency = new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    maximumFractionDigits: 2,
  });

  function calculate() {
    if (!form || !error || !finalBalance || !totalContributions || !totalInterest) {
      return;
    }

    const data = new FormData(form);
    const principal = Number(data.get('principal'));
    const monthlyContribution = Number(data.get('monthlyContribution'));
    const annualRate = Number(data.get('interestRate')) / 100;
    const years = Number(data.get('years'));
    const periodsPerYear = Number(data.get('frequency'));

    const values = [
      principal,
      monthlyContribution,
      annualRate,
      years,
      periodsPerYear,
    ];
    const isInvalid =
      values.some((value) => !Number.isFinite(value)) ||
      principal < 0 ||
      monthlyContribution < 0 ||
      annualRate < 0 ||
      years <= 0 ||
      periodsPerYear <= 0;

    if (isInvalid) {
      error.hidden = false;
      return;
    }

    error.hidden = true;

    const numberOfPeriods = periodsPerYear * years;
    const ratePerPeriod = annualRate / periodsPerYear;
    const contributionPerPeriod = (monthlyContribution * 12) / periodsPerYear;
    const growthFactor = Math.pow(1 + ratePerPeriod, numberOfPeriods);
    const contributionGrowth =
      ratePerPeriod === 0
        ? contributionPerPeriod * numberOfPeriods
        : contributionPerPeriod * ((growthFactor - 1) / ratePerPeriod);

    const balance = principal * growthFactor + contributionGrowth;
    const contributions = principal + monthlyContribution * 12 * years;
    const interest = balance - contributions;

    finalBalance.textContent = currency.format(balance);
    totalContributions.textContent = currency.format(contributions);
    totalInterest.textContent = currency.format(interest);
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    calculate();
  });

  calculate();
</script>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(body) {
    background: #f6f7fb;
    color: #172033;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    line-height: 1.6;
  }

  main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .page-header {
    max-width: 760px;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    color: #3158d3;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 0.8rem;
    font-size: clamp(2.15rem, 6vw, 3.75rem);
    line-height: 1.08;
    letter-spacing: -0.045em;
  }

  h2 {
    margin-bottom: 1.25rem;
    font-size: 1.35rem;
    line-height: 1.25;
  }

  .intro {
    max-width: 680px;
    margin-bottom: 0;
    color: #586176;
    font-size: 1.08rem;
  }

  .calculator {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: 1.25rem;
    align-items: start;
  }

  .panel,
  .content-section {
    border: 1px solid #e1e4ec;
    border-radius: 16px;
    background: #fff;
    box-shadow: 0 12px 35px rgb(22 32 51 / 6%);
  }

  .panel {
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field-wide {
    grid-column: 1 / -1;
  }

  label {
    font-size: 0.9rem;
    font-weight: 650;
  }

  input,
  select {
    width: 100%;
    min-height: 46px;
    border: 1px solid #cdd2df;
    border-radius: 9px;
    background: #fff;
    color: inherit;
    font: inherit;
    padding: 0.65rem 0.75rem;
  }

  input:focus,
  select:focus {
    border-color: #3158d3;
    outline: 3px solid rgb(49 88 211 / 14%);
  }

  .input-with-prefix {
    position: relative;
  }

  .input-with-prefix span {
    position: absolute;
    top: 50%;
    left: 0.8rem;
    color: #6d7485;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .input-with-prefix input {
    padding-left: 1.75rem;
  }

  button {
    width: 100%;
    margin-top: 1.25rem;
    border: 0;
    border-radius: 9px;
    background: #3158d3;
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    padding: 0.8rem 1rem;
    transition:
      background 150ms ease,
      transform 150ms ease;
  }

  button:hover {
    background: #2647b0;
  }

  button:active {
    transform: translateY(1px);
  }

  button:focus-visible {
    outline: 3px solid rgb(49 88 211 / 25%);
    outline-offset: 3px;
  }

  .error {
    margin: 1rem 0 0;
    color: #b42318;
    font-size: 0.9rem;
  }

  .results dl {
    display: grid;
    gap: 0;
    margin: 0;
  }

  .results dl > div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid #eceef3;
    padding: 1rem 0;
  }

  .results dl > div:first-child {
    padding-top: 0;
  }

  .results dt {
    color: #626a7c;
  }

  .results dd {
    margin: 0;
    font-weight: 750;
    text-align: right;
  }

  .results .primary-result dd {
    color: #3158d3;
    font-size: 1.25rem;
  }

  #chart {
    display: grid;
    min-height: 190px;
    margin-top: 1.5rem;
    border: 1px dashed #c9ceda;
    border-radius: 10px;
    background: #f9faff;
    color: #777f91;
    place-items: center;
  }

  #chart span {
    font-size: 0.9rem;
  }

  .content-section {
    margin-top: 1.25rem;
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .faq-list {
    border-top: 1px solid #e6e8ef;
  }

  details {
    border-bottom: 1px solid #e6e8ef;
    padding: 1rem 0;
  }

  summary {
    cursor: pointer;
    font-weight: 700;
  }

  details p {
    max-width: 760px;
    margin: 0.65rem 0 0;
    color: #5b6477;
  }

  .related-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .related-links a {
    border: 1px solid #dfe3ec;
    border-radius: 10px;
    color: #2446ad;
    font-weight: 650;
    padding: 0.9rem 1rem;
    text-decoration: none;
  }

  .related-links a:hover {
    border-color: #3158d3;
    background: #f5f7ff;
  }

  @media (max-width: 760px) {
    main {
      padding: 2.75rem 0;
    }

    .calculator,
    .related-links {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .form-grid {
      grid-template-columns: 1fr;
    }

    .field-wide {
      grid-column: auto;
    }

    .results dl > div {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.2rem;
    }

    .results dd {
      text-align: left;
    }
  }
</style>
