---
import Layout from '../../../../layouts/Layout.astro';
import {
  creditCardExtraPaymentSeoRecords,
  EXPECTED_CREDIT_CARD_EXTRA_PAYMENT_SEO_PAGE_COUNT,
} from '../../../../data/programmatic-seo/credit-card-extra-payment';
import { createProgrammaticExampleGroups } from '../../../../lib/programmatic-seo/examples';
import { auditCreditCardExtraPaymentSeoRecords } from '../../../../lib/programmatic-seo/credit-card-extra-payment';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../../../lib/programmatic-seo/schema';

const audit = auditCreditCardExtraPaymentSeoRecords(
  creditCardExtraPaymentSeoRecords,
  EXPECTED_CREDIT_CARD_EXTRA_PAYMENT_SEO_PAGE_COUNT,
);
const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Calculators', url: '/calculators/' },
      {
        name: 'Credit Card Extra Payment Calculator',
        url: '/calculators/credit-card-extra-payment-calculator/',
      },
      {
        name: 'Examples',
        url: '/calculators/credit-card-extra-payment/examples/',
      },
    ],
    site,
  ),
);
const currency = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});
const groups = createProgrammaticExampleGroups(
  creditCardExtraPaymentSeoRecords,
  [
    {
      id: 'starter-balance',
      title: 'Starter Balance Examples',
      description:
        'Examples focused on smaller balances where an early extra payment can quickly change the path.',
      matches: (record) => record.intent === 'starter-balance',
    },
    {
      id: 'average-balance',
      title: 'Average Balance Examples',
      description:
        'Examples focused on common card balances and practical recurring extra payments.',
      matches: (record) => record.intent === 'average-balance',
    },
    {
      id: 'high-apr',
      title: 'High APR Examples',
      description:
        'Examples focused on high-rate balances where extra principal can save more interest.',
      matches: (record) => record.intent === 'high-apr',
    },
    {
      id: 'aggressive-extra',
      title: 'Aggressive Extra Payment Examples',
      description:
        'Examples focused on larger recurring extra payments and faster payoff targets.',
      matches: (record) => record.intent === 'aggressive-extra',
    },
    {
      id: 'large-balance',
      title: 'Large Balance Examples',
      description:
        'Examples focused on bigger balances where extra payments protect against prolonged interest drag.',
      matches: (record) => record.intent === 'large-balance',
    },
  ],
);
---

<Layout
  title="Credit Card Extra Payment Examples | AutomatorLabs"
  description={`Browse ${audit.actualCount} credit card extra payment examples covering starter balances, high APR cards, aggressive extra payments, and large balances.`}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main id="main-content">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li>
          <a href="/calculators/credit-card-extra-payment-calculator/">
            Credit Card Extra Payment Calculator
          </a>
        </li>
        <li aria-current="page">Examples</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Extra payment scenario library</p>
      <h1>Credit Card Extra Payment Examples</h1>
      <p class="intro">
        Browse {audit.actualCount} worked examples showing how recurring extra
        payments can shorten payoff time and reduce interest across different
        balances and APRs.
      </p>
      <a class="primary-link" href="/calculators/credit-card-extra-payment-calculator/">
        Model your own extra payment scenario
      </a>
      <a class="secondary-link" href="/examples/">
        Browse all financial examples
      </a>
    </header>

    <section class="example-search" aria-label="Search extra payment examples">
      <label for="credit-card-extra-payment-example-search">
        Search extra payment examples
      </label>
      <div class="search-row">
        <input
          id="credit-card-extra-payment-example-search"
          type="search"
          placeholder="Try 50 extra, 24.99, or 10000"
          autocomplete="off"
          aria-controls="credit-card-extra-payment-example-groups"
          aria-describedby="credit-card-extra-payment-example-count"
        />
        <button id="clear-credit-card-extra-payment-example-search" type="button" hidden>
          Clear search
        </button>
      </div>
      <p id="credit-card-extra-payment-example-count" aria-live="polite">
        Showing {audit.actualCount} examples
      </p>
    </section>

    <div id="credit-card-extra-payment-example-groups" class="example-groups">
      {groups.map((group) => (
        <section
          class="example-group"
          aria-labelledby={`${group.id}-heading`}
          data-credit-card-extra-payment-example-group
        >
          <header>
            <div>
              <h2 id={`${group.id}-heading`}>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            <span>{group.records.length} examples</span>
          </header>

          <ul>
            {group.records.map((record) => (
              <li
                data-credit-card-extra-payment-example-card
                data-search-text={[
                  record.question,
                  record.slug,
                  record.intent,
                  record.balance,
                  record.balance.toLocaleString('en-US'),
                  record.aprPercent,
                  record.monthlyPayment,
                  record.extraMonthlyPayment,
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <a href={`/calculators/credit-card-extra-payment/${record.slug}/`}>
                  <strong>{record.question}</strong>
                  <span>
                    {currency.format(record.balance)} balance {' · '}
                    {record.aprPercent}% APR {' · '}
                    {currency.format(record.extraMonthlyPayment)} extra
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p id="no-credit-card-extra-payment-examples" class="no-results" role="status" hidden>
      No extra payment examples found. Try a balance, APR, or extra payment amount.
    </p>
  </main>
</Layout>

<script>
  const input = document.querySelector<HTMLInputElement>(
    '#credit-card-extra-payment-example-search',
  );
  const clearButton = document.querySelector<HTMLButtonElement>(
    '#clear-credit-card-extra-payment-example-search',
  );
  const count = document.querySelector<HTMLElement>(
    '#credit-card-extra-payment-example-count',
  );
  const noResults = document.querySelector<HTMLElement>(
    '#no-credit-card-extra-payment-examples',
  );
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>(
      '[data-credit-card-extra-payment-example-card]',
    ),
  );
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>(
      '[data-credit-card-extra-payment-example-group]',
    ),
  );

  function updateExamples() {
    if (!input || !count || !noResults) return;

    const query = input.value.trim().toLocaleLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches =
        query === '' || (card.dataset.searchText ?? '').includes(query);
      card.hidden = !matches;
      if (matches) visibleCount += 1;
    });

    groups.forEach((group) => {
      group.hidden = !group.querySelector(
        '[data-credit-card-extra-payment-example-card]:not([hidden])',
      );
    });

    count.textContent = `Showing ${visibleCount} ${visibleCount === 1 ? 'example' : 'examples'}`;
    noResults.hidden = visibleCount !== 0;
    if (clearButton) clearButton.hidden = query === '';
  }

  input?.addEventListener('input', updateExamples);
  clearButton?.addEventListener('click', () => {
    if (!input) return;
    input.value = '';
    updateExamples();
    input.focus();
  });
</script>
