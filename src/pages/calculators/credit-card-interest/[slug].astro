---
import ProgrammaticSeoPage from '../../../components/programmatic-seo/ProgrammaticSeoPage.astro';
import {
  creditCardInterestSeoRecords,
  EXPECTED_CREDIT_CARD_INTEREST_SEO_PAGE_COUNT,
} from '../../../data/programmatic-seo/credit-card-interest';
import {
  auditCreditCardInterestSeoRecords,
  createCreditCardInterestSeoPage,
} from '../../../lib/programmatic-seo/credit-card-interest';

auditCreditCardInterestSeoRecords(
  creditCardInterestSeoRecords,
  EXPECTED_CREDIT_CARD_INTEREST_SEO_PAGE_COUNT,
);

export function getStaticPaths() {
  return creditCardInterestSeoRecords.map((record) => ({
    params: { slug: record.slug },
    props: {
      page: createCreditCardInterestSeoPage(
        record,
        creditCardInterestSeoRecords,
      ),
    },
  }));
}

const { page } = Astro.props;
---

<ProgrammaticSeoPage page={page} />
