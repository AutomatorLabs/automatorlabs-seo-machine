---
import Layout from '../../../../layouts/Layout.astro';
import {
  creditCardPayoffSeoRecords,
  EXPECTED_CREDIT_CARD_PAYOFF_SEO_PAGE_COUNT,
} from '../../../../data/programmatic-seo/debt';
import { auditCreditCardPayoffSeoRecords } from '../../../../lib/programmatic-seo/debt';
import { createProgrammaticExampleGroups } from '../../../../lib/programmatic-seo/examples';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../../../lib/programmatic-seo/schema';

const audit = auditCreditCardPayoffSeoRecords(
  creditCardPayoffSeoRecords,
  EXPECTED_CREDIT_CARD_PAYOFF_SEO_PAGE_COUNT,
);
const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Calculators', url: '/calculators/' },
      {
        name: 'Credit Card Payoff Calculator',
        url: '/calculators/credit-card-payoff-calculator/',
      },
      {
        name: 'Credit Card Payoff Examples',
        url: '/calculators/credit-card-payoff/examples/',
      },
    ],
    site,
  ),
);
const currency = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});
const groups = createProgrammaticExampleGroups(
  creditCardPayoffSeoRecords,
  [
    {
      id: 'standard-payoff',
      title: 'Payoff by Monthly Payment',
      description:
        'Estimate payoff time and interest from a fixed monthly credit card payment.',
      matches: (record) => record.extraMonthlyPayment === 0,
    },
    {
      id: 'extra-payment',
      title: 'Payoff With Extra Payments',
      description:
        'Compare how extra monthly principal can shorten payoff time and reduce interest.',
      matches: (record) => record.extraMonthlyPayment > 0,
    },
  ],
  (a, b) =>
    a.balance - b.balance ||
    a.aprPercent - b.aprPercent ||
    a.monthlyPayment - b.monthlyPayment,
);
---

<Layout
  title="Credit Card Payoff Examples | AutomatorLabs"
  description={`Browse ${audit.actualCount} credit card payoff examples by balance, APR, payment amount, and extra payment assumptions.`}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li>
          <a href="/calculators/credit-card-payoff-calculator/">
            Credit Card Payoff Calculator
          </a>
        </li>
        <li aria-current="page">Credit Card Payoff Examples</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Debt payoff examples</p>
      <h1>Credit Card Payoff Examples</h1>
      <p class="intro">
        Browse {audit.actualCount} worked credit card payoff examples covering
        realistic balances, APRs, monthly payments, and extra-payment scenarios.
      </p>
      <a class="primary-link" href="/calculators/credit-card-payoff-calculator/">
        Calculate your credit card payoff
      </a>
      <a class="secondary-link" href="/examples/">
        Browse all financial examples
      </a>
    </header>

    <section class="example-search" aria-label="Search credit card payoff examples">
      <label for="credit-card-payoff-example-search">
        Search credit card payoff examples
      </label>
      <div class="search-row">
        <input
          id="credit-card-payoff-example-search"
          type="search"
          placeholder="Try 10000, 24.99, 300, or extra"
          autocomplete="off"
          aria-controls="credit-card-payoff-example-groups"
          aria-describedby="credit-card-payoff-example-count"
        />
        <button id="clear-credit-card-payoff-example-search" type="button" hidden>
          Clear search
        </button>
      </div>
      <p id="credit-card-payoff-example-count" aria-live="polite">
        Showing {audit.actualCount} examples
      </p>
    </section>

    <div id="credit-card-payoff-example-groups" class="example-groups">
      {groups.map((group) => (
        <section
          class="example-group"
          aria-labelledby={`${group.id}-heading`}
          data-credit-card-payoff-example-group
        >
          <header>
            <div>
              <h2 id={`${group.id}-heading`}>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            <span>{group.records.length} examples</span>
          </header>
          <ul>
            {group.records.map((record) => (
              <li
                data-credit-card-payoff-example-card
                data-search-text={[
                  record.question,
                  record.slug,
                  record.balance,
                  record.balance.toLocaleString('en-US'),
                  record.aprPercent,
                  record.monthlyPayment,
                  record.extraMonthlyPayment > 0 ? 'extra payment' : '',
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <a href={`/calculators/credit-card-payoff/${record.slug}/`}>
                  <strong>{record.question}</strong>
                  <span>
                    {currency.format(record.balance)} balance · {record.aprPercent}% APR · {currency.format(record.monthlyPayment + record.extraMonthlyPayment)}/mo
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p id="no-credit-card-payoff-examples" class="no-results" role="status" hidden>
      No credit card payoff examples found. Try a balance, APR, or payment amount.
    </p>
  </main>
</Layout>

<script>
  const input = document.querySelector<HTMLInputElement>(
    '#credit-card-payoff-example-search',
  );
  const clearButton = document.querySelector<HTMLButtonElement>(
    '#clear-credit-card-payoff-example-search',
  );
  const count = document.querySelector<HTMLElement>(
    '#credit-card-payoff-example-count',
  );
  const noResults = document.querySelector<HTMLElement>(
    '#no-credit-card-payoff-examples',
  );
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>(
      '[data-credit-card-payoff-example-card]',
    ),
  );
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>(
      '[data-credit-card-payoff-example-group]',
    ),
  );

  function updateExamples() {
    if (!input || !count || !noResults) return;

    const query = input.value.trim().toLocaleLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches =
        query === '' || (card.dataset.searchText ?? '').includes(query);
      card.hidden = !matches;
      if (matches) visibleCount += 1;
    });

    groups.forEach((group) => {
      group.hidden = !group.querySelector(
        '[data-credit-card-payoff-example-card]:not([hidden])',
      );
    });

    count.textContent = `Showing ${visibleCount} ${visibleCount === 1 ? 'example' : 'examples'}`;
    noResults.hidden = visibleCount !== 0;
    if (clearButton) clearButton.hidden = query === '';
  }

  input?.addEventListener('input', updateExamples);
  clearButton?.addEventListener('click', () => {
    if (!input) return;
    input.value = '';
    updateExamples();
    input.focus();
  });
</script>

<style>
  main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .breadcrumbs li + li::before {
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a,
  .secondary-link {
    color: var(--link-color);
  }

  .page-header {
    max-width: 850px;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: var(--link-color);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    letter-spacing: -0.045em;
    line-height: 1.05;
  }

  .intro {
    margin: 1rem 0 1.25rem;
    color: var(--muted-text-color);
    font-size: 1.12rem;
    line-height: 1.72;
  }

  .primary-link {
    display: inline-block;
    border-radius: 10px;
    background: var(--button-background);
    color: var(--button-text);
    font-weight: 750;
    padding: 0.8rem 1rem;
    text-decoration: none;
  }

  .secondary-link {
    display: inline-block;
    margin-left: 0.75rem;
    font-weight: 750;
  }

  .example-search {
    margin: 3rem 0;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--card-background);
    padding: 1.25rem;
  }

  .example-search label {
    display: block;
    margin-bottom: 0.6rem;
    color: var(--heading-color);
    font-weight: 750;
  }

  .search-row {
    display: flex;
    gap: 0.7rem;
  }

  .search-row input {
    width: 100%;
    border: 1px solid var(--input-border);
    border-radius: 10px;
    background: var(--input-background);
    color: var(--input-text);
    font: inherit;
    padding: 0.8rem 0.9rem;
  }

  .search-row button {
    border: 1px solid var(--input-border);
    border-radius: 10px;
    background: var(--subtle-background);
    color: var(--text-color);
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    padding: 0.8rem 1rem;
    white-space: nowrap;
  }

  #credit-card-payoff-example-count {
    margin: 0.75rem 0 0;
    color: var(--muted-text-color);
    font-size: 0.92rem;
  }

  .example-groups {
    display: grid;
    gap: 2.5rem;
  }

  .example-group > header {
    display: flex;
    gap: 1rem;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .example-group h2 {
    margin: 0;
    color: var(--heading-color);
    font-size: 1.65rem;
  }

  .example-group header p {
    margin: 0.35rem 0 0;
    color: var(--muted-text-color);
  }

  .example-group header span {
    color: var(--muted-text-color);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .example-group ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .example-group a {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--card-background);
    color: var(--link-color);
    padding: 1rem;
    text-decoration: none;
  }

  .example-group a span {
    margin-top: 0.4rem;
    color: var(--muted-text-color);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .no-results {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--subtle-background);
    padding: 1rem;
  }

  @media (max-width: 720px) {
    main {
      padding: 3rem 0;
    }

    .search-row,
    .example-group > header {
      align-items: stretch;
      flex-direction: column;
    }

    .example-group ul {
      grid-template-columns: 1fr;
    }

    .secondary-link {
      display: block;
      margin: 1rem 0 0;
    }
  }
</style>
