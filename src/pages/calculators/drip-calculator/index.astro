---
import CalculatorPage from '../../../components/CalculatorPage.astro';
import { dripCalculator } from '../../../data/calculators';
import { contentItems } from '../../../data/content';

const relatedItems = dripCalculator.relatedIds.flatMap((id) => {
  const item = contentItems.find((contentItem) => contentItem.id === id);
  return item ? [{ title: item.title, url: item.url }] : [];
});
---

<CalculatorPage
  title={dripCalculator.title}
  eyebrow={dripCalculator.eyebrow}
  description={dripCalculator.description}
  inputs={dripCalculator.inputs}
  outputs={dripCalculator.outputs}
  faq={dripCalculator.faq}
  relatedItems={relatedItems}
>
  <script>
    import { trackSuccessfulCalculation } from '../../../lib/analytics';
    import { parseCalculatorNumber } from '../../../lib/input';
    import { calculateDrip } from '../../../lib/math';

    const form = document.querySelector<HTMLFormElement>('#calculator-form');
    const error = document.querySelector<HTMLElement>('#form-error');
    const finalPortfolioValueResult = document.querySelector<HTMLElement>(
      '#final-portfolio-value-result',
    );
    const totalDividendsEarnedResult = document.querySelector<HTMLElement>(
      '#total-dividends-earned-result',
    );
    const totalContributionsResult = document.querySelector<HTMLElement>(
      '#total-contributions-result',
    );
    const estimatedAnnualDividendIncomeResult =
      document.querySelector<HTMLElement>(
        '#estimated-annual-dividend-income-result',
      );
    const chart = document.querySelector<HTMLElement>('#chart');

    const currency = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 2,
    });

    const compactCurrency = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      notation: 'compact',
      maximumFractionDigits: 1,
    });

    const svgNamespace = 'http://www.w3.org/2000/svg';

    function createSvgElement<K extends keyof SVGElementTagNameMap>(
      name: K,
      attributes: Record<string, string>,
    ): SVGElementTagNameMap[K] {
      const element = document.createElementNS(svgNamespace, name);

      Object.entries(attributes).forEach(([attribute, value]) => {
        element.setAttribute(attribute, value);
      });

      return element;
    }

    function renderDripChart({
      initialInvestment,
      annualDividendYield,
      annualSharePriceAppreciation,
      annualDividendGrowthRate,
      monthlyContribution,
      years,
    }: {
      initialInvestment: number;
      annualDividendYield: number;
      annualSharePriceAppreciation: number;
      annualDividendGrowthRate: number;
      monthlyContribution: number;
      years: number;
    }) {
      if (!chart) return;

      const wholeYears = Math.floor(years);
      const plottedYears = Array.from(
        { length: wholeYears + 1 },
        (_, year) => year,
      );

      if (plottedYears.at(-1) !== years) {
        plottedYears.push(years);
      }

      const points = plottedYears.map((year) => {
        if (year === 0) {
          return {
            year,
            portfolioValue: initialInvestment,
            totalDividends: 0,
          };
        }

        const result = calculateDrip({
          initialInvestment,
          annualDividendYieldPercent: annualDividendYield,
          annualSharePriceAppreciationPercent:
            annualSharePriceAppreciation,
          annualDividendGrowthRatePercent: annualDividendGrowthRate,
          monthlyContribution,
          years: year,
        });

        return {
          year,
          portfolioValue: result.finalPortfolioValue,
          totalDividends: result.totalDividendsEarned,
        };
      });
      const finalPoint = points.at(-1);
      const width = 720;
      const height = 400;
      const margin = { top: 68, right: 28, bottom: 66, left: 100 };
      const plotWidth = width - margin.left - margin.right;
      const plotHeight = height - margin.top - margin.bottom;
      const maximumValue = Math.max(
        ...points.flatMap((point) => [
          point.portfolioValue,
          point.totalDividends,
        ]),
        1,
      );
      const xPosition = (year: number) =>
        margin.left + (year / years) * plotWidth;
      const yPosition = (value: number) =>
        margin.top +
        plotHeight -
        (value / maximumValue) * plotHeight;
      const svg = createSvgElement('svg', {
        viewBox: `0 0 ${width} ${height}`,
        'aria-hidden': 'true',
        focusable: 'false',
      });

      for (let index = 0; index <= 4; index += 1) {
        const ratio = index / 4;
        const y = margin.top + plotHeight - ratio * plotHeight;
        const value = maximumValue * ratio;

        svg.append(
          createSvgElement('line', {
            x1: String(margin.left),
            y1: String(y),
            x2: String(width - margin.right),
            y2: String(y),
            stroke: 'var(--border-subtle)',
            'stroke-width': '1',
          }),
        );

        const label = createSvgElement('text', {
          x: String(margin.left - 10),
          y: String(y + 4),
          fill: 'var(--muted-text-color)',
          'font-size': '14',
          'text-anchor': 'end',
        });
        label.textContent = compactCurrency.format(value);
        svg.append(label);
      }

      const xTickCount = Math.min(6, Math.max(1, Math.ceil(years)));
      for (let index = 0; index <= xTickCount; index += 1) {
        const year = (years * index) / xTickCount;
        const label = createSvgElement('text', {
          x: String(xPosition(year)),
          y: String(height - 22),
          fill: 'var(--muted-text-color)',
          'font-size': '14',
          'text-anchor': 'middle',
        });
        label.textContent = Number.isInteger(year)
          ? String(year)
          : year.toFixed(1);
        svg.append(label);
      }

      const xAxisLabel = createSvgElement('text', {
        x: String(margin.left + plotWidth / 2),
        y: String(height - 4),
        fill: 'var(--muted-text-color)',
        'font-size': '15',
        'font-weight': '600',
        'text-anchor': 'middle',
      });
      xAxisLabel.textContent = 'Years';
      svg.append(xAxisLabel);

      const yAxisLabel = createSvgElement('text', {
        x: '22',
        y: String(margin.top + plotHeight / 2),
        fill: 'var(--muted-text-color)',
        'font-size': '15',
        'font-weight': '600',
        'text-anchor': 'middle',
        transform: `rotate(-90 22 ${margin.top + plotHeight / 2})`,
      });
      yAxisLabel.textContent = 'Portfolio value';
      svg.append(yAxisLabel);

      const legendItems = [
        {
          label: 'Portfolio value',
          color: 'var(--link-color)',
          x: margin.left,
        },
        {
          label: 'Total dividends earned',
          color: 'var(--warning-text)',
          x: margin.left + 170,
        },
      ];

      legendItems.forEach((item) => {
        svg.append(
          createSvgElement('line', {
            x1: String(item.x),
            y1: '24',
            x2: String(item.x + 24),
            y2: '24',
            stroke: item.color,
            'stroke-width': '4',
            'stroke-linecap': 'round',
          }),
        );
        const label = createSvgElement('text', {
          x: String(item.x + 32),
          y: '28',
          fill: 'var(--text-color)',
          'font-size': '14',
          'font-weight': '600',
        });
        label.textContent = item.label;
        svg.append(label);
      });

      const createLinePath = (
        key: 'portfolioValue' | 'totalDividends',
      ) =>
        points
          .map(
            (point, index) =>
              `${index === 0 ? 'M' : 'L'} ${xPosition(point.year)} ${yPosition(point[key])}`,
          )
          .join(' ');

      svg.append(
        createSvgElement('path', {
          d: createLinePath('portfolioValue'),
          fill: 'none',
          stroke: 'var(--link-color)',
          'stroke-linecap': 'round',
          'stroke-linejoin': 'round',
          'stroke-width': '4',
        }),
        createSvgElement('path', {
          d: createLinePath('totalDividends'),
          fill: 'none',
          stroke: 'var(--warning-text)',
          'stroke-linecap': 'round',
          'stroke-linejoin': 'round',
          'stroke-width': '4',
        }),
      );

      chart.replaceChildren(svg);
      chart.setAttribute(
        'aria-label',
        `Dividend reinvestment projection over ${years} years. The estimated final portfolio value is ${currency.format(finalPoint?.portfolioValue ?? initialInvestment)}, including ${currency.format(finalPoint?.totalDividends ?? 0)} in cumulative dividends earned and reinvested.`,
      );
    }

    function calculate() {
      if (
        !form ||
        !error ||
        !finalPortfolioValueResult ||
        !totalDividendsEarnedResult ||
        !totalContributionsResult ||
        !estimatedAnnualDividendIncomeResult
      ) {
        return false;
      }

      const data = new FormData(form);
      const initialInvestment = parseCalculatorNumber(
        data.get('initialInvestment'),
      );
      const annualDividendYield = parseCalculatorNumber(
        data.get('annualDividendYield'),
      );
      const annualSharePriceAppreciation = parseCalculatorNumber(
        data.get('annualSharePriceAppreciation'),
      );
      const annualDividendGrowthRate = parseCalculatorNumber(
        data.get('annualDividendGrowthRate'),
      );
      const monthlyContribution = parseCalculatorNumber(
        data.get('monthlyContribution'),
      );
      const years = parseCalculatorNumber(data.get('years'));
      const nonNegativeValues = [
        initialInvestment,
        annualDividendYield,
        annualSharePriceAppreciation,
        annualDividendGrowthRate,
        monthlyContribution,
      ];

      if (
        nonNegativeValues.some(
          (value) => !Number.isFinite(value) || value < 0,
        ) ||
        !Number.isFinite(years) ||
        years <= 0
      ) {
        error.textContent =
          'Investment, contribution, and percentage values cannot be negative. Number of years must be greater than 0.';
        error.hidden = false;
        return false;
      }

      error.hidden = true;

      const result = calculateDrip({
        initialInvestment,
        annualDividendYieldPercent: annualDividendYield,
        annualSharePriceAppreciationPercent: annualSharePriceAppreciation,
        annualDividendGrowthRatePercent: annualDividendGrowthRate,
        monthlyContribution,
        years,
      });

      finalPortfolioValueResult.textContent = currency.format(
        result.finalPortfolioValue,
      );
      totalDividendsEarnedResult.textContent = currency.format(
        result.totalDividendsEarned,
      );
      totalContributionsResult.textContent = currency.format(
        result.totalContributions,
      );
      estimatedAnnualDividendIncomeResult.textContent = currency.format(
        result.estimatedAnnualDividendIncome,
      );

      renderDripChart({
        initialInvestment,
        annualDividendYield,
        annualSharePriceAppreciation,
        annualDividendGrowthRate,
        monthlyContribution,
        years,
      });
      return true;
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      trackSuccessfulCalculation('drip', calculate);
    });

    calculate();
  </script>
</CalculatorPage>
