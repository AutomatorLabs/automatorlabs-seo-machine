---
import Layout from '../../../../layouts/Layout.astro';
import {
  EXPECTED_DRIP_SEO_PAGE_COUNT,
  dripSeoRecords,
} from '../../../../data/programmatic-seo/drip';
import { createProgrammaticExampleGroups } from '../../../../lib/programmatic-seo/examples';
import { auditDripSeoRecords } from '../../../../lib/programmatic-seo/drip';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../../../lib/programmatic-seo/schema';

const audit = auditDripSeoRecords(
  dripSeoRecords,
  EXPECTED_DRIP_SEO_PAGE_COUNT,
);
const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Calculators', url: '/calculators/' },
      {
        name: 'DRIP Calculator',
        url: '/calculators/drip-calculator/',
      },
      {
        name: 'Examples',
        url: '/calculators/drip/examples/',
      },
    ],
    site,
  ),
);
const currency = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});
const groups = createProgrammaticExampleGroups(dripSeoRecords, [
  {
    id: 'stock',
    title: 'Stock DRIP Examples',
    description:
      'Individual-stock dividend reinvestment scenarios across different yields, share prices, contributions, and time horizons.',
    matches: (record) => record.intent === 'stock-drip',
  },
  {
    id: 'etf',
    title: 'ETF DRIP Examples',
    description:
      'Fund-based DRIP scenarios that connect dividend yield, contributions, and long-term portfolio growth.',
    matches: (record) => record.intent === 'etf-drip',
  },
  {
    id: 'portfolio-growth',
    title: 'Portfolio Growth With Reinvested Dividends',
    description:
      'Account-level DRIP examples for different starting balances, monthly contributions, and compounding assumptions.',
    matches: (record) => record.intent === 'portfolio-growth-drip',
  },
  {
    id: 'snowball',
    title: 'Dividend Snowball Scenarios',
    description:
      'Worked examples that show how reinvested dividends and ongoing contributions can build momentum over time.',
    matches: (record) => record.intent === 'dividend-snowball-drip',
  },
  {
    id: 'retirement',
    title: 'Retirement DRIP Examples',
    description:
      'Retirement-oriented DRIP scenarios for larger portfolios, future income, and long-term reinvestment planning.',
    matches: (record) => record.intent === 'retirement-income-drip',
  },
]);
---

<Layout
  title="DRIP Examples | AutomatorLabs"
  description={`Browse ${audit.actualCount} DRIP examples covering dividend reinvestment plans, stock and ETF scenarios, dividend snowball setups, portfolio growth, and retirement income planning.`}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main id="main-content">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li>
          <a href="/calculators/drip-calculator/">
            DRIP Calculator
          </a>
        </li>
        <li aria-current="page">Examples</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Dividend reinvestment scenario library</p>
      <h1>DRIP Examples</h1>
      <p class="intro">
        Browse {audit.actualCount} worked examples covering dividend
        reinvestment plans, reinvesting dividends into more shares, dividend
        snowball scenarios, portfolio growth with reinvested dividends,
        stock and ETF setups, and retirement-oriented DRIP planning.
      </p>
      <a
        class="primary-link"
        href="/calculators/drip-calculator/"
      >
        Model your own DRIP scenario
      </a>
      <a class="secondary-link" href="/examples/">
        Browse all financial examples
      </a>
    </header>

    <section
      class="example-search"
      aria-label="Search DRIP examples"
    >
      <label for="drip-example-search">
        Search DRIP examples
      </label>
      <div class="search-row">
        <input
          id="drip-example-search"
          type="search"
          placeholder="Try ETF, snowball, retirement, $50,000, or 20 years"
          autocomplete="off"
          aria-controls="drip-example-groups"
          aria-describedby="drip-example-count"
        />
        <button
          id="clear-drip-example-search"
          type="button"
          hidden
        >
          Clear search
        </button>
      </div>
      <p id="drip-example-count" aria-live="polite">
        Showing {audit.actualCount} examples
      </p>
    </section>

    <div
      id="drip-example-groups"
      class="example-groups"
    >
      {groups.map((group) => (
        <section
          class="example-group"
          aria-labelledby={`${group.id}-heading`}
          data-drip-example-group
        >
          <header>
            <div>
              <h2 id={`${group.id}-heading`}>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            <span>{group.records.length} examples</span>
          </header>

          <ul>
            {group.records.map((record) => (
              <li
                data-drip-example-card
                data-search-text={[
                  record.question,
                  record.slug,
                  record.intent,
                  record.scenarioLabel,
                  record.initialInvestment,
                  record.initialInvestment.toLocaleString('en-US'),
                  record.assumedSharePrice,
                  record.assumedSharePrice.toLocaleString('en-US'),
                  record.annualDividendYieldPercent,
                  `${record.annualDividendYieldPercent}%`,
                  record.monthlyContribution,
                  record.monthlyContribution.toLocaleString('en-US'),
                  record.years,
                  `${record.years} years`,
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <a href={`/calculators/drip/${record.slug}/`}>
                  <strong>{record.question}</strong>
                  <span>
                    {currency.format(record.initialInvestment)} start
                    {' · '}
                    {record.annualDividendYieldPercent}% yield
                    {' · '}
                    {currency.format(record.monthlyContribution)}/month
                    {' · '}
                    {record.years} years
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p
      id="no-drip-examples"
      class="no-results"
      role="status"
      hidden
    >
      No DRIP examples found. Try a strategy, share price, amount, or time horizon.
    </p>
  </main>
</Layout>

<script>
  const input = document.querySelector<HTMLInputElement>(
    '#drip-example-search',
  );
  const clearButton = document.querySelector<HTMLButtonElement>(
    '#clear-drip-example-search',
  );
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('[data-drip-example-card]'),
  );
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>('[data-drip-example-group]'),
  );
  const count = document.querySelector<HTMLElement>('#drip-example-count');
  const noResults = document.querySelector<HTMLElement>('#no-drip-examples');

  const updateResults = () => {
    const query = input?.value.trim().toLocaleLowerCase() ?? '';
    let visibleCount = 0;

    cards.forEach((card) => {
      const searchableText = card.dataset.searchText ?? '';
      const matches = query.length === 0 || searchableText.includes(query);
      card.hidden = !matches;

      if (matches) {
        visibleCount += 1;
      }
    });

    groups.forEach((group) => {
      const visibleCards = group.querySelectorAll(
        '[data-drip-example-card]:not([hidden])',
      );
      group.hidden = visibleCards.length === 0;
    });

    if (count) {
      count.textContent = `Showing ${visibleCount} example${
        visibleCount === 1 ? '' : 's'
      }`;
    }

    if (noResults) {
      noResults.hidden = visibleCount !== 0;
    }

    if (clearButton) {
      clearButton.hidden = query.length === 0;
    }
  };

  input?.addEventListener('input', updateResults);
  clearButton?.addEventListener('click', () => {
    if (!input) return;
    input.value = '';
    updateResults();
    input.focus();
  });
</script>

<style>
  main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li + li::before {
    content: '/';
    margin-right: 0.45rem;
    color: var(--border-strong);
  }

  .page-header {
    display: grid;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .eyebrow {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--link-color);
  }

  .page-header h1 {
    margin: 0;
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    line-height: 1.05;
  }

  .intro {
    margin: 0;
    max-width: 72ch;
    color: var(--muted-text-color);
    font-size: 1.05rem;
  }

  .primary-link,
  .secondary-link {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.8rem 1.2rem;
    font-weight: 700;
    text-decoration: none;
  }

  .primary-link {
    background: var(--link-color);
    color: white;
  }

  .secondary-link {
    border: 1px solid var(--border-strong);
    color: var(--text-color);
  }

  .example-search {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 2rem;
    padding: 1.25rem;
    border: 1px solid var(--border-subtle);
    border-radius: 1.25rem;
    background: var(--surface-muted);
  }

  .example-search label {
    font-weight: 700;
  }

  .search-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .search-row input {
    flex: 1 1 16rem;
    min-width: 0;
    border: 1px solid var(--border-strong);
    border-radius: 0.9rem;
    padding: 0.85rem 1rem;
    font: inherit;
    color: inherit;
    background: white;
  }

  .search-row button {
    border: 1px solid var(--border-strong);
    border-radius: 0.9rem;
    padding: 0.85rem 1rem;
    font: inherit;
    font-weight: 700;
    color: inherit;
    background: white;
    cursor: pointer;
  }

  .example-groups {
    display: grid;
    gap: 1.5rem;
  }

  .example-group {
    border: 1px solid var(--border-subtle);
    border-radius: 1.25rem;
    background: white;
    padding: 1.25rem;
  }

  .example-group header {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .example-group h2 {
    margin: 0 0 0.35rem;
    font-size: 1.3rem;
  }

  .example-group p {
    margin: 0;
    max-width: 64ch;
    color: var(--muted-text-color);
  }

  .example-group header span {
    color: var(--muted-text-color);
    font-weight: 700;
  }

  .example-group ul {
    display: grid;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .example-group a {
    display: grid;
    gap: 0.3rem;
    padding: 1rem;
    border: 1px solid var(--border-subtle);
    border-radius: 1rem;
    color: inherit;
    text-decoration: none;
  }

  .example-group a:hover {
    border-color: var(--link-color);
    box-shadow: 0 10px 24px color-mix(in srgb, var(--link-color) 12%, transparent);
  }

  .example-group strong {
    font-size: 1rem;
  }

  .example-group a span {
    color: var(--muted-text-color);
  }

  .no-results {
    margin-top: 1.5rem;
    color: var(--muted-text-color);
  }

  @media (max-width: 720px) {
    main {
      width: min(100% - 1rem, 1120px);
      padding: 3.5rem 0;
    }
  }
</style>
