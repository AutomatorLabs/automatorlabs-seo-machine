---
import CalculatorPage from '../../../components/CalculatorPage.astro';
import { etfFeeDragCalculator } from '../../../data/calculators';
import { contentItems } from '../../../data/content';
import { featuredEtfFeeDragSeoRecords } from '../../../data/programmatic-seo/etf-fee-drag';

const relatedItems = etfFeeDragCalculator.relatedIds.flatMap((id) => {
  const item = contentItems.find((contentItem) => contentItem.id === id);
  return item ? [{ title: item.title, url: item.url }] : [];
});
const exampleItems = [
  {
    title: 'Browse all 200 ETF fee drag examples',
    url: '/calculators/etf-fee-drag/examples/',
  },
  ...featuredEtfFeeDragSeoRecords.map((record) => ({
    title: record.question,
    url: `/calculators/etf-fee-drag/${record.slug}/`,
  })),
];
---

<CalculatorPage
  title={etfFeeDragCalculator.title}
  eyebrow={etfFeeDragCalculator.eyebrow}
  description={etfFeeDragCalculator.description}
  inputs={etfFeeDragCalculator.inputs}
  outputs={etfFeeDragCalculator.outputs}
  faq={etfFeeDragCalculator.faq}
  relatedItems={relatedItems}
  exampleItems={exampleItems}
>
  <script>
    import { trackSuccessfulCalculation } from '../../../lib/analytics';
    import { parseCalculatorNumber } from '../../../lib/input';
    import { calculateEtfFeeDrag } from '../../../lib/math';

    const form = document.querySelector<HTMLFormElement>('#calculator-form');
    const error = document.querySelector<HTMLElement>('#form-error');
    const etfAEndingBalanceResult = document.querySelector<HTMLElement>(
      '#etf-a-ending-balance-result',
    );
    const etfBEndingBalanceResult = document.querySelector<HTMLElement>(
      '#etf-b-ending-balance-result',
    );
    const differenceBetweenEtfsResult = document.querySelector<HTMLElement>(
      '#difference-between-etfs-result',
    );
    const higherCostEtfDragResult = document.querySelector<HTMLElement>(
      '#higher-cost-etf-drag-result',
    );

    const currency = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 2,
    });

    function calculate() {
      if (
        !form ||
        !error ||
        !etfAEndingBalanceResult ||
        !etfBEndingBalanceResult ||
        !differenceBetweenEtfsResult ||
        !higherCostEtfDragResult
      ) {
        return false;
      }

      const data = new FormData(form);
      const investmentAmount = parseCalculatorNumber(
        data.get('investmentAmount'),
      );
      const monthlyContribution = parseCalculatorNumber(
        data.get('monthlyContribution'),
      );
      const etfAExpenseRatio = parseCalculatorNumber(
        data.get('etfAExpenseRatio'),
      );
      const etfBExpenseRatio = parseCalculatorNumber(
        data.get('etfBExpenseRatio'),
      );
      const expectedReturn = parseCalculatorNumber(data.get('expectedReturn'));
      const years = parseCalculatorNumber(data.get('years'));
      const nonNegativeValues = [
        investmentAmount,
        monthlyContribution,
        etfAExpenseRatio,
        etfBExpenseRatio,
        expectedReturn,
      ];

      if (
        nonNegativeValues.some(
          (value) => !Number.isFinite(value) || value < 0,
        ) ||
        !Number.isFinite(years) ||
        years <= 0
      ) {
        error.textContent =
          'Investment amount, monthly contribution, expense ratios, and expected return cannot be negative. Number of years must be greater than 0.';
        error.hidden = false;
        return false;
      }

      error.hidden = true;

      const result = calculateEtfFeeDrag({
        investmentAmount,
        monthlyContribution,
        etfAExpenseRatioPercent: etfAExpenseRatio,
        etfBExpenseRatioPercent: etfBExpenseRatio,
        expectedAnnualReturnPercent: expectedReturn,
        years,
      });

      etfAEndingBalanceResult.textContent = currency.format(
        result.etfAEndingBalance,
      );
      etfBEndingBalanceResult.textContent = currency.format(
        result.etfBEndingBalance,
      );
      differenceBetweenEtfsResult.textContent = currency.format(
        result.differenceBetweenEtfs,
      );
      higherCostEtfDragResult.textContent = currency.format(
        result.higherCostEtfDrag,
      );
      return true;
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      trackSuccessfulCalculation('etf_fee_drag', calculate);
    });

    calculate();
  </script>
</CalculatorPage>
