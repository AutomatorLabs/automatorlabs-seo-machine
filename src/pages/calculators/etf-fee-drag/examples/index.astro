---
import Layout from '../../../../layouts/Layout.astro';
import {
  etfFeeDragSeoRecords,
  EXPECTED_ETF_FEE_DRAG_SEO_PAGE_COUNT,
} from '../../../../data/programmatic-seo/etf-fee-drag';
import { createProgrammaticExampleGroups } from '../../../../lib/programmatic-seo/examples';
import { auditEtfFeeDragSeoRecords } from '../../../../lib/programmatic-seo/etf-fee-drag';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../../../lib/programmatic-seo/schema';

const audit = auditEtfFeeDragSeoRecords(
  etfFeeDragSeoRecords,
  EXPECTED_ETF_FEE_DRAG_SEO_PAGE_COUNT,
);
const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Calculators', url: '/calculators/' },
      {
        name: 'ETF Fee Drag Calculator',
        url: '/calculators/etf-fee-drag-calculator/',
      },
      { name: 'Examples', url: '/calculators/etf-fee-drag/examples/' },
    ],
    site,
  ),
);

const groups = createProgrammaticExampleGroups(etfFeeDragSeoRecords, [
  {
    id: 'low-cost',
    title: 'Low-Cost ETF Fee Drag Examples',
    description:
      'Examples focused on small expense-ratio gaps between low-cost ETFs and broad-market funds.',
    matches: (record) => record.intent === 'low-cost-etf',
  },
  {
    id: 'index-fund',
    title: 'Index Fund ETF Comparisons',
    description:
      'Examples comparing broad index-style ETF fee assumptions across longer holding periods.',
    matches: (record) => record.intent === 'index-fund-comparison',
  },
  {
    id: 'retirement',
    title: 'Retirement ETF Fee Drag Examples',
    description:
      'Examples for larger retirement balances where ETF fee drag compounds over decades.',
    matches: (record) => record.intent === 'retirement-etf',
  },
  {
    id: 'taxable',
    title: 'Taxable ETF Fee Drag Examples',
    description:
      'Examples framed around taxable brokerage ETF choices while isolating fund-expense drag only.',
    matches: (record) => record.intent === 'taxable-etf',
  },
  {
    id: 'high-fee',
    title: 'High-Fee ETF Comparison Examples',
    description:
      'Examples showing how wider ETF expense-ratio gaps can create noticeably larger long-term differences.',
    matches: (record) => record.intent === 'high-fee-etf',
  },
]);
---

<Layout
  title="ETF Fee Drag Examples | AutomatorLabs"
  description={`Browse ${audit.actualCount} ETF fee drag examples across low-cost ETFs, index fund comparisons, retirement portfolios, taxable accounts, and higher-fee fund scenarios.`}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main id="main-content">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li>
          <a href="/calculators/etf-fee-drag-calculator/">
            ETF Fee Drag Calculator
          </a>
        </li>
        <li aria-current="page">Examples</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">ETF comparison scenario library</p>
      <h1>ETF Fee Drag Examples</h1>
      <p class="intro">
        Browse {audit.actualCount} worked examples comparing two ETF expense
        ratios across low-cost index funds, retirement balances, taxable
        accounts, and longer-term fee drag scenarios.
      </p>
      <a class="primary-link" href="/calculators/etf-fee-drag-calculator/">
        Compare your own ETF fee gap
      </a>
      <a class="secondary-link" href="/examples/">
        Browse all financial examples
      </a>
    </header>

    <section class="example-search" aria-label="Search ETF fee drag examples">
      <label for="etf-fee-drag-example-search">
        Search ETF fee drag examples
      </label>
      <div class="search-row">
        <input
          id="etf-fee-drag-example-search"
          type="search"
          placeholder="Try retirement, taxable, 0.03%, 0.20%, or $100,000"
          autocomplete="off"
          aria-controls="etf-fee-drag-example-groups"
          aria-describedby="etf-fee-drag-example-count"
        />
        <button id="clear-etf-fee-drag-example-search" type="button" hidden>
          Clear search
        </button>
      </div>
      <p id="etf-fee-drag-example-count" aria-live="polite">
        Showing {audit.actualCount} examples
      </p>
    </section>

    <div id="etf-fee-drag-example-groups" class="example-groups">
      {groups.map((group) => (
        <section
          class="example-group"
          aria-labelledby={`${group.id}-heading`}
          data-etf-fee-drag-example-group
        >
          <header>
            <div>
              <h2 id={`${group.id}-heading`}>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            <span>{group.records.length} examples</span>
          </header>

          <ul>
            {group.records.map((record) => (
              <li
                data-etf-fee-drag-example-card
                data-search-text={[
                  record.question,
                  record.slug,
                  record.intent,
                  record.scenarioLabel,
                  record.investmentAmount,
                  record.monthlyContribution,
                  `${record.etfAExpenseRatioPercent}%`,
                  `${record.etfBExpenseRatioPercent}%`,
                  `${record.years} years`,
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <a href={`/calculators/etf-fee-drag/${record.slug}/`}>
                  <strong>{record.question}</strong>
                  <span>
                    ${record.investmentAmount.toLocaleString('en-US')} start
                    {' · '}
                    ${record.monthlyContribution.toLocaleString('en-US')} monthly
                    {' · '}
                    {record.etfAExpenseRatioPercent}% vs {record.etfBExpenseRatioPercent}%
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p id="no-etf-fee-drag-examples" class="no-results" role="status" hidden>
      No ETF fee drag examples found. Try a fee level, account type, or balance.
    </p>
  </main>
</Layout>

<script>
  const input = document.querySelector<HTMLInputElement>(
    '#etf-fee-drag-example-search',
  );
  const clearButton = document.querySelector<HTMLButtonElement>(
    '#clear-etf-fee-drag-example-search',
  );
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('[data-etf-fee-drag-example-card]'),
  );
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>('[data-etf-fee-drag-example-group]'),
  );
  const count = document.querySelector<HTMLElement>(
    '#etf-fee-drag-example-count',
  );
  const noResults = document.querySelector<HTMLElement>(
    '#no-etf-fee-drag-examples',
  );

  function updateSearch() {
    const query = input?.value.trim().toLocaleLowerCase() ?? '';
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches =
        query.length === 0 ||
        (card.dataset.searchText ?? '').includes(query);
      card.hidden = !matches;
      if (matches) visibleCount += 1;
    });

    groups.forEach((group) => {
      const hasVisibleCard = Array.from(
        group.querySelectorAll<HTMLElement>('[data-etf-fee-drag-example-card]'),
      ).some((card) => !card.hidden);
      group.hidden = !hasVisibleCard;
    });

    if (count) {
      count.textContent = `Showing ${visibleCount} example${visibleCount === 1 ? '' : 's'}`;
    }
    if (noResults) noResults.hidden = visibleCount !== 0;
    if (clearButton) clearButton.hidden = query.length === 0;
  }

  input?.addEventListener('input', updateSearch);
  clearButton?.addEventListener('click', () => {
    if (!input) return;
    input.value = '';
    updateSearch();
    input.focus();
  });
</script>

<style>
  @import '../../../../styles/programmatic-examples.css';
</style>
