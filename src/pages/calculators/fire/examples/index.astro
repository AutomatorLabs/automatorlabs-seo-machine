---
import Layout from '../../../../layouts/Layout.astro';
import {
  EXPECTED_FIRE_SEO_PAGE_COUNT,
  fireSeoRecords,
} from '../../../../data/programmatic-seo/fire';
import { auditFireSeoRecords } from '../../../../lib/programmatic-seo/fire';
import { createProgrammaticExampleGroups } from '../../../../lib/programmatic-seo/examples';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../../../lib/programmatic-seo/schema';

const audit = auditFireSeoRecords(
  fireSeoRecords,
  EXPECTED_FIRE_SEO_PAGE_COUNT,
);
const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Calculators', url: '/calculators/' },
      { name: 'FIRE Calculator', url: '/calculators/fire-calculator/' },
      { name: 'FIRE Examples', url: '/calculators/fire/examples/' },
    ],
    site,
  ),
);
const currency = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});
const groups = createProgrammaticExampleGroups(fireSeoRecords, [
  {
    id: 'lean-spending-target',
    title: 'Lean FIRE Spending Targets',
    description:
      'Portfolio targets for lower annual spending levels, up to $50,000 per year.',
    matches: (record) => record.intent === 'lean-spending-target',
  },
  {
    id: 'regular-spending-target',
    title: 'Regular FIRE Spending Targets',
    description:
      'Portfolio targets for a common middle range of annual spending, $50,000 to $125,000 per year.',
    matches: (record) => record.intent === 'regular-spending-target',
  },
  {
    id: 'fat-spending-target',
    title: 'Fat FIRE Spending Targets',
    description:
      'Portfolio targets for higher annual spending levels, $125,000 per year and up.',
    matches: (record) => record.intent === 'fat-spending-target',
  },
  {
    id: 'underfunded-portfolio-check',
    title: 'Underfunded Portfolio Checks',
    description:
      'Scenarios where the portfolio falls short of the FIRE target at a 4% withdrawal rate.',
    matches: (record) => record.intent === 'underfunded-portfolio-check',
  },
  {
    id: 'funded-portfolio-check',
    title: 'Funded Portfolio Checks',
    description:
      'Scenarios where the portfolio meets or exceeds the FIRE target at a 4% withdrawal rate.',
    matches: (record) => record.intent === 'funded-portfolio-check',
  },
]);
---

<Layout
  title="FIRE Number Examples | AutomatorLabs"
  description={`Browse ${audit.actualCount} FIRE examples covering annual spending targets and portfolio-versus-spending checks, with withdrawal-rate comparisons and planning assumptions.`}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main id="main-content">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li><a href="/calculators/fire-calculator/">FIRE Calculator</a></li>
        <li aria-current="page">FIRE Examples</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Financial independence examples</p>
      <h1>FIRE Number Examples</h1>
      <p class="intro">
        Browse {audit.actualCount} controlled FIRE planning examples. The
        collection covers annual spending targets and portfolio checks using
        an explicit withdrawal-rate assumption.
      </p>
      <a class="primary-link" href="/calculators/fire-calculator/">
        Calculate your FIRE number
      </a>
      <a class="secondary-link" href="/examples/">
        Browse all financial examples
      </a>
    </header>

    <section class="example-search" aria-label="Search FIRE examples">
      <label for="fire-example-search">Search FIRE examples</label>
      <div class="search-row">
        <input
          id="fire-example-search"
          type="search"
          placeholder="Try 40000, 1,000,000, or spending"
          autocomplete="off"
          aria-controls="fire-example-groups"
          aria-describedby="fire-example-count"
        />
        <button id="clear-fire-example-search" type="button" hidden>
          Clear search
        </button>
      </div>
      <p id="fire-example-count" aria-live="polite">
        Showing {audit.actualCount} examples
      </p>
    </section>

    <div id="fire-example-groups" class="example-groups">
      {groups.map((group) => (
        <section
          class="example-group"
          aria-labelledby={`${group.id}-heading`}
          data-fire-example-group
        >
          <header>
            <div>
              <h2 id={`${group.id}-heading`}>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            <span>{group.records.length} examples</span>
          </header>
          <ul>
            {group.records.map((record) => (
              <li
                data-fire-example-card
                data-search-text={[
                  record.question,
                  record.slug,
                  record.intent,
                  record.annualSpending,
                  record.annualSpending.toLocaleString('en-US'),
                  record.portfolioValue ?? '',
                  record.portfolioValue?.toLocaleString('en-US') ?? '',
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <a href={`/calculators/fire/${record.slug}/`}>
                  <strong>{record.question}</strong>
                  <span>
                    {currency.format(record.annualSpending)} annual spending
                    {record.portfolioValue
                      ? ` · ${currency.format(record.portfolioValue)} portfolio`
                      : ' · FIRE target estimate'}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p id="no-fire-examples" class="no-results" role="status" hidden>
      No FIRE examples found. Try a spending or portfolio amount.
    </p>
  </main>
</Layout>

<script>
  const input = document.querySelector<HTMLInputElement>(
    '#fire-example-search',
  );
  const clearButton = document.querySelector<HTMLButtonElement>(
    '#clear-fire-example-search',
  );
  const count = document.querySelector<HTMLElement>('#fire-example-count');
  const noResults = document.querySelector<HTMLElement>('#no-fire-examples');
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('[data-fire-example-card]'),
  );
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>('[data-fire-example-group]'),
  );

  function updateExamples() {
    if (!input || !count || !noResults) return;

    const query = input.value.trim().toLocaleLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches =
        query === '' || (card.dataset.searchText ?? '').includes(query);
      card.hidden = !matches;
      if (matches) visibleCount += 1;
    });

    groups.forEach((group) => {
      group.hidden = !group.querySelector(
        '[data-fire-example-card]:not([hidden])',
      );
    });

    count.textContent = `Showing ${visibleCount} ${visibleCount === 1 ? 'example' : 'examples'}`;
    noResults.hidden = visibleCount !== 0;
    if (clearButton) clearButton.hidden = query === '';
  }

  input?.addEventListener('input', updateExamples);
  clearButton?.addEventListener('click', () => {
    if (!input) return;
    input.value = '';
    updateExamples();
    input.focus();
  });
</script>

<style>
  main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .breadcrumbs li + li::before {
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a {
    color: var(--link-color);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  .page-header {
    max-width: 850px;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: var(--link-color);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    letter-spacing: -0.045em;
    line-height: 1.05;
  }

  .intro {
    margin: 1rem 0 1.25rem;
    color: var(--muted-text-color);
    font-size: 1.12rem;
    line-height: 1.72;
  }

  .primary-link {
    display: inline-block;
    border-radius: 10px;
    background: var(--button-background);
    color: var(--button-text);
    font-weight: 750;
    padding: 0.8rem 1rem;
    text-decoration: none;
  }

  .secondary-link {
    display: inline-block;
    margin-left: 0.75rem;
    color: var(--link-color);
    font-weight: 750;
  }

  .example-search {
    margin: 3rem 0;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--card-background);
    padding: 1.25rem;
  }

  .example-search label {
    display: block;
    margin-bottom: 0.6rem;
    color: var(--heading-color);
    font-weight: 750;
  }

  .search-row {
    display: flex;
    gap: 0.7rem;
  }

  .search-row input {
    width: 100%;
    border: 1px solid var(--input-border);
    border-radius: 10px;
    background: var(--input-background);
    color: var(--input-text);
    font: inherit;
    padding: 0.8rem 0.9rem;
  }

  .search-row input:focus {
    border-color: var(--link-color);
    box-shadow: 0 0 0 3px var(--focus-ring);
    outline: none;
  }

  .search-row button {
    border: 1px solid var(--input-border);
    border-radius: 10px;
    background: var(--subtle-background);
    color: var(--text-color);
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    padding: 0.8rem 1rem;
    white-space: nowrap;
  }

  #fire-example-count {
    margin: 0.75rem 0 0;
    color: var(--muted-text-color);
    font-size: 0.92rem;
  }

  .example-groups {
    display: grid;
    gap: 2.5rem;
  }

  .example-group > header {
    display: flex;
    gap: 1rem;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .example-group h2 {
    margin: 0;
    color: var(--heading-color);
    font-size: 1.65rem;
  }

  .example-group header p {
    margin: 0.35rem 0 0;
    color: var(--muted-text-color);
  }

  .example-group header span {
    color: var(--muted-text-color);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .example-group ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .example-group a {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--card-background);
    color: var(--link-color);
    padding: 1rem;
    text-decoration: none;
  }

  .example-group a:hover {
    border-color: var(--link-color);
    background: var(--subtle-background);
  }

  .example-group a span {
    margin-top: 0.4rem;
    color: var(--muted-text-color);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .no-results {
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--subtle-background);
    padding: 1rem;
  }

  @media (max-width: 720px) {
    main {
      padding: 3rem 0;
    }

    .search-row,
    .example-group > header {
      align-items: stretch;
      flex-direction: column;
    }

    .example-group ul {
      grid-template-columns: 1fr;
    }

    .secondary-link {
      display: block;
      margin: 1rem 0 0;
    }
  }
</style>
