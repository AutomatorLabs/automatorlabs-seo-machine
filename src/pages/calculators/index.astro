---
import { contentItems } from '../../data/content';
import { calculatorCategories } from '../../data/calculator-categories';
import NewsletterCta from '../../components/NewsletterCta.astro';
import Layout from '../../layouts/Layout.astro';

const calculators = contentItems
  .filter((item) => item.category === 'calculator')
  .sort((a, b) => a.priority - b.priority);

const calculatorGroups = calculatorCategories.map((group) => {
  const groupIds = new Set(group.ids);

  return {
    ...group,
    calculators: calculators.filter((item) => groupIds.has(item.id)),
  };
});

const categoryFilterLabels: Record<string, string> = {
  'fire-retirement': 'FIRE & Retirement',
  investing: 'Investing',
  'debt-loans': 'Debt & Loans',
  'home-mortgage': 'Home & Mortgage',
  'budgeting-savings': 'Budgeting & Savings',
  'college-tax-advantaged': 'College & Tax-Advantaged Accounts',
};

const categoryFilters = [
  { slug: 'all', label: 'All' },
  ...calculatorCategories.map((category) => ({
    slug: category.slug,
    label: categoryFilterLabels[category.slug],
  })),
];
---

<Layout
  title="Calculators | AutomatorLabs"
  description="Explore free financial and planning calculators from AutomatorLabs."
>
  <main>
    <p class="eyebrow">Calculators</p>
    <h1>Practical calculators for better decisions</h1>
    <p>
      Explore our growing collection of simple, useful calculators, or
      <a href="/examples/">browse worked financial examples</a>.
    </p>

    <section
      class="calculator-search"
      aria-label="Calculator search and filters"
    >
      <label id="calculator-search-label" for="calculator-search">
        Search calculators
      </label>
      <div class="search-row">
        <input
          id="calculator-search"
          type="search"
          placeholder="Search calculators..."
          autocomplete="off"
          aria-controls="calculator-groups"
          aria-describedby="calculator-count"
        />
        <button id="clear-calculator-search" type="button" hidden>
          Clear search
        </button>
      </div>

      <div class="category-filters" aria-label="Filter calculators by category">
        {categoryFilters.map((filter, index) => (
          <button
            type="button"
            data-category-filter={filter.slug}
            aria-pressed={index === 0 ? 'true' : 'false'}
          >
            {filter.label}
          </button>
        ))}
      </div>

      <p id="calculator-count" class="calculator-count" aria-live="polite">
        Showing {calculators.length} calculators
      </p>
    </section>

    <div id="calculator-groups" class="calculator-groups">
      {calculatorGroups.map((group) => (
        <section
          class="calculator-group"
          data-calculator-group
          data-category={group.slug}
        >
          <header class="group-header">
            <div>
              <h2>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            <a href={`/calculators/${group.slug}/`}>View category</a>
          </header>

          <ul class="calculator-list">
            {group.calculators.map((item) => (
              <li
                class:list={{ 'is-live': item.status === 'live' }}
                data-calculator-card
                data-category={group.slug}
                data-search-text={[
                  item.title,
                  item.description,
                  item.category,
                  item.slug,
                  item.primaryKeyword,
                  ...item.secondaryKeywords,
                  group.title,
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                {item.status === 'live' ? (
                  <a class="calculator-card" href={item.url}>
                    <span class="card-meta">
                      <span class="category-label">{group.title}</span>
                      <span class="status live">Live</span>
                    </span>
                    <span class="card-title">{item.title}</span>
                    <span class="card-description">{item.description}</span>
                    <span class="card-action" aria-hidden="true">
                      Open calculator <span>→</span>
                    </span>
                  </a>
                ) : (
                  <div class="calculator-card planned-card">
                    <span class="card-meta">
                      <span class="category-label">{group.title}</span>
                      <span class="status">Planned</span>
                    </span>
                    <h3 class="card-title">{item.title}</h3>
                    <p class="card-description">{item.description}</p>
                  </div>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p id="no-calculators-found" class="no-results" role="status" hidden>
      No calculators found. Try a different search.
    </p>

    <NewsletterCta compact />
  </main>
</Layout>

<script>
  const searchInput =
    document.querySelector<HTMLInputElement>('#calculator-search');
  const calculatorCards = Array.from(
    document.querySelectorAll<HTMLElement>('[data-calculator-card]'),
  );
  const calculatorGroups = Array.from(
    document.querySelectorAll<HTMLElement>('[data-calculator-group]'),
  );
  const calculatorCount =
    document.querySelector<HTMLElement>('#calculator-count');
  const noResults =
    document.querySelector<HTMLElement>('#no-calculators-found');
  const clearSearchButton = document.querySelector<HTMLButtonElement>(
    '#clear-calculator-search',
  );
  const categoryFilterButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[data-category-filter]'),
  );
  let activeCategory = 'all';

  function normalizeSearch(value: string): string {
    return value.trim().toLocaleLowerCase();
  }

  function updateCalculatorResults() {
    if (!searchInput || !calculatorCount || !noResults) {
      return;
    }

    const query = normalizeSearch(searchInput.value);
    let visibleCount = 0;

    calculatorCards.forEach((card) => {
      const searchText = card.dataset.searchText ?? '';
      const matchesSearch = query === '' || searchText.includes(query);
      const matchesCategory =
        activeCategory === 'all' ||
        card.dataset.category === activeCategory;
      const matches = matchesSearch && matchesCategory;

      card.hidden = !matches;
      if (matches) {
        visibleCount += 1;
      }
    });

    calculatorGroups.forEach((group) => {
      const hasVisibleCalculator = Array.from(
        group.querySelectorAll<HTMLElement>('[data-calculator-card]'),
      ).some((card) => !card.hidden);

      group.hidden = !hasVisibleCalculator;
    });

    calculatorCount.textContent = `Showing ${visibleCount} ${
      visibleCount === 1 ? 'calculator' : 'calculators'
    }`;
    noResults.hidden = visibleCount !== 0;
    if (clearSearchButton) {
      clearSearchButton.hidden = query === '';
    }
  }

  searchInput?.addEventListener('input', updateCalculatorResults);

  categoryFilterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      activeCategory = button.dataset.categoryFilter ?? 'all';
      categoryFilterButtons.forEach((candidate) => {
        candidate.setAttribute(
          'aria-pressed',
          String(candidate === button),
        );
      });
      updateCalculatorResults();
    });
  });

  clearSearchButton?.addEventListener('click', () => {
    if (!searchInput) return;

    searchInput.value = '';
    activeCategory = 'all';
    categoryFilterButtons.forEach((button) => {
      button.setAttribute(
        'aria-pressed',
        String(button.dataset.categoryFilter === 'all'),
      );
    });
    updateCalculatorResults();
    searchInput.focus();
  });
</script>

<style>
  main {
    width: min(1040px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 5rem 0;
  }

  .eyebrow {
    color: var(--link-color);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.25rem, 7vw, 3.75rem);
    letter-spacing: -0.04em;
    line-height: 1.08;
  }

  p {
    color: var(--muted-text-color);
  }

  .calculator-search {
    margin-top: 2rem;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--card-background);
    padding: clamp(1.25rem, 4vw, 1.75rem);
  }

  .calculator-search label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--text-color);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .search-row {
    display: flex;
    gap: 0.65rem;
  }

  .calculator-search input {
    width: 100%;
    border: 1px solid var(--input-border);
    border-radius: 10px;
    background: var(--input-background);
    color: var(--input-text);
    font: inherit;
    padding: 0.85rem 1rem;
  }

  .calculator-search input::placeholder {
    color: var(--muted-text-color);
    opacity: 1;
  }

  .calculator-search input:focus {
    border-color: var(--link-color);
    box-shadow: 0 0 0 3px var(--focus-ring);
    outline: none;
  }

  #clear-calculator-search {
    flex: 0 0 auto;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: var(--form-background);
    color: var(--link-color);
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    padding: 0.75rem 0.9rem;
  }

  #clear-calculator-search:hover {
    border-color: var(--link-color);
    background: var(--subtle-background);
  }

  #clear-calculator-search:focus-visible,
  .category-filters button:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: 2px;
  }

  .category-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .category-filters button {
    border: 1px solid var(--border-color);
    border-radius: 999px;
    background: var(--form-background);
    color: var(--text-color);
    cursor: pointer;
    font: inherit;
    font-size: 0.86rem;
    font-weight: 700;
    padding: 0.52rem 0.78rem;
  }

  .category-filters button:hover {
    border-color: var(--link-color);
  }

  .category-filters button[aria-pressed='true'] {
    border-color: var(--button-background);
    background: var(--button-background);
    color: var(--button-text);
  }

  .calculator-count {
    margin: 1rem 0 0;
    font-size: 0.88rem;
  }

  .calculator-groups {
    display: grid;
    gap: 2.75rem;
    margin-top: 2.25rem;
  }

  .calculator-group[hidden] {
    display: none;
  }

  .group-header {
    display: flex;
    gap: 1rem;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .group-header h2,
  .group-header p {
    margin: 0;
  }

  .group-header h2 {
    font-size: 1.45rem;
    letter-spacing: -0.02em;
  }

  .group-header p {
    margin-top: 0.3rem;
    font-size: 0.94rem;
  }

  .group-header a {
    flex: 0 0 auto;
    color: var(--link-color);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .calculator-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .calculator-list li {
    display: block;
    min-width: 0;
    border: 1px solid var(--border-color);
    border-radius: 14px;
    background: var(--card-background);
    box-shadow: 0 8px 24px transparent;
    overflow: hidden;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .calculator-list li.is-live:hover {
    border-color: var(--link-color);
    box-shadow: 0 12px 30px var(--shadow-color);
    transform: translateY(-2px);
  }

  .calculator-list li[hidden] {
    display: none;
  }

  .calculator-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    color: var(--text-color);
    padding: 1.2rem;
    text-decoration: none;
  }

  .calculator-card:focus-visible {
    border-radius: 13px;
    box-shadow: inset 0 0 0 3px var(--focus-ring);
    outline: none;
  }

  .planned-card {
    cursor: default;
  }

  .card-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.85rem;
  }

  .category-label {
    color: var(--muted-text-color);
    font-size: 0.7rem;
    font-weight: 750;
    letter-spacing: 0.045em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .card-title {
    margin: 0;
    color: var(--text-color);
    font-size: 1.08rem;
    font-weight: 750;
    line-height: 1.3;
  }

  .card-description {
    margin: 0.5rem 0 0;
    color: var(--muted-text-color);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .card-action {
    display: flex;
    gap: 0.35rem;
    align-items: center;
    margin-top: auto;
    padding-top: 1.15rem;
    color: var(--link-color);
    font-size: 0.85rem;
    font-weight: 750;
  }

  .card-action span {
    transition: transform 160ms ease;
  }

  .calculator-card:hover .card-action span {
    transform: translateX(3px);
  }

  .status {
    flex: 0 0 auto;
    border-radius: 999px;
    background: var(--subtle-background);
    color: var(--subtle-text);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    text-transform: uppercase;
  }

  .status.live {
    background: var(--success-background);
    color: var(--success-text);
  }

  .no-results {
    border: 1px dashed var(--border-color);
    border-radius: 12px;
    margin-top: 1.25rem;
    background: var(--card-background);
    color: var(--muted-text-color);
    padding: 1.25rem;
    text-align: center;
  }

  .no-results[hidden] {
    display: none;
  }

  @media (max-width: 640px) {
    main {
      padding: 3.25rem 0;
    }

    .calculator-list {
      grid-template-columns: 1fr;
    }

    .group-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .search-row {
      flex-direction: column;
    }

    #clear-calculator-search {
      width: 100%;
    }
  }
</style>
