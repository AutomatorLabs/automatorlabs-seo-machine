---
import { contentItems } from '../../data/content';
import Layout from '../../layouts/Layout.astro';

const calculators = contentItems
  .filter((item) => item.category === 'calculator')
  .sort((a, b) => a.priority - b.priority);
---

<Layout
  title="Calculators | AutomatorLabs"
  description="Explore free financial and planning calculators from AutomatorLabs."
>
  <main>
    <p class="eyebrow">Calculators</p>
    <h1>Practical calculators for better decisions</h1>
    <p>Explore our growing collection of simple, useful calculators.</p>

    <ul class="calculator-list">
      {calculators.map((item) => (
        <li>
          <div>
            {item.status === 'live' ? (
              <a href={item.url}>{item.title}</a>
            ) : (
              <h2>{item.title}</h2>
            )}
            <p>{item.description}</p>
          </div>
          <span class:list={['status', { live: item.status === 'live' }]}>
            {item.status === 'live' ? 'Live' : 'Planned'}
          </span>
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  main {
    width: min(760px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 5rem 0;
  }

  .eyebrow {
    color: #3158d3;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.25rem, 7vw, 3.75rem);
    letter-spacing: -0.04em;
    line-height: 1.08;
  }

  p {
    color: #586176;
  }

  .calculator-list {
    display: grid;
    gap: 0.75rem;
    margin-top: 2rem;
    padding: 0;
    list-style: none;
  }

  .calculator-list li {
    display: flex;
    border: 1px solid #e1e4ec;
    border-radius: 12px;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
  }

  .calculator-list h2,
  .calculator-list p {
    margin: 0;
  }

  .calculator-list h2,
  .calculator-list a {
    font-size: 1rem;
  }

  .calculator-list p {
    margin-top: 0.35rem;
    font-size: 0.92rem;
  }

  a {
    color: #3158d3;
    font-weight: 700;
  }

  .status {
    flex: 0 0 auto;
    border-radius: 999px;
    background: #eef1f7;
    color: #697386;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    text-transform: uppercase;
  }

  .status.live {
    background: #e8f7ed;
    color: #217a3c;
  }
</style>
