---
import { contentItems } from '../../data/content';
import Layout from '../../layouts/Layout.astro';

const calculators = contentItems
  .filter((item) => item.category === 'calculator')
  .sort((a, b) => a.priority - b.priority);

const calculatorGroups = [
  {
    title: 'FIRE & Retirement',
    description:
      'Plan financial independence, retirement timing, withdrawals, and sustainable income.',
    ids: [
      'fire-calculator',
      'coast-fire-calculator',
      'four-percent-rule-calculator',
      'retirement-withdrawal-calculator',
      'financial-independence-date-calculator',
      'lean-fire-calculator',
      'fat-fire-calculator',
      'barista-fire-calculator',
      'safe-withdrawal-rate-calculator',
      'years-to-retirement-calculator',
      'retirement-income-gap-calculator',
      'portfolio-withdrawal-sustainability-calculator',
      'retirement-tax-drag-calculator',
    ],
  },
  {
    title: 'Investing',
    description:
      'Explore growth, returns, inflation, dividends, fees, and investment strategies.',
    ids: [
      'compound-interest-calculator',
      'rule-of-72-calculator',
      'inflation-calculator',
      'investment-fee-calculator',
      'expense-ratio-calculator',
      'cagr-calculator',
      'etf-fee-drag-calculator',
      'dividend-yield-calculator',
      'dividend-growth-calculator',
      'drip-calculator',
      'lump-sum-vs-dca-calculator',
      'real-rate-of-return-calculator',
      'inflation-adjusted-return-calculator',
    ],
  },
  {
    title: 'Debt & Loans',
    description:
      'Estimate payments, payoff timelines, interest costs, and debt repayment strategies.',
    ids: [
      'loan-payment-calculator',
      'debt-payoff-calculator',
      'debt-snowball-calculator',
      'debt-avalanche-calculator',
      'credit-card-interest-calculator',
      'auto-loan-calculator',
      'student-loan-calculator',
      'student-loan-payoff-calculator',
    ],
  },
  {
    title: 'Home & Mortgage',
    description:
      'Compare housing choices, mortgage costs, home equity, affordability, and down payments.',
    ids: [
      'mortgage-payoff-calculator',
      'refinance-calculator',
      'heloc-calculator',
      'rent-vs-buy-calculator',
      'home-affordability-calculator',
      'down-payment-calculator',
      'mortgage-recast-calculator',
    ],
  },
  {
    title: 'Budgeting & Savings',
    description:
      'Build stronger cash flow, savings habits, emergency funds, and personal balance sheets.',
    ids: [
      'savings-rate-calculator',
      'net-worth-calculator',
      'emergency-fund-calculator',
      'savings-goal-calculator',
      'budget-calculator',
    ],
  },
  {
    title: 'College & Tax-Advantaged Accounts',
    description:
      'Plan education costs and compare retirement, health, and tax-advantaged accounts.',
    ids: [
      'roth-vs-traditional-ira-calculator',
      '401k-growth-calculator',
      'ira-growth-calculator',
      'taxable-vs-tax-advantaged-calculator',
      'hsa-growth-calculator',
      '529-college-savings-calculator',
      'college-cost-inflation-calculator',
    ],
  },
].map((group) => {
  const groupIds = new Set(group.ids);

  return {
    ...group,
    calculators: calculators.filter((item) => groupIds.has(item.id)),
  };
});
---

<Layout
  title="Calculators | AutomatorLabs"
  description="Explore free financial and planning calculators from AutomatorLabs."
>
  <main>
    <p class="eyebrow">Calculators</p>
    <h1>Practical calculators for better decisions</h1>
    <p>Explore our growing collection of simple, useful calculators.</p>

    <section class="calculator-search" aria-labelledby="calculator-search-label">
      <label id="calculator-search-label" for="calculator-search">
        Search calculators
      </label>
      <input
        id="calculator-search"
        type="search"
        placeholder="Try FIRE, debt, mortgage, dividend..."
        autocomplete="off"
        aria-controls="calculator-groups"
        aria-describedby="calculator-count"
      />
      <p id="calculator-count" class="calculator-count" aria-live="polite">
        Showing {calculators.length} calculators
      </p>
    </section>

    <div id="calculator-groups" class="calculator-groups">
      {calculatorGroups.map((group) => (
        <section class="calculator-group" data-calculator-group>
          <header class="group-header">
            <h2>{group.title}</h2>
            <p>{group.description}</p>
          </header>

          <ul class="calculator-list">
            {group.calculators.map((item) => (
              <li
                data-calculator-card
                data-search-text={[
                  item.title,
                  item.description,
                  item.category,
                  item.primaryKeyword,
                  ...item.secondaryKeywords,
                  group.title,
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <div>
                  {item.status === 'live' ? (
                    <a href={item.url}>{item.title}</a>
                  ) : (
                    <h3>{item.title}</h3>
                  )}
                  <p>{item.description}</p>
                </div>
                <span class:list={['status', { live: item.status === 'live' }]}>
                  {item.status === 'live' ? 'Live' : 'Planned'}
                </span>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p id="no-calculators-found" class="no-results" role="status" hidden>
      No calculators found.
    </p>
  </main>
</Layout>

<script>
  const searchInput =
    document.querySelector<HTMLInputElement>('#calculator-search');
  const calculatorCards = Array.from(
    document.querySelectorAll<HTMLElement>('[data-calculator-card]'),
  );
  const calculatorGroups = Array.from(
    document.querySelectorAll<HTMLElement>('[data-calculator-group]'),
  );
  const calculatorCount =
    document.querySelector<HTMLElement>('#calculator-count');
  const noResults =
    document.querySelector<HTMLElement>('#no-calculators-found');

  function normalizeSearch(value: string): string {
    return value.trim().toLocaleLowerCase();
  }

  function updateCalculatorResults() {
    if (!searchInput || !calculatorCount || !noResults) {
      return;
    }

    const query = normalizeSearch(searchInput.value);
    let visibleCount = 0;

    calculatorCards.forEach((card) => {
      const searchText = card.dataset.searchText ?? '';
      const matches = query === '' || searchText.includes(query);

      card.hidden = !matches;
      if (matches) {
        visibleCount += 1;
      }
    });

    calculatorGroups.forEach((group) => {
      const hasVisibleCalculator = Array.from(
        group.querySelectorAll<HTMLElement>('[data-calculator-card]'),
      ).some((card) => !card.hidden);

      group.hidden = !hasVisibleCalculator;
    });

    calculatorCount.textContent = `Showing ${visibleCount} ${
      visibleCount === 1 ? 'calculator' : 'calculators'
    }`;
    noResults.hidden = visibleCount !== 0;
  }

  searchInput?.addEventListener('input', updateCalculatorResults);
</script>

<style>
  main {
    width: min(760px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 5rem 0;
  }

  .eyebrow {
    color: var(--link-color);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.25rem, 7vw, 3.75rem);
    letter-spacing: -0.04em;
    line-height: 1.08;
  }

  p {
    color: var(--muted-text-color);
  }

  .calculator-search {
    margin-top: 2rem;
  }

  .calculator-search label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--text-color);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .calculator-search input {
    width: 100%;
    border: 1px solid var(--input-border);
    border-radius: 10px;
    background: var(--input-background);
    color: var(--input-text);
    font: inherit;
    padding: 0.85rem 1rem;
  }

  .calculator-search input::placeholder {
    color: var(--muted-text-color);
    opacity: 1;
  }

  .calculator-search input:focus {
    border-color: var(--link-color);
    box-shadow: 0 0 0 3px var(--focus-ring);
    outline: none;
  }

  .calculator-count {
    margin: 0.6rem 0 0;
    font-size: 0.88rem;
  }

  .calculator-groups {
    display: grid;
    gap: 2.75rem;
    margin-top: 2.25rem;
  }

  .calculator-group[hidden] {
    display: none;
  }

  .group-header {
    margin-bottom: 1rem;
  }

  .group-header h2,
  .group-header p {
    margin: 0;
  }

  .group-header h2 {
    font-size: 1.45rem;
    letter-spacing: -0.02em;
  }

  .group-header p {
    margin-top: 0.3rem;
    font-size: 0.94rem;
  }

  .calculator-list {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .calculator-list li {
    display: flex;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--card-background);
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
  }

  .calculator-list li[hidden] {
    display: none;
  }

  .calculator-list h3,
  .calculator-list p {
    margin: 0;
  }

  .calculator-list h3,
  .calculator-list a {
    font-size: 1rem;
  }

  .calculator-list p {
    margin-top: 0.35rem;
    font-size: 0.92rem;
  }

  a {
    color: var(--link-color);
    font-weight: 700;
  }

  .status {
    flex: 0 0 auto;
    border-radius: 999px;
    background: var(--subtle-background);
    color: var(--subtle-text);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    text-transform: uppercase;
  }

  .status.live {
    background: var(--success-background);
    color: var(--success-text);
  }

  .no-results {
    border: 1px dashed var(--border-color);
    border-radius: 12px;
    margin-top: 1.25rem;
    background: var(--card-background);
    color: var(--muted-text-color);
    padding: 1.25rem;
    text-align: center;
  }

  .no-results[hidden] {
    display: none;
  }
</style>
