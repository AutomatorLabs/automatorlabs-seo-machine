---
import Layout from '../../../../layouts/Layout.astro';
import {
  investmentFeeSeoRecords,
  EXPECTED_INVESTMENT_FEE_SEO_PAGE_COUNT,
} from '../../../../data/programmatic-seo/investment-fee';
import { createProgrammaticExampleGroups } from '../../../../lib/programmatic-seo/examples';
import { auditInvestmentFeeSeoRecords } from '../../../../lib/programmatic-seo/investment-fee';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../../../lib/programmatic-seo/schema';

const audit = auditInvestmentFeeSeoRecords(
  investmentFeeSeoRecords,
  EXPECTED_INVESTMENT_FEE_SEO_PAGE_COUNT,
);
const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Calculators', url: '/calculators/' },
      {
        name: 'Investment Fee Calculator',
        url: '/calculators/investment-fee-calculator/',
      },
      { name: 'Examples', url: '/calculators/investment-fee/examples/' },
    ],
    site,
  ),
);

const groups = createProgrammaticExampleGroups(investmentFeeSeoRecords, [
  {
    id: 'general',
    title: 'General Investment Fee Examples',
    description:
      'Examples focused on recurring annual investment fees across common balances and monthly contributions.',
    matches: (record) => record.intent === 'general-investing-fees',
  },
  {
    id: 'retirement',
    title: 'Retirement Fee Examples',
    description:
      'Examples showing how recurring annual fees affect larger balances and long retirement timelines.',
    matches: (record) => record.intent === 'retirement-fees',
  },
  {
    id: 'advisor',
    title: 'Advisor Fee Examples',
    description:
      'Examples highlighting advisory-fee drag across growing portfolios and recurring contributions.',
    matches: (record) => record.intent === 'advisor-fee-impact',
  },
  {
    id: 'taxable',
    title: 'Taxable Investment Fee Examples',
    description:
      'Examples framed around taxable investing while isolating recurring fee drag only.',
    matches: (record) => record.intent === 'taxable-fees',
  },
  {
    id: 'fund',
    title: 'Fund Fee Drag Examples',
    description:
      'Examples centered on mutual-fund or fund-level annual fee drag over time.',
    matches: (record) => record.intent === 'fund-fee-drag',
  },
]);
---

<Layout
  title="Investment Fee Examples | AutomatorLabs"
  description={`Browse ${audit.actualCount} investment fee examples across retirement balances, advisor fees, taxable accounts, recurring contributions, and long-term fee drag.`}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li>
          <a href="/calculators/investment-fee-calculator/">
            Investment Fee Calculator
          </a>
        </li>
        <li aria-current="page">Examples</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Investment fee scenario library</p>
      <h1>Investment Fee Examples</h1>
      <p class="intro">
        Browse {audit.actualCount} worked examples showing how recurring
        annual fees can reduce long-term investment growth across retirement,
        taxable, and advisor-fee scenarios.
      </p>
      <a class="primary-link" href="/calculators/investment-fee-calculator/">
        Model your own investment fee scenario
      </a>
      <a class="secondary-link" href="/examples/">
        Browse all financial examples
      </a>
    </header>

    <section class="example-search" aria-label="Search investment fee examples">
      <label for="investment-fee-example-search">
        Search investment fee examples
      </label>
      <div class="search-row">
        <input
          id="investment-fee-example-search"
          type="search"
          placeholder="Try advisor, retirement, taxable, 1%, or $100,000"
          autocomplete="off"
          aria-controls="investment-fee-example-groups"
          aria-describedby="investment-fee-example-count"
        />
        <button id="clear-investment-fee-example-search" type="button" hidden>
          Clear search
        </button>
      </div>
      <p id="investment-fee-example-count" aria-live="polite">
        Showing {audit.actualCount} examples
      </p>
    </section>

    <div id="investment-fee-example-groups" class="example-groups">
      {groups.map((group) => (
        <section
          class="example-group"
          aria-labelledby={`${group.id}-heading`}
          data-investment-fee-example-group
        >
          <header>
            <div>
              <h2 id={`${group.id}-heading`}>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            <span>{group.records.length} examples</span>
          </header>

          <ul>
            {group.records.map((record) => (
              <li
                data-investment-fee-example-card
                data-search-text={[
                  record.question,
                  record.slug,
                  record.intent,
                  record.scenarioLabel,
                  record.startingInvestment,
                  record.monthlyContribution,
                  `${record.annualFeePercent}%`,
                  `${record.years} years`,
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <a href={`/calculators/investment-fee/${record.slug}/`}>
                  <strong>{record.question}</strong>
                  <span>
                    ${record.startingInvestment.toLocaleString('en-US')} start
                    {' · '}
                    ${record.monthlyContribution.toLocaleString('en-US')} monthly
                    {' · '}
                    {record.annualFeePercent}% annual fee
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p id="no-investment-fee-examples" class="no-results" role="status" hidden>
      No investment fee examples found. Try a fee level, balance, or scenario type.
    </p>
  </main>
</Layout>

<script>
  const input = document.querySelector<HTMLInputElement>(
    '#investment-fee-example-search',
  );
  const clearButton = document.querySelector<HTMLButtonElement>(
    '#clear-investment-fee-example-search',
  );
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('[data-investment-fee-example-card]'),
  );
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>('[data-investment-fee-example-group]'),
  );
  const count = document.querySelector<HTMLElement>(
    '#investment-fee-example-count',
  );
  const noResults = document.querySelector<HTMLElement>(
    '#no-investment-fee-examples',
  );

  function updateSearch() {
    const query = input?.value.trim().toLocaleLowerCase() ?? '';
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches =
        query.length === 0 ||
        (card.dataset.searchText ?? '').includes(query);
      card.hidden = !matches;
      if (matches) visibleCount += 1;
    });

    groups.forEach((group) => {
      const hasVisibleCard = Array.from(
        group.querySelectorAll<HTMLElement>('[data-investment-fee-example-card]'),
      ).some((card) => !card.hidden);
      group.hidden = !hasVisibleCard;
    });

    if (count) {
      count.textContent = `Showing ${visibleCount} example${visibleCount === 1 ? '' : 's'}`;
    }
    if (noResults) noResults.hidden = visibleCount !== 0;
    if (clearButton) clearButton.hidden = query.length === 0;
  }

  input?.addEventListener('input', updateSearch);
  clearButton?.addEventListener('click', () => {
    if (!input) return;
    input.value = '';
    updateSearch();
    input.focus();
  });
</script>

<style>
  @import '../../../../styles/programmatic-examples.css';
</style>
