---
import CalculatorPage from '../../../components/CalculatorPage.astro';
import { mortgagePayoffCalculator } from '../../../data/calculators';
import { contentItems } from '../../../data/content';

const relatedItems = mortgagePayoffCalculator.relatedIds.flatMap((id) => {
  const item = contentItems.find((contentItem) => contentItem.id === id);
  return item ? [{ title: item.title, url: item.url }] : [];
});
---

<CalculatorPage
  title={mortgagePayoffCalculator.title}
  eyebrow={mortgagePayoffCalculator.eyebrow}
  description={mortgagePayoffCalculator.description}
  inputs={mortgagePayoffCalculator.inputs}
  outputs={mortgagePayoffCalculator.outputs}
  faq={mortgagePayoffCalculator.faq}
  relatedItems={relatedItems}
>
  <script>
    import { trackSuccessfulCalculation } from '../../../lib/analytics';
    import {
      parseCalculatorNumber,
      parseOptionalCalculatorNumber,
    } from '../../../lib/input';
    import {
      calculateMonthlyLoanPayment,
      calculateMortgagePayoff,
    } from '../../../lib/math';

    const form = document.querySelector<HTMLFormElement>('#calculator-form');
    const error = document.querySelector<HTMLElement>('#form-error');
    const requiredMonthlyPaymentResult =
      document.querySelector<HTMLElement>(
        '#required-monthly-payment-result',
      );
    const totalInterestPaidResult = document.querySelector<HTMLElement>(
      '#total-interest-paid-result',
    );
    const totalAmountPaidResult = document.querySelector<HTMLElement>(
      '#total-amount-paid-result',
    );
    const timeSavedResult =
      document.querySelector<HTMLElement>('#time-saved-result');
    const interestSavedResult = document.querySelector<HTMLElement>(
      '#interest-saved-result',
    );
    const chart = document.querySelector<HTMLElement>('#chart');

    const currency = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 2,
    });

    const compactCurrency = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      notation: 'compact',
      maximumFractionDigits: 1,
    });

    const svgNamespace = 'http://www.w3.org/2000/svg';

    function createSvgElement<K extends keyof SVGElementTagNameMap>(
      name: K,
      attributes: Record<string, string>,
    ): SVGElementTagNameMap[K] {
      const element = document.createElementNS(svgNamespace, name);

      Object.entries(attributes).forEach(([attribute, value]) => {
        element.setAttribute(attribute, value);
      });

      return element;
    }

    function createBalanceSchedule({
      loanAmount,
      monthlyInterestRate,
      monthlyPayment,
      maximumMonths,
    }: {
      loanAmount: number;
      monthlyInterestRate: number;
      monthlyPayment: number;
      maximumMonths: number;
    }) {
      const points = [{ month: 0, balance: loanAmount }];
      let balance = loanAmount;
      let month = 0;

      while (balance > 0.005 && month < maximumMonths) {
        const interest = balance * monthlyInterestRate;
        const payment = Math.min(monthlyPayment, balance + interest);

        balance = Math.max(balance + interest - payment, 0);
        month += 1;

        if (month % 12 === 0 || balance === 0) {
          points.push({ month, balance });
        }
      }

      return points;
    }

    function renderMortgagePayoffChart({
      loanAmount,
      annualInterestRatePercent,
      loanTermYears,
      extraMonthlyPayment,
    }: {
      loanAmount: number;
      annualInterestRatePercent: number;
      loanTermYears: number;
      extraMonthlyPayment: number;
    }) {
      if (!chart) return;

      const requiredMonthlyPayment = calculateMonthlyLoanPayment(
        loanAmount,
        annualInterestRatePercent,
        loanTermYears,
      );
      const monthlyInterestRate =
        annualInterestRatePercent / 100 / 12;
      const maximumMonths = loanTermYears * 12;
      const standardPoints = createBalanceSchedule({
        loanAmount,
        monthlyInterestRate,
        monthlyPayment: requiredMonthlyPayment,
        maximumMonths,
      });
      const extraPaymentPoints = createBalanceSchedule({
        loanAmount,
        monthlyInterestRate,
        monthlyPayment: requiredMonthlyPayment + extraMonthlyPayment,
        maximumMonths,
      });
      const standardPayoffMonth =
        standardPoints.at(-1)?.month ?? maximumMonths;
      const extraPayoffMonth =
        extraPaymentPoints.at(-1)?.month ?? maximumMonths;
      const width = 720;
      const height = 400;
      const margin = { top: 68, right: 28, bottom: 66, left: 100 };
      const plotWidth = width - margin.left - margin.right;
      const plotHeight = height - margin.top - margin.bottom;
      const xPosition = (month: number) =>
        margin.left + (month / maximumMonths) * plotWidth;
      const yPosition = (balance: number) =>
        margin.top +
        plotHeight -
        (balance / loanAmount) * plotHeight;
      const svg = createSvgElement('svg', {
        viewBox: `0 0 ${width} ${height}`,
        'aria-hidden': 'true',
        focusable: 'false',
      });

      for (let index = 0; index <= 4; index += 1) {
        const ratio = index / 4;
        const y = margin.top + plotHeight - ratio * plotHeight;
        const balance = loanAmount * ratio;

        svg.append(
          createSvgElement('line', {
            x1: String(margin.left),
            y1: String(y),
            x2: String(width - margin.right),
            y2: String(y),
            stroke: 'var(--border-subtle)',
            'stroke-width': '1',
          }),
        );

        const label = createSvgElement('text', {
          x: String(margin.left - 10),
          y: String(y + 4),
          fill: 'var(--muted-text-color)',
          'font-size': '14',
          'text-anchor': 'end',
        });
        label.textContent = compactCurrency.format(balance);
        svg.append(label);
      }

      const xTickCount = Math.min(6, loanTermYears);
      for (let index = 0; index <= xTickCount; index += 1) {
        const year = (loanTermYears * index) / xTickCount;
        const label = createSvgElement('text', {
          x: String(xPosition(year * 12)),
          y: String(height - 22),
          fill: 'var(--muted-text-color)',
          'font-size': '14',
          'text-anchor': 'middle',
        });
        label.textContent = Number.isInteger(year)
          ? String(year)
          : year.toFixed(1);
        svg.append(label);
      }

      const xAxisLabel = createSvgElement('text', {
        x: String(margin.left + plotWidth / 2),
        y: String(height - 4),
        fill: 'var(--muted-text-color)',
        'font-size': '15',
        'font-weight': '600',
        'text-anchor': 'middle',
      });
      xAxisLabel.textContent = 'Years';
      svg.append(xAxisLabel);

      const yAxisLabel = createSvgElement('text', {
        x: '22',
        y: String(margin.top + plotHeight / 2),
        fill: 'var(--muted-text-color)',
        'font-size': '15',
        'font-weight': '600',
        'text-anchor': 'middle',
        transform: `rotate(-90 22 ${margin.top + plotHeight / 2})`,
      });
      yAxisLabel.textContent = 'Remaining mortgage balance';
      svg.append(yAxisLabel);

      const legendItems = [
        {
          label: 'Standard payoff',
          color: 'var(--link-color)',
          x: margin.left,
        },
        {
          label: 'Extra-payment payoff',
          color: 'var(--warning-text)',
          x: margin.left + 170,
        },
      ];

      legendItems.forEach((item) => {
        svg.append(
          createSvgElement('line', {
            x1: String(item.x),
            y1: '24',
            x2: String(item.x + 24),
            y2: '24',
            stroke: item.color,
            'stroke-width': '4',
            'stroke-linecap': 'round',
          }),
        );
        const label = createSvgElement('text', {
          x: String(item.x + 32),
          y: '28',
          fill: 'var(--text-color)',
          'font-size': '14',
          'font-weight': '600',
        });
        label.textContent = item.label;
        svg.append(label);
      });

      const createLinePath = (
        points: Array<{ month: number; balance: number }>,
      ) =>
        points
          .map(
            (point, index) =>
              `${index === 0 ? 'M' : 'L'} ${xPosition(point.month)} ${yPosition(point.balance)}`,
          )
          .join(' ');

      svg.append(
        createSvgElement('path', {
          d: createLinePath(standardPoints),
          fill: 'none',
          stroke: 'var(--link-color)',
          'stroke-linecap': 'round',
          'stroke-linejoin': 'round',
          'stroke-width': '4',
        }),
        createSvgElement('path', {
          d: createLinePath(extraPaymentPoints),
          fill: 'none',
          stroke: 'var(--warning-text)',
          'stroke-linecap': 'round',
          'stroke-linejoin': 'round',
          'stroke-width': '4',
        }),
      );

      chart.replaceChildren(svg);
      chart.setAttribute(
        'aria-label',
        extraMonthlyPayment > 0
          ? `Mortgage balance projection. The standard payment pays off the ${currency.format(loanAmount)} mortgage in ${formatMonths(standardPayoffMonth)}, while paying an extra ${currency.format(extraMonthlyPayment)} per month pays it off in ${formatMonths(extraPayoffMonth)}.`
          : `Mortgage balance projection showing the ${currency.format(loanAmount)} mortgage declining to zero over ${formatMonths(standardPayoffMonth)}. The standard and extra-payment lines overlap because no extra payment was entered.`,
      );
    }

    function formatMonths(totalMonths: number): string {
      if (totalMonths === 0) {
        return '0 months';
      }

      const years = Math.floor(totalMonths / 12);
      const months = totalMonths % 12;
      const parts: string[] = [];

      if (years > 0) {
        parts.push(`${years} ${years === 1 ? 'year' : 'years'}`);
      }

      if (months > 0) {
        parts.push(`${months} ${months === 1 ? 'month' : 'months'}`);
      }

      return parts.join(', ');
    }

    function calculate() {
      if (
        !form ||
        !error ||
        !requiredMonthlyPaymentResult ||
        !totalInterestPaidResult ||
        !totalAmountPaidResult ||
        !timeSavedResult ||
        !interestSavedResult
      ) {
        return false;
      }

      const data = new FormData(form);
      const loanAmount = parseCalculatorNumber(data.get('loanAmount'));
      const annualInterestRatePercent = parseCalculatorNumber(
        data.get('annualInterestRate'),
      );
      const loanTermYears = parseCalculatorNumber(
        data.get('loanTermYears'),
      );
      const extraMonthlyPayment =
        parseOptionalCalculatorNumber(data.get('extraMonthlyPayment')) ?? 0;

      if (
        !Number.isFinite(loanAmount) ||
        !Number.isFinite(annualInterestRatePercent) ||
        !Number.isFinite(loanTermYears) ||
        !Number.isFinite(extraMonthlyPayment) ||
        loanAmount <= 0 ||
        annualInterestRatePercent < 0 ||
        loanTermYears <= 0 ||
        !Number.isInteger(loanTermYears) ||
        extraMonthlyPayment < 0
      ) {
        error.textContent =
          'Loan amount must be greater than $0. Interest and extra payments cannot be negative, and the loan term must be a whole number of years greater than 0.';
        error.hidden = false;
        return false;
      }

      error.hidden = true;

      const result = calculateMortgagePayoff({
        loanAmount,
        annualInterestRatePercent,
        loanTermYears,
        extraMonthlyPayment,
      });

      requiredMonthlyPaymentResult.textContent = currency.format(
        result.requiredMonthlyPayment,
      );
      totalInterestPaidResult.textContent = currency.format(
        result.totalInterestPaid,
      );
      totalAmountPaidResult.textContent = currency.format(
        result.totalAmountPaid,
      );
      timeSavedResult.textContent = formatMonths(result.timeSavedMonths);
      interestSavedResult.textContent = currency.format(
        result.interestSaved,
      );

      renderMortgagePayoffChart({
        loanAmount,
        annualInterestRatePercent,
        loanTermYears,
        extraMonthlyPayment,
      });
      return true;
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      trackSuccessfulCalculation('mortgage_payoff', calculate);
    });

    calculate();
  </script>
</CalculatorPage>
