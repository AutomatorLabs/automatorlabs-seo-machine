---
import ProgrammaticSeoPage from '../../../components/programmatic-seo/ProgrammaticSeoPage.astro';
import {
  EXPECTED_RETIREMENT_TAX_DRAG_SEO_PAGE_COUNT,
  retirementTaxDragSeoRecords,
} from '../../../data/programmatic-seo/retirement-tax-drag';
import {
  auditRetirementTaxDragSeoRecords,
  createRetirementTaxDragSeoPage,
} from '../../../lib/programmatic-seo/retirement-tax-drag';

auditRetirementTaxDragSeoRecords(
  retirementTaxDragSeoRecords,
  EXPECTED_RETIREMENT_TAX_DRAG_SEO_PAGE_COUNT,
);

export function getStaticPaths() {
  return retirementTaxDragSeoRecords.map((record) => ({
    params: { slug: record.slug },
    props: {
      page: createRetirementTaxDragSeoPage(
        record,
        retirementTaxDragSeoRecords,
      ),
    },
  }));
}

const { page } = Astro.props;
---

<ProgrammaticSeoPage page={page} />
