---
import CalculatorPage from '../../../components/CalculatorPage.astro';
import { savingsGoalCalculator } from '../../../data/calculators';
import { contentItems } from '../../../data/content';

const relatedItems = savingsGoalCalculator.relatedIds.flatMap((id) => {
  const item = contentItems.find((contentItem) => contentItem.id === id);
  return item ? [{ title: item.title, url: item.url }] : [];
});
---

<CalculatorPage
  title={savingsGoalCalculator.title}
  eyebrow={savingsGoalCalculator.eyebrow}
  description={savingsGoalCalculator.description}
  inputs={savingsGoalCalculator.inputs}
  outputs={savingsGoalCalculator.outputs}
  faq={savingsGoalCalculator.faq}
  relatedItems={relatedItems}
>
  <script>
    import { trackSuccessfulCalculation } from '../../../lib/analytics';
    import { parseCalculatorNumber } from '../../../lib/input';
    import { calculateSavingsGoal } from '../../../lib/math';

    const form = document.querySelector<HTMLFormElement>('#calculator-form');
    const error = document.querySelector<HTMLElement>('#form-error');
    const amountStillNeededResult = document.querySelector<HTMLElement>(
      '#amount-still-needed-result',
    );
    const estimatedMonthsResult = document.querySelector<HTMLElement>(
      '#estimated-months-result',
    );
    const estimatedCompletionDateResult =
      document.querySelector<HTMLElement>(
        '#estimated-completion-date-result',
      );
    const totalContributionsNeededResult =
      document.querySelector<HTMLElement>(
        '#total-contributions-needed-result',
      );

    const currency = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 2,
    });

    const completionDate = new Intl.DateTimeFormat('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });

    function addMonths(date: Date, months: number): Date {
      const result = new Date(date);
      const originalDay = result.getDate();

      result.setDate(1);
      result.setMonth(result.getMonth() + months);
      const lastDayOfTargetMonth = new Date(
        result.getFullYear(),
        result.getMonth() + 1,
        0,
      ).getDate();
      result.setDate(Math.min(originalDay, lastDayOfTargetMonth));

      return result;
    }

    function calculate() {
      if (
        !form ||
        !error ||
        !amountStillNeededResult ||
        !estimatedMonthsResult ||
        !estimatedCompletionDateResult ||
        !totalContributionsNeededResult
      ) {
        return false;
      }

      const data = new FormData(form);
      const goalAmount = parseCalculatorNumber(data.get('goalAmount'));
      const currentSavings = parseCalculatorNumber(
        data.get('currentSavings'),
      );
      const monthlyContribution = parseCalculatorNumber(
        data.get('monthlyContribution'),
      );
      const expectedReturn = parseCalculatorNumber(data.get('expectedReturn'));

      if (
        !Number.isFinite(goalAmount) ||
        !Number.isFinite(currentSavings) ||
        !Number.isFinite(monthlyContribution) ||
        !Number.isFinite(expectedReturn) ||
        goalAmount <= 0 ||
        currentSavings < 0 ||
        monthlyContribution < 0 ||
        expectedReturn < 0
      ) {
        error.textContent =
          'Savings goal must be greater than 0. Current savings, monthly contribution, and expected return cannot be negative.';
        error.hidden = false;
        return false;
      }

      error.hidden = true;

      const result = calculateSavingsGoal({
        goalAmount,
        currentSavings,
        monthlyContribution,
        expectedAnnualReturnPercent: expectedReturn,
      });

      amountStillNeededResult.textContent = currency.format(
        result.amountStillNeeded,
      );

      if (result.status === 'funded') {
        estimatedMonthsResult.textContent = 'Already funded';
        estimatedCompletionDateResult.textContent = 'Completed';
        totalContributionsNeededResult.textContent = currency.format(0);
      } else if (result.status === 'unreachable') {
        estimatedMonthsResult.textContent =
          'Unreachable with current contribution';
        estimatedCompletionDateResult.textContent =
          'Increase the monthly contribution';
        totalContributionsNeededResult.textContent = 'Unreachable';
      } else {
        const months = result.estimatedMonthsToGoal ?? 0;
        estimatedMonthsResult.textContent =
          `${months} ${months === 1 ? 'month' : 'months'}`;
        estimatedCompletionDateResult.textContent = completionDate.format(
          addMonths(new Date(), months),
        );
        totalContributionsNeededResult.textContent = currency.format(
          result.totalContributionsNeeded ?? 0,
        );
      }

      return true;
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      trackSuccessfulCalculation('savings_goal', calculate);
    });

    calculate();
  </script>
</CalculatorPage>
