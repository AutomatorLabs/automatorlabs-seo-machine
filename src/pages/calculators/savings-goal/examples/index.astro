---
import Layout from '../../../../layouts/Layout.astro';
import {
  EXPECTED_SAVINGS_GOAL_SEO_PAGE_COUNT,
  savingsGoalSeoRecords,
} from '../../../../data/programmatic-seo/savings-goal';
import { auditSavingsGoalSeoRecords } from '../../../../lib/programmatic-seo/savings-goal';
import { createProgrammaticExampleGroups } from '../../../../lib/programmatic-seo/examples';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../../../lib/programmatic-seo/schema';

const audit = auditSavingsGoalSeoRecords(
  savingsGoalSeoRecords,
  EXPECTED_SAVINGS_GOAL_SEO_PAGE_COUNT,
);
const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Calculators', url: '/calculators/' },
      {
        name: 'Savings Goal Calculator',
        url: '/calculators/savings-goal-calculator/',
      },
      {
        name: 'Savings Goal Examples',
        url: '/calculators/savings-goal/examples/',
      },
    ],
    site,
  ),
);
const currency = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});
const groups = createProgrammaticExampleGroups(
  savingsGoalSeoRecords,
  [
    {
      id: 'general',
      title: 'Savings Targets by Amount and Time',
      description:
        'Compare monthly savings estimates for general targets from $10,000 to $1 million.',
      matches: (record) => record.intent === 'general',
    },
    {
      id: 'home',
      title: 'House Down Payment Goals',
      description:
        'Plan a home down payment across two-, three-, and five-year timelines.',
      matches: (record) => record.intent === 'down-payment',
    },
    {
      id: 'emergency',
      title: 'Emergency Fund Goals',
      description:
        'Estimate monthly deposits for practical emergency savings targets.',
      matches: (record) => record.intent === 'emergency-fund',
    },
    {
      id: 'vacation-vehicle',
      title: 'Vacation and Vehicle Funds',
      description:
        'Build sinking funds for planned travel or a future vehicle purchase.',
      matches: (record) =>
        record.intent === 'vacation' || record.intent === 'vehicle',
    },
    {
      id: 'retirement',
      title: 'Retirement Targets by Age',
      description:
        'Estimate monthly savings for long-term targets using a starting and target age.',
      matches: (record) => record.intent === 'retirement-age',
    },
  ],
  (a, b) => a.goalAmount - b.goalAmount || a.years - b.years,
);
---

<Layout
  title="Savings Goal Examples and Monthly Targets | AutomatorLabs"
  description="Browse and search 100 savings goal examples for general targets, house down payments, emergency funds, vacations, vehicles, and retirement milestones."
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li>
          <a href="/calculators/savings-goal-calculator/">
            Savings Goal Calculator
          </a>
        </li>
        <li aria-current="page">Savings Goal Examples</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Savings planning library</p>
      <h1>Savings Goal Examples</h1>
      <p class="intro">
        Browse {audit.actualCount} worked savings plans covering general
        targets, down payments, emergency funds, travel, vehicles, and
        retirement milestones. Each page estimates a monthly deposit and
        shows a year-by-year projection.
      </p>
      <a class="primary-link" href="/calculators/savings-goal-calculator/">
        Build your savings plan
      </a>
      <a class="secondary-link" href="/examples/">
        Browse all financial examples
      </a>
    </header>

    <section class="example-search" aria-label="Search savings goal examples">
      <label for="savings-goal-example-search">
        Search savings goal examples
      </label>
      <div class="search-row">
        <input
          id="savings-goal-example-search"
          type="search"
          placeholder="Try 50,000, down payment, 5 years, or age 65"
          autocomplete="off"
          aria-controls="savings-goal-example-groups"
          aria-describedby="savings-goal-example-count"
        />
        <button id="clear-savings-goal-example-search" type="button" hidden>
          Clear search
        </button>
      </div>
      <p id="savings-goal-example-count" aria-live="polite">
        Showing {audit.actualCount} examples
      </p>
    </section>

    <div id="savings-goal-example-groups" class="example-groups">
      {groups.map((group) => (
        <section
          class="example-group"
          aria-labelledby={`${group.id}-heading`}
          data-savings-goal-example-group
        >
          <header>
            <div>
              <h2 id={`${group.id}-heading`}>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            <span>{group.records.length} examples</span>
          </header>
          <ul>
            {group.records.map((record) => (
              <li
                data-savings-goal-example-card
                data-search-text={[
                  record.question,
                  record.slug,
                  record.intent,
                  record.purpose,
                  record.goalAmount,
                  record.goalAmount.toLocaleString('en-US'),
                  record.years,
                  `${record.years} years`,
                  record.currentAge ?? '',
                  record.targetAge ?? '',
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <a href={`/calculators/savings-goal/${record.slug}/`}>
                  <strong>{record.question}</strong>
                  <span>
                    {currency.format(record.goalAmount)} · {record.years} years
                    · {record.purpose}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p id="no-savings-goal-examples" class="no-results" role="status" hidden>
      No savings goal examples found. Try an amount, timeline, or goal type.
    </p>
  </main>
</Layout>

<script>
  const input = document.querySelector<HTMLInputElement>(
    '#savings-goal-example-search',
  );
  const clearButton = document.querySelector<HTMLButtonElement>(
    '#clear-savings-goal-example-search',
  );
  const count = document.querySelector<HTMLElement>(
    '#savings-goal-example-count',
  );
  const noResults = document.querySelector<HTMLElement>(
    '#no-savings-goal-examples',
  );
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>(
      '[data-savings-goal-example-card]',
    ),
  );
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>(
      '[data-savings-goal-example-group]',
    ),
  );

  function updateExamples() {
    if (!input || !count || !noResults) return;

    const query = input.value.trim().toLocaleLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches =
        query === '' || (card.dataset.searchText ?? '').includes(query);
      card.hidden = !matches;
      if (matches) visibleCount += 1;
    });

    groups.forEach((group) => {
      group.hidden = !group.querySelector(
        '[data-savings-goal-example-card]:not([hidden])',
      );
    });

    count.textContent = `Showing ${visibleCount} ${visibleCount === 1 ? 'example' : 'examples'}`;
    noResults.hidden = visibleCount !== 0;
    if (clearButton) clearButton.hidden = query === '';
  }

  input?.addEventListener('input', updateExamples);
  clearButton?.addEventListener('click', () => {
    if (!input) return;
    input.value = '';
    updateExamples();
    input.focus();
  });
</script>

<style>
  main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .breadcrumbs li + li::before {
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a {
    color: var(--link-color);
    text-decoration: none;
  }

  .page-header {
    max-width: 820px;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    margin: 0 0 0.65rem;
    color: var(--accent-color);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.25rem, 6vw, 4.6rem);
    line-height: 0.98;
  }

  .intro {
    max-width: 760px;
    margin: 1.2rem 0 1.5rem;
    color: var(--muted-text-color);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .primary-link,
  .secondary-link {
    display: inline-flex;
    margin: 0.35rem 0.65rem 0.35rem 0;
    padding: 0.8rem 1rem;
    border-radius: 0.75rem;
    font-weight: 800;
    text-decoration: none;
  }

  .primary-link {
    background: var(--accent-color);
    color: #fff;
  }

  .secondary-link {
    border: 1px solid var(--border-color);
    color: var(--link-color);
  }

  .example-search {
    margin-bottom: 2rem;
    padding: 1.25rem;
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    background: var(--panel-color);
  }

  .example-search label {
    display: block;
    margin-bottom: 0.6rem;
    font-weight: 800;
  }

  .search-row {
    display: flex;
    gap: 0.75rem;
  }

  .search-row input {
    width: 100%;
    min-height: 3rem;
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--border-color);
    border-radius: 0.7rem;
    background: var(--background-color);
    color: var(--text-color);
    font: inherit;
  }

  .search-row button {
    padding: 0.7rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: 0.7rem;
    background: var(--background-color);
    color: var(--text-color);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .example-search p {
    margin: 0.75rem 0 0;
    color: var(--muted-text-color);
  }

  .example-groups {
    display: grid;
    gap: 1.5rem;
  }

  .example-group {
    padding: 1.35rem;
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    background: var(--panel-color);
  }

  .example-group > header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .example-group h2,
  .example-group p {
    margin: 0;
  }

  .example-group p {
    margin-top: 0.35rem;
    color: var(--muted-text-color);
  }

  .example-group > header span {
    flex: none;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .example-group ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .example-group a {
    display: grid;
    gap: 0.35rem;
    height: 100%;
    padding: 1rem;
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    color: var(--text-color);
    text-decoration: none;
  }

  .example-group a:hover {
    border-color: var(--accent-color);
  }

  .example-group a span {
    color: var(--muted-text-color);
    font-size: 0.92rem;
  }

  .no-results {
    padding: 1rem;
    border: 1px solid var(--border-color);
    border-radius: 0.8rem;
    color: var(--muted-text-color);
  }

  @media (max-width: 720px) {
    main {
      padding: 3rem 0;
    }

    .search-row,
    .example-group > header {
      display: grid;
    }

    .example-group ul {
      grid-template-columns: 1fr;
    }
  }
</style>
