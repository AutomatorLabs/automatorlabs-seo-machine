---
import CalculatorPage from '../../../components/CalculatorPage.astro';
import { studentLoanCalculator } from '../../../data/calculators';
import { contentItems } from '../../../data/content';
import { featuredStudentLoanSeoRecords } from '../../../data/programmatic-seo/student-loan';

const relatedItems = studentLoanCalculator.relatedIds.flatMap((id) => {
  const item = contentItems.find((contentItem) => contentItem.id === id);
  return item ? [{ title: item.title, url: item.url }] : [];
});

const exampleItems = [
  {
    title: 'Browse all 200 student loan examples',
    url: '/calculators/student-loan/examples/',
  },
  ...featuredStudentLoanSeoRecords.map((record) => ({
    title: record.question,
    url: `/calculators/student-loan/${record.slug}/`,
  })),
];
---

<CalculatorPage
  title={studentLoanCalculator.title}
  eyebrow={studentLoanCalculator.eyebrow}
  description={studentLoanCalculator.description}
  inputs={studentLoanCalculator.inputs}
  outputs={studentLoanCalculator.outputs}
  faq={studentLoanCalculator.faq}
  relatedItems={relatedItems}
  exampleItems={exampleItems}
>
  <script>
    import { trackSuccessfulCalculation } from '../../../lib/analytics';
    import { parseCalculatorNumber } from '../../../lib/input';
    import { calculateMortgagePayoff } from '../../../lib/math';

    const balanceInput = document.querySelector<HTMLInputElement>(
      '#student-loan-balance',
    );
    const form = balanceInput?.form ?? null;
    const error = document.querySelector<HTMLElement>('#form-error');
    const requiredMonthlyPaymentResult =
      document.querySelector<HTMLElement>(
        '#required-monthly-payment-result',
      );
    const totalInterestPaidResult = document.querySelector<HTMLElement>(
      '#total-interest-paid-result',
    );
    const totalAmountPaidResult = document.querySelector<HTMLElement>(
      '#total-amount-paid-result',
    );
    const payoffTimeResult =
      document.querySelector<HTMLElement>('#payoff-time-result');
    const interestSavedResult = document.querySelector<HTMLElement>(
      '#interest-saved-result',
    );

    const currency = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 2,
    });

    function formatMonths(totalMonths: number): string {
      const years = Math.floor(totalMonths / 12);
      const months = totalMonths % 12;
      const parts: string[] = [];

      if (years > 0) {
        parts.push(`${years} ${years === 1 ? 'year' : 'years'}`);
      }

      if (months > 0) {
        parts.push(`${months} ${months === 1 ? 'month' : 'months'}`);
      }

      return parts.length > 0 ? parts.join(', ') : '0 months';
    }

    function calculate() {
      if (
        !form ||
        !error ||
        !requiredMonthlyPaymentResult ||
        !totalInterestPaidResult ||
        !totalAmountPaidResult ||
        !payoffTimeResult ||
        !interestSavedResult
      ) {
        return false;
      }

      const data = new FormData(form);
      const studentLoanBalance = parseCalculatorNumber(
        data.get('studentLoanBalance'),
      );
      const annualInterestRatePercent = parseCalculatorNumber(
        data.get('annualInterestRate'),
      );
      const loanTermYears = parseCalculatorNumber(
        data.get('loanTermYears'),
      );
      const monthlyExtraPayment = parseCalculatorNumber(
        data.get('monthlyExtraPayment'),
      );

      if (
        !Number.isFinite(studentLoanBalance) ||
        !Number.isFinite(annualInterestRatePercent) ||
        !Number.isFinite(loanTermYears) ||
        !Number.isFinite(monthlyExtraPayment) ||
        studentLoanBalance <= 0 ||
        annualInterestRatePercent < 0 ||
        loanTermYears <= 0 ||
        !Number.isInteger(loanTermYears) ||
        monthlyExtraPayment < 0
      ) {
        error.textContent =
          'Student loan balance and loan term must be greater than 0. The term must be a whole number of years, and interest and extra payments cannot be negative.';
        error.hidden = false;
        return false;
      }

      error.hidden = true;

      const result = calculateMortgagePayoff({
        loanAmount: studentLoanBalance,
        annualInterestRatePercent,
        loanTermYears,
        extraMonthlyPayment: monthlyExtraPayment,
      });

      requiredMonthlyPaymentResult.textContent = currency.format(
        result.requiredMonthlyPayment,
      );
      totalInterestPaidResult.textContent = currency.format(
        result.totalInterestPaid,
      );
      totalAmountPaidResult.textContent = currency.format(
        result.totalAmountPaid,
      );
      payoffTimeResult.textContent = formatMonths(result.payoffTimeMonths);
      interestSavedResult.textContent = currency.format(
        result.interestSaved,
      );

      return true;
    }

    if (form) {
      form.onsubmit = (event) => {
        event.preventDefault();
        trackSuccessfulCalculation('student_loan', calculate);
      };
    }

    calculate();
  </script>
</CalculatorPage>
