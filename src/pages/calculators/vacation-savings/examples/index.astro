---
import Layout from '../../../../layouts/Layout.astro';
import {
  EXPECTED_VACATION_SAVINGS_SEO_PAGE_COUNT,
  vacationSavingsSeoRecords,
} from '../../../../data/programmatic-seo/vacation-savings';
import { createProgrammaticExampleGroups } from '../../../../lib/programmatic-seo/examples';
import { auditVacationSavingsSeoRecords } from '../../../../lib/programmatic-seo/vacation-savings';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../../../lib/programmatic-seo/schema';

const audit = auditVacationSavingsSeoRecords(
  vacationSavingsSeoRecords,
  EXPECTED_VACATION_SAVINGS_SEO_PAGE_COUNT,
);
const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Calculators', url: '/calculators/' },
      {
        name: 'Vacation Savings Calculator',
        url: '/calculators/vacation-savings-calculator/',
      },
      { name: 'Examples', url: '/calculators/vacation-savings/examples/' },
    ],
    site,
  ),
);

const groups = createProgrammaticExampleGroups(vacationSavingsSeoRecords, [
  {
    id: 'weekend-getaway',
    title: 'Weekend Getaway Savings Examples',
    description:
      'Examples for smaller travel goals with short vacation-saving timelines.',
    matches: (record) => record.intent === 'weekend-getaway',
  },
  {
    id: 'family-vacation',
    title: 'Family Vacation Savings Examples',
    description:
      'Examples for larger family trip budgets and recurring monthly travel saving.',
    matches: (record) => record.intent === 'family-vacation',
  },
  {
    id: 'international-trip',
    title: 'International Trip Savings Examples',
    description:
      'Examples for bigger travel budgets, longer timelines, and multi-year planning.',
    matches: (record) => record.intent === 'international-trip',
  },
  {
    id: 'luxury-vacation',
    title: 'Luxury Vacation Savings Examples',
    description:
      'Examples for premium or bucket-list travel goals that need more savings runway.',
    matches: (record) => record.intent === 'luxury-vacation',
  },
  {
    id: 'retirement-travel',
    title: 'Retirement Travel Savings Examples',
    description:
      'Examples for recurring travel goals later in life with longer planning horizons.',
    matches: (record) => record.intent === 'retirement-travel',
  },
]);
---

<Layout
  title="Vacation Savings Examples | AutomatorLabs"
  description={`Browse ${audit.actualCount} vacation savings examples across weekend getaways, family trips, international travel, luxury vacations, and retirement travel goals.`}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/calculators/">Calculators</a></li>
        <li>
          <a href="/calculators/vacation-savings-calculator/">
            Vacation Savings Calculator
          </a>
        </li>
        <li aria-current="page">Examples</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Vacation savings library</p>
      <h1>Vacation Savings Examples</h1>
      <p class="intro">
        Browse {audit.actualCount} worked examples covering weekend getaways,
        family vacations, international trips, luxury travel, and retirement
        travel planning.
      </p>
      <a class="primary-link" href="/calculators/vacation-savings-calculator/">
        Plan your own vacation savings goal
      </a>
      <a class="secondary-link" href="/examples/">
        Browse all financial examples
      </a>
    </header>

    <section
      class="example-search"
      aria-label="Search vacation savings examples"
    >
      <label for="vacation-savings-example-search">
        Search vacation savings examples
      </label>
      <div class="search-row">
        <input
          id="vacation-savings-example-search"
          type="search"
          placeholder="Try family, international, $8,000, or 4 years"
          autocomplete="off"
          aria-controls="vacation-savings-example-groups"
          aria-describedby="vacation-savings-example-count"
        />
        <button id="clear-vacation-savings-example-search" type="button" hidden>
          Clear search
        </button>
      </div>
      <p id="vacation-savings-example-count" aria-live="polite">
        Showing {audit.actualCount} examples
      </p>
    </section>

    <div id="vacation-savings-example-groups" class="example-groups">
      {groups.map((group) => (
        <section
          class="example-group"
          aria-labelledby={`${group.id}-heading`}
          data-vacation-savings-example-group
        >
          <header>
            <div>
              <h2 id={`${group.id}-heading`}>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            <span>{group.records.length} examples</span>
          </header>

          <ul>
            {group.records.map((record) => (
              <li
                data-vacation-savings-example-card
                data-search-text={[
                  record.question,
                  record.slug,
                  record.intent,
                  record.scenarioLabel,
                  record.purposeLabel,
                  record.goalAmount,
                  record.currentSavings,
                  `${record.years} years`,
                ]
                  .join(' ')
                  .toLocaleLowerCase()}
              >
                <a href={`/calculators/vacation-savings/${record.slug}/`}>
                  <strong>{record.question}</strong>
                  <span>
                    ${record.goalAmount.toLocaleString('en-US')}
                    trip budget
                    {' · '}
                    ${record.currentSavings.toLocaleString('en-US')}
                    saved
                    {' · '}
                    {record.years} years
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p
      id="no-vacation-savings-examples"
      class="no-results"
      role="status"
      hidden
    >
      No vacation savings examples found. Try a trip type, budget, or time
      horizon.
    </p>
  </main>
</Layout>

<script>
  const input = document.querySelector<HTMLInputElement>(
    '#vacation-savings-example-search',
  );
  const clearButton = document.querySelector<HTMLButtonElement>(
    '#clear-vacation-savings-example-search',
  );
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>(
      '[data-vacation-savings-example-card]',
    ),
  );
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>(
      '[data-vacation-savings-example-group]',
    ),
  );
  const count = document.querySelector<HTMLElement>(
    '#vacation-savings-example-count',
  );
  const noResults = document.querySelector<HTMLElement>(
    '#no-vacation-savings-examples',
  );

  function updateSearch() {
    const query = input?.value.trim().toLocaleLowerCase() ?? '';
    let visibleCount = 0;

    cards.forEach((card) => {
      const matches =
        query.length === 0 ||
        (card.dataset.searchText ?? '').includes(query);
      card.hidden = !matches;
      if (matches) visibleCount += 1;
    });

    groups.forEach((group) => {
      const hasVisibleCard = Array.from(
        group.querySelectorAll<HTMLElement>(
          '[data-vacation-savings-example-card]',
        ),
      ).some((card) => !card.hidden);
      group.hidden = !hasVisibleCard;
    });

    if (count) {
      count.textContent = `Showing ${visibleCount} example${visibleCount === 1 ? '' : 's'}`;
    }
    if (noResults) noResults.hidden = visibleCount !== 0;
    if (clearButton) clearButton.hidden = query.length === 0;
  }

  input?.addEventListener('input', updateSearch);
  clearButton?.addEventListener('click', () => {
    if (input) {
      input.value = '';
      input.focus();
    }
    updateSearch();
  });
</script>

<style>
  @import '../../../../styles/programmatic-examples.css';
</style>
