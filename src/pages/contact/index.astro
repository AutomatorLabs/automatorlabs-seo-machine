---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Contact | AutomatorLabs"
  description="Contact AutomatorLabs with questions, feedback, or suggestions."
>
  <main>
    <h1>Contact</h1>
    <p>Contact details are coming soon. You can also reach us through GitHub.</p>
    <a href="https://github.com/AutomatorLabs/automatorlabs-seo-machine">
      Visit AutomatorLabs on GitHub
    </a>
  </main>
</Layout>

<style>
  main {
    width: min(760px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 5rem 0;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.25rem, 7vw, 3.75rem);
    letter-spacing: -0.04em;
  }

  p {
    color: #586176;
  }

  a {
    color: #3158d3;
    font-weight: 700;
  }
</style>
