---
import Layout from '../../layouts/Layout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { programmaticSeoClusters } from '../../data/programmatic-seo/clusters';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../lib/programmatic-seo/schema';

const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Financial Examples', url: '/examples/' },
    ],
    site,
  ),
);
const totalExamples = programmaticSeoClusters.reduce(
  (total, cluster) => total + cluster.pageCount,
  0,
);
---

<Layout
  title="Financial Examples and Projections | AutomatorLabs"
  description="Browse worked financial examples for investment growth, compound interest, retirement planning, debt payoff, savings goals, and mortgages, with transparent assumptions, calculators, guides, and detailed projections."
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main id="main-content">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">Financial Examples</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Worked financial projections</p>
      <h1>Financial Examples</h1>
      <p class="intro">
        Browse {totalExamples} static examples that show what specific
        financial assumptions produce. These are educational projections—not
        forecasts or personalized advice—and each cluster links back to the
        calculator and guide behind the numbers.
      </p>
    </header>

    <div class="cluster-grid">
      {programmaticSeoClusters.map((cluster) => (
        <section
          class="cluster-card"
          aria-labelledby={`${cluster.id}-examples-heading`}
        >
          <p class="cluster-count">{cluster.pageCount} examples</p>
          <h2 id={`${cluster.id}-examples-heading`}>{cluster.title}</h2>
          <p>{cluster.description}</p>
          <a class="primary-link" href={cluster.examplesUrl}>
            Browse {cluster.title}
          </a>

          <div class="representative-links">
            <h3>Example projections</h3>
            <ul>
              {cluster.representativePages.map((page) => (
                <li><a href={page.url}>{page.title}</a></li>
              ))}
            </ul>
          </div>

          <div class="supporting-links">
            <a href={cluster.calculator.url}>{cluster.calculator.title}</a>
            <a href={cluster.guide.url}>{cluster.guide.title}</a>
          </div>
        </section>
      ))}
    </div>

    <NewsletterSignup
      compact
      headline="Get new worked examples and calculators"
      description="Follow new financial scenarios, planning tools, and practical guides as they are published."
    />
  </main>
</Layout>

<style>
  main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li + li::before {
    margin-right: 0.45rem;
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a {
    color: var(--link-color);
    text-decoration: none;
  }

  .page-header {
    max-width: 860px;
    margin-bottom: 3rem;
  }

  .eyebrow,
  .cluster-count {
    margin: 0;
    color: var(--link-color);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0.6rem 0 1rem;
    font-size: clamp(2.6rem, 8vw, 4.8rem);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .intro {
    margin: 0;
    color: var(--muted-text-color);
    font-size: 1.14rem;
    line-height: 1.75;
  }

  .cluster-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .cluster-card {
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--card-background);
    box-shadow: 0 12px 35px var(--shadow-color);
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .cluster-card h2 {
    margin: 0.45rem 0 0.75rem;
    color: var(--heading-color);
    font-size: 1.75rem;
  }

  .cluster-card > p:not(.cluster-count) {
    color: var(--muted-text-color);
    line-height: 1.65;
  }

  .primary-link {
    display: inline-block;
    margin-top: 0.4rem;
    border-radius: 10px;
    background: var(--button-background);
    color: var(--button-text);
    font-weight: 750;
    padding: 0.75rem 0.95rem;
    text-decoration: none;
  }

  .primary-link:hover {
    background: var(--button-hover-background);
  }

  .representative-links {
    margin-top: 1.5rem;
    border-top: 1px solid var(--border-subtle);
    padding-top: 1.25rem;
  }

  .representative-links h3 {
    margin: 0 0 0.65rem;
    color: var(--heading-color);
    font-size: 1rem;
  }

  .representative-links ul {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding-left: 1.2rem;
  }

  .representative-links a,
  .supporting-links a {
    color: var(--link-color);
  }

  .supporting-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.1rem;
    margin-top: 1.25rem;
    font-size: 0.9rem;
    font-weight: 700;
  }

  @media (max-width: 720px) {
    main {
      padding: 3rem 0;
    }

    .cluster-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
