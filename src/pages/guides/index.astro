---
import { guideHubs } from '../../data/guide-hubs';
import { calculatorGuides } from '../../data/calculator-guides';
import { comparisonGuides } from '../../data/comparison-guides';
import { topicalGuides } from '../../data/topical-guides';
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Guides | AutomatorLabs"
  description="Read practical guides about money, data, and automation."
>
  <main>
    <p class="eyebrow">Guides</p>
    <h1>Clear guides for practical problems</h1>
    <p class="intro">
      Beginner-friendly explanations for financial decisions, with practical
      calculators to help you explore the numbers.
    </p>

    <h2>Topic guides</h2>
    <ul class="guide-list">
      {guideHubs.map((guide) => (
        <li>
          <a href={`/guides/${guide.slug}/`}>
            <span>{guide.title}</span>
            <small>{guide.description}</small>
          </a>
        </li>
      ))}
    </ul>

    <h2 class="comparison-guides-heading">Comparison guides</h2>
    <p class="section-intro">
      Compare common financial strategies side by side, understand their
      tradeoffs, and choose the calculator that matches your question.
    </p>
    <ul class="guide-list comparison-guide-list">
      {comparisonGuides.map((guide) => (
        <li>
          <a href={`/guides/${guide.slug}/`}>
            <span>{guide.title}</span>
            <small>{guide.metaDescription}</small>
          </a>
        </li>
      ))}
    </ul>

    <h2 class="topical-guides-heading">Compound interest learning</h2>
    <p class="section-intro">
      Go deeper on rates, compounding frequency, inflation, and the difference
      between nominal growth and real purchasing power.
    </p>
    <ul class="guide-list topical-guide-list">
      {topicalGuides.map((guide) => (
        <li>
          <a href={`/guides/${guide.slug}/`}>
            <span>{guide.title}</span>
            <small>{guide.metaDescription}</small>
          </a>
        </li>
      ))}
    </ul>

    <h2 class="calculator-guides-heading">Calculator guides</h2>
    <p class="section-intro">
      Learn how each calculator works, walk through its inputs and results,
      and review practical examples and common mistakes.
    </p>
    <ul class="guide-list calculator-guide-list">
      {calculatorGuides.map((guide) => (
        <li>
          <a href={`/guides/${guide.slug}/`}>
            <span>{guide.title}</span>
            <small>{guide.intro}</small>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  main {
    width: min(760px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 5rem 0;
  }

  .eyebrow {
    color: var(--link-color);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.25rem, 7vw, 3.75rem);
    letter-spacing: -0.04em;
    line-height: 1.08;
  }

  .intro {
    color: var(--muted-text-color);
  }

  h2 {
    margin: 2.5rem 0 0;
    font-size: 1.45rem;
    letter-spacing: -0.02em;
  }

  .section-intro {
    margin: 0.45rem 0 0;
    color: var(--muted-text-color);
    line-height: 1.6;
  }

  .calculator-guides-heading {
    margin-top: 3.5rem;
  }

  .comparison-guides-heading,
  .topical-guides-heading {
    margin-top: 3.5rem;
  }

  .comparison-guide-list,
  .topical-guide-list,
  .calculator-guide-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .guide-list {
    display: grid;
    gap: 0.85rem;
    margin: 2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .guide-list a {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--card-background);
    color: var(--link-color);
    font-weight: 750;
    padding: 1rem;
    text-decoration: none;
  }

  .guide-list a:hover {
    border-color: var(--link-color);
    background: var(--subtle-background);
  }

  .guide-list small {
    margin-top: 0.35rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.5;
  }

  @media (max-width: 620px) {
    .comparison-guide-list,
    .topical-guide-list,
    .calculator-guide-list {
      grid-template-columns: 1fr;
    }
  }
</style>
