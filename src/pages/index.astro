---
import { contentItems } from '../data/content';
import Layout from '../layouts/Layout.astro';

const calculators = contentItems
  .filter((item) => item.category === 'calculator')
  .sort((a, b) => a.priority - b.priority);
---

<Layout
  title="AutomatorLabs | Free Calculators and Tools"
  description="Free calculators and tools for money, data, and automation."
>
  <main>
    <section>
      <h1>AutomatorLabs</h1>
      <p>Free calculators and tools for money, data, and automation.</p>

      <ul class="content-list">
        {calculators.map((item) => (
          <li>
            {item.status === 'live' ? (
              <a href={item.url}>{item.title}</a>
            ) : (
              <span>{item.title}</span>
            )}
            <small>{item.status === 'live' ? 'Live' : 'Planned'}</small>
          </li>
        ))}
      </ul>
    </section>
  </main>
</Layout>

<style>
  main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 5rem 0;
  }

  section {
    max-width: 720px;
  }

  h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  p {
    color: #586176;
    font-size: 1.15rem;
  }

  .content-list {
    display: grid;
    gap: 0.75rem;
    margin-top: 2rem;
    padding: 0;
    list-style: none;
  }

  .content-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  a {
    color: #3158d3;
    font-weight: 700;
  }

  .content-list span {
    color: #4b5563;
    font-weight: 700;
  }

  small {
    border-radius: 999px;
    background: #eef1f7;
    color: #697386;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    text-transform: uppercase;
  }
</style>
