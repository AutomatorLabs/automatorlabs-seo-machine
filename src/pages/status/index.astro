---
import Layout from '../../layouts/Layout.astro';
import { calculatorConfigs } from '../../data/calculators';
import { programmaticSeoClusters } from '../../data/programmatic-seo/clusters';
import { topics } from '../../data/topics';

const calculatorCount = Object.keys(calculatorConfigs).length;
const programmaticClusterCount = programmaticSeoClusters.length;
const topicSectionCount = topics.length;
---

<Layout
  title="Status | AutomatorLabs"
  description="Static release verification page for AutomatorLabs public routes and source-backed counts."
  noindex={true}
>
  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">Status</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Release verification</p>
      <h1>AutomatorLabs status</h1>
      <p class="intro">
        This is a static health page for release checks. If it loads with the
        expected styles, links, and counts, the published build artifact is
        serving core public entry points from source-controlled data.
      </p>
    </header>

    <section class="status-card" aria-labelledby="health-heading">
      <h2 id="health-heading">Build health</h2>
      <p class="health-text">
        Build artifact is designed to be environment-independent and static.
        This page does not report runtime infrastructure, databases, or API
        dependencies because the public site is generated from source data at
        build time.
      </p>
    </section>

    <section class="status-grid" aria-label="Public status details">
      <article class="status-card">
        <h2>Site</h2>
        <dl class="metrics">
          <div>
            <dt>Site name</dt>
            <dd>AutomatorLabs</dd>
          </div>
          <div>
            <dt>Calculators</dt>
            <dd>{calculatorCount}</dd>
          </div>
          <div>
            <dt>Programmatic clusters</dt>
            <dd>{programmaticClusterCount}</dd>
          </div>
          <div>
            <dt>Topic sections</dt>
            <dd>{topicSectionCount}</dd>
          </div>
        </dl>
      </article>

      <article class="status-card">
        <h2>Quick links</h2>
        <ul class="link-list">
          <li><a href="/">Homepage</a></li>
          <li><a href="/calculators/">Calculators</a></li>
          <li><a href="/guides/">Guides</a></li>
          <li><a href="/topics/">Topics</a></li>
          <li><a href="/examples/">Examples</a></li>
          <li><a href="/sitemap-index.xml">Sitemap</a></li>
        </ul>
      </article>
    </section>
  </main>
</Layout>

<style>
  main {
    width: min(960px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4rem 0 5rem;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .breadcrumbs li + li::before {
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a,
  .link-list a {
    color: var(--link-color);
  }

  .breadcrumbs a {
    text-decoration: none;
  }

  .breadcrumbs a:hover,
  .link-list a:hover {
    text-decoration: underline;
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--text-color);
    font-weight: 650;
  }

  .page-header {
    max-width: 780px;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    margin: 0 0 0.6rem;
    color: var(--link-color);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    letter-spacing: -0.045em;
    line-height: 1.05;
  }

  .intro {
    margin: 1rem 0 0;
    color: var(--muted-text-color);
    font-size: 1.12rem;
    line-height: 1.7;
  }

  .status-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .status-card {
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--card-background);
    box-shadow: 0 12px 35px var(--shadow-color);
    padding: clamp(1.35rem, 4vw, 2rem);
  }

  h2 {
    margin: 0 0 0.9rem;
    font-size: clamp(1.35rem, 3vw, 1.85rem);
    letter-spacing: -0.03em;
  }

  .health-text {
    margin: 0;
    color: var(--muted-text-color);
    line-height: 1.75;
  }

  .metrics {
    display: grid;
    gap: 0.9rem;
    margin: 0;
  }

  .metrics div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  .metrics div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .metrics dt {
    color: var(--muted-text-color);
    font-weight: 600;
  }

  .metrics dd {
    margin: 0;
    color: var(--heading-color);
    font-weight: 750;
  }

  .link-list {
    display: grid;
    gap: 0.8rem;
    margin: 0;
    padding-left: 1.15rem;
  }

  .link-list li {
    color: var(--muted-text-color);
  }

  @media (max-width: 760px) {
    main {
      padding-top: 3rem;
    }

    .status-grid {
      grid-template-columns: 1fr;
    }

    .metrics div {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
