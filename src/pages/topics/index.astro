---
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { topics } from '../../data/topics';
import Layout from '../../layouts/Layout.astro';
import {
  createBreadcrumbSchema,
  serializeJsonLd,
} from '../../lib/programmatic-seo/schema';

const site = Astro.site ?? new URL('https://automatorlabs.co');
const breadcrumbSchema = serializeJsonLd(
  createBreadcrumbSchema(
    [
      { name: 'Home', url: '/' },
      { name: 'Browse by Topic', url: '/topics/' },
    ],
    site,
  ),
);
---

<Layout
  title="Browse by Topic | AutomatorLabs"
  description="Browse AutomatorLabs financial calculators, guides, and worked examples by topic, including investing, retirement, FIRE, mortgages, debt, savings, inflation, taxes, loans, and net worth."
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main id="main-content">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">Browse by Topic</li>
      </ol>
    </nav>

    <header class="page-header">
      <p class="eyebrow">Browse by topic</p>
      <h1>Find calculators, guides, and examples by topic</h1>
      <p class="intro">
        Use this hub to move through AutomatorLabs by financial topic instead
        of by content type. Each section points to calculators, guide hubs, and
        worked examples that explain the assumptions behind the numbers.
      </p>
    </header>

    <div class="topic-grid">
      {topics.map((topic) => (
        <section class="topic-card" aria-labelledby={`${topic.title.toLowerCase().replaceAll(' ', '-')}-topic-heading`}>
          <h2 id={`${topic.title.toLowerCase().replaceAll(' ', '-')}-topic-heading`}>
            {topic.title}
          </h2>
          <p>{topic.description}</p>

          <div class="link-columns">
            <div>
              <h3>Calculators</h3>
              <ul>
                {topic.calculators.map((link) => (
                  <li><a href={link.url}>{link.title}</a></li>
                ))}
              </ul>
            </div>
            <div>
              <h3>Guides</h3>
              <ul>
                {topic.guides.map((link) => (
                  <li><a href={link.url}>{link.title}</a></li>
                ))}
              </ul>
            </div>
            <div>
              <h3>Examples</h3>
              <ul>
                {topic.examples.map((link) => (
                  <li><a href={link.url}>{link.title}</a></li>
                ))}
              </ul>
            </div>
          </div>
        </section>
      ))}
    </div>

    <NewsletterSignup
      compact
      headline="Get new calculators and topic guides"
      description="Follow new AutomatorLabs tools, worked examples, and practical planning guides as they are published."
    />
  </main>
</Layout>

<style>
  main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li + li::before {
    margin-right: 0.45rem;
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a {
    color: var(--link-color);
    text-decoration: none;
  }

  .page-header {
    max-width: 860px;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--link-color);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0.6rem 0 1rem;
    font-size: clamp(2.45rem, 8vw, 4.8rem);
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .intro {
    margin: 0;
    color: var(--muted-text-color);
    font-size: 1.14rem;
    line-height: 1.75;
  }

  .topic-grid {
    display: grid;
    gap: 1rem;
  }

  .topic-card {
    border: 1px solid var(--border-color);
    border-radius: 18px;
    background: var(--card-background);
    box-shadow: 0 12px 35px var(--shadow-color);
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .topic-card h2 {
    margin: 0 0 0.65rem;
    font-size: clamp(1.55rem, 3vw, 2rem);
    letter-spacing: -0.03em;
  }

  .topic-card > p {
    max-width: 820px;
    margin: 0 0 1.4rem;
    color: var(--muted-text-color);
    line-height: 1.65;
  }

  .link-columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .link-columns h3 {
    margin: 0 0 0.65rem;
    font-size: 0.84rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .link-columns ul {
    display: grid;
    gap: 0.5rem;
    margin: 0;
    padding-left: 1.1rem;
  }

  .link-columns a {
    font-weight: 700;
    line-height: 1.45;
  }

  @media (max-width: 760px) {
    main {
      padding: 3rem 0;
    }

    .link-columns {
      grid-template-columns: 1fr;
    }
  }
</style>
