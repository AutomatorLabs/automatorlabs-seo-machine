---
import WealthRank from '../components/WealthRank.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import Layout from '../layouts/Layout.astro';
import {
  createFaqSchema,
  serializeJsonLd,
} from '../lib/programmatic-seo/schema';

const title =
  'Income & Net Worth Percentile Calculator — Where Do You Rank in the World?';
const description =
  'Enter your income or net worth and see exactly where you rank — in your own country and against every adult on Earth. Free, instant, 216 countries. Data from the World Inequality Database.';

const faqs = [
  {
    question: 'How is my percentile calculated?',
    answer:
      'Your figure is compared against the full income or wealth distribution of your country, using data from the World Inequality Database (the research project behind Thomas Piketty, Emmanuel Saez and Gabriel Zucman). For the global comparison, your number is converted using purchasing power parity, which adjusts for the fact that the same money buys different amounts in different countries.',
  },
  {
    question: "Why does the tool say 'per adult'?",
    answer:
      'The underlying data splits household income and wealth equally between the adults in a household. So if you share finances with a partner, enter roughly half of your household total for an accurate comparison.',
  },
  {
    question: 'Is my data saved or sent anywhere?',
    answer:
      'No. Everything is calculated in your browser. Nothing you type is stored, transmitted, or logged.',
  },
  {
    question: 'Why am I in a much higher percentile globally than in my own country?',
    answer:
      "Because global inequality is far larger than inequality within any single country. A median income in a wealthy country typically lands in the top 10 percent worldwide. Most people are surprised by this — it's the most interesting thing this calculator shows.",
  },
  {
    question: 'How accurate are the currency conversions?',
    answer:
      "Exchange rates are approximate snapshots refreshed periodically, not live market quotes, so treat conversions as close-enough rather than exact. The percentile itself comes from the underlying distribution data and doesn't depend on the display currency.",
  },
];

const faqStructuredDataJson = serializeJsonLd(createFaqSchema(faqs));
---

<Layout
  title={title}
  description={description}
  socialImagePath="/social/automatorlabs-default-social.svg"
  socialImageAlt="Where Do You Rank? An income and net worth percentile calculator comparing you to your country and the world."
>
  <script type="application/ld+json" set:html={faqStructuredDataJson} />

  <main id="main-content">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-current="page">Where Do You Rank</li>
      </ol>
    </nav>

    <WealthRank />

    <section class="faq-section" aria-labelledby="faq-heading">
      <h2 id="faq-heading">Frequently asked questions</h2>
      <div class="faq-list">
        {faqs.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="next-steps" aria-labelledby="next-steps-heading">
      <h2 id="next-steps-heading">Turn the number into a plan</h2>
      <p>
        Know your rank? <a href="/calculators/fire-calculator/">See what financial independence would take from here</a>,
        or <a href="/calculators/net-worth-calculator/">track your net worth over time</a> and watch the percentile move.
        Or <a href="/calculators/">browse all calculators</a>.
      </p>
    </section>

    <section class="cross-link" aria-labelledby="cross-link-heading">
      <h2 id="cross-link-heading">More from the Data Playground</h2>
      <p>
        Liked seeing where you rank? Check <a href="/birth-lottery/">The Birth Lottery</a> —
        the odds of being born in your country, in your year — or
        <a href="/purple-star-chart/">Your Purple Star Chart</a>, the thousand-year-old
        Eastern birth chart, explained in plain English.
      </p>
    </section>

    <NewsletterSignup compact />
  </main>
</Layout>

<style>
  main {
    width: min(900px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4.5rem 0;
  }

  .breadcrumbs {
    margin-bottom: 1.5rem;
    color: var(--muted-text-color);
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .breadcrumbs li {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .breadcrumbs li + li::before {
    color: var(--muted-text-color);
    content: '›';
  }

  .breadcrumbs a {
    color: var(--link-color);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--text-color);
    font-weight: 650;
  }

  .faq-section,
  .next-steps,
  .cross-link {
    margin-top: 3.5rem;
    border-top: 1px solid var(--border-color);
    padding-top: 2rem;
  }

  .faq-section h2,
  .next-steps h2,
  .cross-link h2 {
    margin: 0 0 0.9rem;
    color: var(--heading-color);
    font-size: 1.55rem;
    letter-spacing: -0.02em;
  }

  .faq-list details {
    border-bottom: 1px solid var(--border-color);
    padding: 1rem 0;
  }

  .faq-list summary {
    cursor: pointer;
    font-weight: 700;
    color: var(--text-color);
  }

  .faq-list details p {
    max-width: 760px;
    margin: 0.65rem 0 0;
    color: var(--muted-text-color);
    line-height: 1.7;
  }

  .next-steps p,
  .cross-link p {
    margin: 0;
    max-width: 74ch;
    color: var(--text-color);
    font-size: 1rem;
    line-height: 1.8;
  }

  .next-steps a,
  .cross-link a {
    color: var(--link-color);
  }

  @media (max-width: 620px) {
    main {
      padding: 3rem 0;
    }
  }
</style>
